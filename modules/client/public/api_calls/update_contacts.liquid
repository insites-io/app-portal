---
to: 'https://{{context.location.host}}/core/api/v1/contacts'
format: http
request_type: PUT
callback: >
  {% assign response_hash = response.body | parse_json %}
  {% log response_hash.items.email, type: 'Register - Update CRM Contact' %} 
request_headers: >
    {
        "Content-Type": "application/json",
        "Authorization": "<%= instance_api_key =%>"
    }
---
{
    "id": "{{form.id}}",
    "email": "{{form.email}}",
    "company_uuid": null,
    "mobile_phone_country_code": "{{form.mobile_phone_country_code}}",
    "mobile_phone_number": "{{form.mobile_phone_number}}",
    "addresses": [
        {
        "address_1": "{{form.address_1}}",
        "address_2": "{{form.address_2}}",
        "suburb": "{{form.suburb}}",
        "state": "{{form.state}}",
        "country": "{{form.country}}",      
        "default_address": true,
        "id": null
        }
    ]
}