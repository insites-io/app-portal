---
name: update_contact_address
to: 'https://{{context.location.host}}/core/api/v1/contacts/addresses'
format: http
request_type: PUT
#callback: >
#   {% log response, type: 'response object' %}
#   {% assign response_hash = response.body | parse_json %}
#   {% log response_hash, type: 'response body as hash' %} 
request_headers: >
    {% include 'modules/client/api_headers' %}
---
{%- assign props = data.properties -%}
{
    "uuid": "{{ props.contact_address_uuid }}", //REQUIRED
    "contact_uuid": "{{ props.contact_uuid }}", //REQUIRED
    "address_label": "{{ props.address_1 }}", //REQUIRED
    "default_address": true,
    "address_1": "{{ props.address_1 }}",
    "address_2": "{{ props.address_2 }}",
    "suburb": "{{ props.suburb }}",
    "state": "{{ props.state }}",    
    "postcode": "{{ props.postcode }}",
    "country": "{{ props.country }}"
}