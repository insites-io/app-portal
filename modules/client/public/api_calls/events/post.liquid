---
name: add_events
to: 'https://{{context.location.host}}/core/api/v1/events'
format: http
request_type: POST
#callback: >
#  {% assign response_hash = response.body | parse_json %}
#  {% log response_hash.items.properties.description, type: 'Event response' %} 
request_headers: >
    {
        "Content-Type": "application/json",
        {% if context.location.host == 'insites-app-client-portal-dev1.staging.oregon.platform-os.com' %}
        "Authorization": "<%= instance_api_key =%>"
        {% elsif context.location.host == 'insites-app-client-portal-dev3.staging.oregon.platform-os.com' %}
        "Authorization": "<%= instance_api_key_dev3 =%>"
        {% else %}
        "Authorization": "<%= instance_api_key_uat =%>"
        {% endif %}
    }
---

{%- capture details -%}
    {{ data.details }}
{%- endcapture -%}

{
    "font_icon": "{{ data.font_icon }}",
    "font_icon_color": "{{ data.font_icon_color }}",
    "description": "{{ data.description }}",
    "details": {{ details | json }},
    "related_type": "{{ data.related_type }}",
    "related_uuid": "{{ data.related_uuid }}"
}