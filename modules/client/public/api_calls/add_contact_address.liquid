---
name: add_contact_address
to: 'https://{{context.location.host}}/core/api/v1/contacts/addresses'
format: http
request_type: POST
callback: >  
  {% log response, type: 'response object' %} 
  {% assign response_hash = response.body | parse_json %}
  {% log response_hash.items.properties.address_label, type: 'Add CRM Contact Address' %}
request_headers: >
    {
        "Content-Type": "application/json",
        "Authorization": "<%= instance_api_key =%>"
    }
---

{%  liquid 
    if data.contact_uuid
        assign contact_uuid = data.contact_uuid
    else
        graphql user = 'modules/client/account/get_user_uuid', id: data.id | dig: 'items','results' | first
        assign contact_uuid = user.uuid
    endif

    assign props = data.properties
%}

{
    "contact_uuid": "{{contact_uuid}}",
    "address_label": "{{props.address_1}}", 
    "default_address": true,
    "address_1": "{{props.address_1}}",
    "address_2": "{{props.address_2}}",
    "suburb": "{{props.suburb}}",
    "state": "{{props.state}}",
    "postcode": "{{ props.postcode }}",
    "country": "{{props.country}}"
}