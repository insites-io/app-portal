---
name: add_payment
to: 'https://{{context.location.host}}/ecommerce/api/v1/payments'
format: http
request_type: POST
callback: >
  {% log response, type: 'add payment - response object' %}
  {% assign response_hash = response.body | parse_json %}
  {% log response_hash, type: 'add payment - response body as hash' %} 
request_headers: >
    {% include 'modules/client/api_headers' %}
---

{%- capture payment_gateway_details -%}
    {{ data.payment_gateway_details }}
{%- endcapture -%}

{% log data, type: "data -- post add_payment" %}

{
    "payload": {
        "notes": "{{ data.notes | default: "notes" }}",
        "amount": "{{ data.amount }}",
        "source": "credit_card",
        "status": "{{ data.payment_status }}",
        "bank_bsb": "",
        "currency": "{{ data.currency }}",
        "bank_name": "",
        "date_time": "{{ data.date_time }}",
        "card_brand": "{{ data.card_brand }}",
        "order_uuid": "{{ data.order_uuid }}",
        "card_expiry_year": "{{ data.card_exp_year }}",
        "card_expiry_month": "{{ data.card_exp_month }}",
        "payment_method_name": "",
        "payment_gateway_name": "{{ data.payment_gateway_name }}",
        "bank_last_four_digits": "",
        "card_last_four_digits": "{{ data.card_last4 }}",
        "payment_gateway_details": "{{ data.payment_gateway_details | json }}"
    }
}