---
to: 'https://{{context.location.host}}/core/api/v1/companies'
format: http
request_type: POST
callback: >
  {% assign response_hash = response.body | parse_json %}
   {% log response_hash.items.properties.company_name, type: 'Register - Add CRM Company' %} 
  {% graphql res = 'modules/client/account/set_company_uuid', id: form.id, company_uuid: response_hash.items.properties.uuid %}
  {% log res, type: 'Register - Set company_uuid' %}
request_headers: >
    {
        "Content-Type": "application/json",
        "Authorization": "instance_92d3be32-b64f-4909-91fe-2db66783f617_Qz26R453IgamR5S7j18aHEheVbgqmV3zycGGc3UyE8c"
    }
---

{
    "company_name": "{{form.company_name}}",
    "registered_business_number": "{{form.registered_business_number}}",
    "email_1": "{{form.email_1}}",
    "mobile_phone_country_code": "{{form.company_mobile_phone_country_code}}",
    "mobile_phone_number": "{{form.company_mobile_phone_number}}",
    "addresses": [
        {
            "address_label": "Default Address",
            "address_1": "{{form.company_address_1}}",
            "address_2": "{{form.company_address_2}}",
            "suburb": "{{form.company_suburb}}",
            "state": "{{form.company_state}}",
            "country": "{{form.company_country}}",      
            "default_address": true
        }
    ]
}