---
name: create_card
to: https://api.stripe.com/v1/customers/{{ data.customer_id }}/sources
enabled: true
trigger_condition: true
request_type: POST
callback: >
  {%- assign response_data = response.body | to_hash -%}
  {% if response_data.error %}
    {%- log response_data.error, type: 'modules/client/create_card' -%}
  {% endif %}
headers: >
  {% if data %}
    {%- include 'modules/client/stripe/get_stripe_settings' -%}
    {%- log context.exports.stripe.data.sk_key, type: 'TEST create_card sk_key' -%}
    {
      "Content-Type": "application/x-www-form-urlencoded",
      "Authorization": "Bearer {{context.exports.stripe.data.sk_key}}"
    }
  {% endif %}
---
source={{ data.source }}{% for data in data.metadata %}&metadata[{{ data[0] }}]={{ data[1] | url_encode }}{% endfor %}
{% log 'create_card', type: 'TEST: api_call create_card' %}