---
name: create_charge
to: https://api.stripe.com/v1/charges
enabled: true
format: https
trigger_condition: true
request_type: Post
callback: >

  {%- assign response_data = response.body | to_hash -%}
  {%- log response_data, type: 'modules/insites_payments/create_charge -> response_data' -%}
  
  {% if response_data.error %}
    {%- log response_data.error, type: 'modules/insites_payments/create_charge' -%}
  {% endif %}
request_headers: >
  {% if data %}
    {% if context.environment == "production" %}
      {% assign stripe_sk_key = context.constants.insites_stripe_sk_live_key %}
      {% assign stripe_account_id = context.constants.insites_stripe_account_id %}
    {% else %}
      {% assign stripe_sk_key = context.constants.stripe_sk_test_key %}
      {% assign stripe_account_id = context.constants.stripe_account_id %}
    {% endif %}

    {
      "Content-Type": "application/x-www-form-urlencoded",
      "Authorization": "Bearer {{ stripe_sk_key }}",
      "Idempotency-Key": "{{ data.idempotency_key }}",
      "Stripe-Account": "{{ stripe_account_id }}"
    }
  {% endif %}
---
{%- assign allowed_params = 'application_fee,currency,description,statement_descriptor,capture,customer,destination,transfer_group,amount,source' | split: ',' -%}
{%- assign request_params = '' | split: "|" -%}
{%- for var in data -%}
  {%- if var[1] != blank -%}
    {%- if var[0] == 'metadata' and var[1].size > 0 -%}
      {% assign metadata_hash = var[1] | to_hash %}
      {% for meta in metadata_hash %}
        {%- capture pair %}metadata[{{ meta[0] }}]={{ meta[1] | url_encode }}{% endcapture -%}
        {%- assign request_params = request_params | add_to_array: pair -%}
      {% endfor %}
    {% elsif allowed_params contains var[0] %}
      {%- capture pair %}{{ var[0] }}={{ var[1] | url_encode }}{% endcapture -%}
      {%- assign request_params = request_params | add_to_array: pair -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
{{ request_params | join: '&' | html_safe }}