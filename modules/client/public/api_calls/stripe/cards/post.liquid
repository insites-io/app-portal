---
name: create_card
to: https://api.stripe.com/v1/customers/{{ data.payment_method_token }}/sources
enabled: true
trigger_condition: true
request_type: POST
callback: >
  {%- assign response_data = response.body | to_hash -%}
  {% if response_data.error %}
    {% comment %}  
      Uncomment this code when debugging error when creating stripe card 
      log response_data.error, type: 'client > api calls > stripe > cards > post.liquid == response_data'  
    {% endcomment %}
  {% endif %}
request_headers: >
  {% if data %}
    {%- include 'modules/client/stripe/get_stripe_settings' -%}
    {
      "Content-Type": "application/x-www-form-urlencoded",
      "Authorization": "Bearer {{ context.exports.stripe.data.sk_key }}"
    }
  {% endif %}
---
source={{ data.source }}{% for data in data.metadata %}&metadata[{{ data[0] }}]={{ data[1] | url_encode }}{% endfor %}