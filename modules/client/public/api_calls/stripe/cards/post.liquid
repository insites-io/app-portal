---
name: create_card
to: https://api.stripe.com/v1/customers/{{ data.payment_method_token }}/sources
enabled: true
trigger_condition: true
request_type: POST
callback: >
  {%- assign response_data = response.body | to_hash -%}
  {% if response_data.error %}
    {%- log response_data.error, type: 'client > api calls > stripe > cards > post.liquid == response_data' -%}
  {% endif %}
request_headers: >
  {% if data %}
    {% if context.environment == "production" %}
      {% assign stripe_sk_key = context.constants.insites_stripe_sk_live_key %}
    {% else %}
      {% assign stripe_sk_key = context.constants.stripe_sk_test_key %}
    {% endif %}

    {
      "Content-Type": "application/x-www-form-urlencoded",
      "Authorization": "Bearer {{ stripe_sk_key }}"
    }
  {% endif %}
---
source={{ data.source }}{% for data in data.metadata %}&metadata[{{ data[0] }}]={{ data[1] | url_encode }}{% endfor %}