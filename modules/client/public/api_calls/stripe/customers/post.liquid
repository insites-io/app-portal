---
name: create_customer
to: https://api.stripe.com/v1/customers
enabled: true
trigger_condition: true
request_type: POST
callback: >
  {%- assign response_data = response.body | to_hash -%}
  {%- log response_data, type: 'response_data > create_customer' -%}
  {% if response_data.error %}
    {%- log response_data.error, type: 'post > create_customer' -%}
  {% endif %}
request_headers: >
  {% if data %}
    {% if context.environment == "production" %}
      {% assign stripe_sk_key = context.constants.insites_stripe_sk_live_key %}
    {% else %}
      {% assign stripe_sk_key = context.constants.stripe_sk_test_key %}
    {% endif %}

    {
      "Content-Type": "application/x-www-form-urlencoded",
      "Authorization": "Bearer {{ stripe_sk_key }}"
    }
  {% endif %}
---

{%- if data.email -%}email={{ data.email | url_encode }}&{%- endif -%}{%- if data.description -%}description={{ data.description | url_encode }}&{%- endif -%}name={{ data.name | url_encode }}&{%- if data.source -%}source={{ data.source }}{%- endif -%}{%- for data in data.metadata -%}&metdata[{{ data[0] }}]={{ data[1] | url_encode }}{%- endfor -%}