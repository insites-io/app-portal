---
name: update_company_address
to: 'https://{{context.location.host}}/core/api/v1/companies/addresses'
format: http
request_type: PUT
#callback: >
#   {% log response, type: 'response object' %}
#   {% assign response_hash = response.body | parse_json %}
#   {% log response_hash, type: 'response body as hash' %} 
request_headers: >
    {
        "Content-Type": "application/json",
        "Authorization": "<%= instance_api_key =%>"
    }
---
{%- assign props = data.properties -%}
{
    "uuid": "{{ props.company_address_uuid }}", //REQUIRED
    "company_uuid": "{{ props.company_uuid }}", //REQUIRED
    "address_label": "{{ props.company_address_1 }}", //REQUIRED
    "default_address": true,
    "address_1": "{{ props.company_address_1 }}",
    "address_2": "{{ props.company_address_2 }}",
    "suburb": "{{ props.company_suburb }}",
    "state": "{{ props.company_state }}",    
    "postcode": "{{ props.company_postcode }}",
    "country": "{{ props.company_country }}"
}