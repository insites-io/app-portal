---
name: update_company
to: 'https://{{context.location.host}}/core/api/v1/companies'
format: http
request_type: PUT
# callback: >
#   {% log response, type: 'response object' %}
#   {% assign response_hash = response.body | parse_json %}
#   {% log response_hash, type: 'response body as hash' %} 
request_headers: >
    {
        "Content-Type": "application/json",
        "Authorization": "<%= instance_api_key =%>"
    }
---    
{
    "id": "{{data.id}}",
    "company_name": "{{data.company_name}}",
    "registered_business_number": "{{data.registered_business_number}}",
    "email_1": "{{data.email_1}}",
    "mobile_phone_country_code": "{{data.company_mobile_phone_country_code}}",
    "mobile_phone_number": "{{data.company_mobile_phone_number}}",
    "addresses": [
        {
        "address_1": "{{data.company_address_1}}",
        "address_2": "{{data.company_address_2}}",
        "suburb": "{{data.company_suburb}}",
        "state": "{{data.company_state}}",
        "country": "{{data.company_country}}",      
        "default_address": true
        }
    ]
}