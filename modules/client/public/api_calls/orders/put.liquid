---
name: update_order
to: 'https://{{context.location.host}}/ecommerce/api/v1/orders'
format: http
request_type: PUT
callback: >
  {% assign response_hash = response.body | parse_json %}
request_headers: >
    {% include 'modules/client/api_headers' %}
---

{% log data, type: "Update Order" %}

{% if data.is_discount_code_enabled == "false" %}
    {% assign is_discount_code_enabled = false %}
{% else %}
    {% assign is_discount_code_enabled = true %}
{% endif %}

{
    "payload": {
        "id": "{{ data.id }}", 
        "order_reference": "{{ data.order_reference }}", 
        "order_status": "{{ data.order_status }}",
        "order_shipping_status": "",
        "order_payment_status": "{{ data.order_payment_status }}",
        "order_contact_uuid": "",
        "order_contact_first_name": "{{ data.order_first_name }}", 
        "order_contact_last_name": "{{ data.order_last_name }}", 
        "order_contact_email": "{{ data.order_email }}",
        "order_contact_phone_country_code": "",
        "order_contact_phone_number": "",
        "order_company_uuid": "",
        "order_company_name": "",
        "order_company_email": "",
        "order_company_phone_country_code": "",
        "order_company_phone_number": "{{ data.order_phone }}",
        "date_time": "{{ data.date_time }}",
        "notes": "",
        "currency": "{{ data.currency }}",
        "subtotal_amount": {{ data.order_value | times: 1.0 }},
        "total_tax_amount": {{ data.total_tax_amount | times: 1.0 }},
        "total_shipping_amount": {{ data.total_shipping_amount | times: 1.0 }},
        "total_amount": {{ data.total_amount | times: 1.0 }},
        "total_amount_paid": {{ data.total_amount | times: 1.0 }},
        {% comment %} "discount_code_uuids": ["f06f6c0c-90ca-4658-bc3a-bef46cbc3c0d"], {% endcomment %}
        {% if is_discount_code_enabled %}
            {% if data.discount_code_uuids.size != 0 %}
                "discount_code_uuids": {{ data.discount_code_uuids | default: "" }},
            {% endif %}
        {% endif %}
        "total_discount_amount": {{ data.total_discount_amount | times: 1.0 | default: 0.0 }}


        {% comment %} 

        Only include params that is needed during oder update process

        "billing_address_1": "",
        "billing_address_2": "",
        "billing_address_3": "",
        "billing_city": "",
        "billing_county": "",
