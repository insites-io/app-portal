---
name: update_crm_via_invite_user
to: 'https://{{context.location.host}}/core/api/v1/contacts'
format: http
enabled: true
trigger_condition: true
request_type: PUT
callback: >
    {% assign response_hash = response.body | parse_json %}
    {% graphql create_contact_custom_field = "modules/client/account/create_contact_custom_field", contact_uuid: response_hash.items.uuid %}
    {% log create_contact_custom_field, type: "create_contact_custom_field -- put" %}
request_headers: >
    {% include 'modules/website/api_headers' %}
---
{
    "id": "{{ data.id }}", //REQUIRED
    "first_name": "{{ data.first_name }} ",
    "last_name": "{{ data.last_name }} ",
    "email": "{{ data.email }}", //REQUIRED
    "company_uuid": "{{ data.company_uuid }}",
    "work_phone_country_code": "{{ data.mobile_phone_country_code }}",
    "work_phone_number": "{{ data.mobile_phone_number }}",
    "job_title": "{{ data.job_title }}"
}