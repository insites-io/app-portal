---
to: 'https://{{context.location.host}}/ecommerce/api/v1/orders'
format: http
request_type: POST
callback: >
  {% assign response_hash = response.body | parse_json %}
   {% log response_hash.items.properties.company_name, type: 'Pay Bill - Add Order' %} 
  {% graphql res = 'modules/client/account/set_company_uuid', id: form.id, company_uuid: response_hash.items.properties.uuid %}
  {% log res, type: 'Register - Set company_uuid' %}
request_headers: >
    {
        "Content-Type": "application/json",
        "Authorization": "<%= instance_api_key =%>"
    }
---

{
    "payload": {
        "order_number": "2Z9V8B4124", //REQUIRED
        "user_id": "13", //REQUIRED
        "currency": "AUD", //REQUIRED
        "date_time": "2023-05-10T01:22:11.000Z", //REQUIRED
        "order_value": 9.99, //FLOAT
        "tax_amount": 0, //FLOAT
        "shipping_amount": 0, //FLOAT
        "total_amount": 9.99, //FLOAT
        "amount_due": 0, //FLOAT
        "total_discount_amount": 0, //FLOAT
        "is_enabled": true, //BOOLEAN
        "notes": null,
        "gateway_id": null,
        
        "tax_invoice_upload": {},
        "gateway_customer_id": null,
        "picking_slip_upload": {},
        
        "packaging_label_upload": {},
        "order_status": null,
        "order_payment_status": null,
        "shipping_status": null,
        "tracking_code": null,
        "freight_supplier": null,
        "freight_method": null
    }
}