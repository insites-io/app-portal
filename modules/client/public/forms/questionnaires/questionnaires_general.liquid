---
name: questionnaires_general
resource: modules/client/questionnaires
resource_owner: anyone
redirect_to: /client-portal/questionnaires-additional-details/{{form.id}}
fields:
  properties:
    user_id:
      validation:
        presence: true
    year:
      validation:
        presence: true
    have_you_heard:
      validation:
        presence: true
    howd_you_learn:
      validation:
        presence: true
    reason_for_visit:
      validation:
        presence: true
    personal_email:
      validation:
        presence: true
    primary_phone:  
    previous_job:    
    service_of_interest:
      validation:
        presence: true
    attach_documents:    
default_payload: |-
  {%- assign year_now = 'now' | date: '%Y' -%}
  {
    "properties_attributes": {
      "user_id": "{{context.current_user.id}}",
      "year": "{{year_now}}"
    }
  }
callback_actions: |-    
  {%- session formID = form.id -%}
---

{%- graphql database_info = "modules/client/forms/get_database_info", $resource: "modules/client/questionnaires" | dig: "items","results" | first -%}
{%- assign groups = database_info.metadata.groups | sort_by: "weight" -%}
{%- assign fields = database_info.properties -%}
{%- assign form = form | add_hash_key: "metadata", fields -%}


{%- form html-class: 'insites-form insites-form-code' html-novalidate: 'novalidate' html-data-form: 'modules/client/questionnaires' -%}

    <input name="{{ form.fields.properties.user_id.name }}" type="hidden" value="{{context.current_user.id}}" >
    <input name="{{ form.fields.properties.year.name }}" type="hidden" value="{{'now' | date: '%Y'}}" >

    <div class="insites-form-grid">
    
    <div class="form-groups-tab">        
        {% include "modules/client/questionnaires-steps" %}
    </div>    

    
    <!-- Form Group: General -->
    <div class="form-group" active>

        <div class="column-1">
            <div class="spacer large"></div>
            <h2 class="heading-2">General Information</h2>
            <div class="spacer small"></div>
	    </div>

        <!-- Field: Have you ever heard about Insites? -->
        <div class="column-1">
            <div class="list-field-wrap" 
                data-type="string"
                data-ui="list_radio" 
                data-name="{{ form.fields.properties.have_you_heard.name }}"
                {%- if form.errors['properties.have_you_heard'] != nil -%} has-error="true" {%- endif -%}>
                <label class="list-field_label">{%- include 'modules/client/insites_database/label', form: form, name: 'have_you_heard' -%}</label>
                <div class="list-radio-options">
                    <ins-radio
                        label="Yes" value="Yes"
                        name="{{ form.fields.properties.have_you_heard.name }}"
                        {% if form.fields.properties.have_you_heard.value == 'Yes' %}checked{% endif %}>
                    </ins-radio>
                    <ins-radio
                        label="No" value="No"
                        name="{{ form.fields.properties.have_you_heard.name }}"
                        {% if form.fields.properties.have_you_heard.value == 'No' %}checked{% endif %}>
                    </ins-radio>
                </div>
                <p class="list-field_error">{{ form.errors['properties.have_you_heard'] }}</p>
            </div>
        </div>
    
        <!-- Field: How did you learn about Insites? -->
        <div class="column-2">
            <ins-select
                searchable 
                data-type="string"
                data-ui="list_select"
                label="{%- include 'modules/client/insites_database/label', form: form, name: 'howd_you_learn' -%}"
                name="{{ form.fields.properties.howd_you_learn.name }}"
                value="{{ form.fields.properties.howd_you_learn.value }}"
                error-message="{{ form.errors.howd_you_learn }}"
                
                {%- if form.errors['properties.howd_you_learn'] != nil -%} has-error {%- endif -%}>
                <ins-select-option label="Word of Mouth" value="Word of Mouth"></ins-select-option>
                <ins-select-option label="Online Ads" value="Online Ads"></ins-select-option>
                <ins-select-option label="Social Media" value="Social Media"></ins-select-option>
            </ins-select>
        </div>
    
        <!-- Field: What is the main reason you visit our website?  -->
        <div class="column-2">
            <ins-select
                searchable 
                data-type="string"
                data-ui="list_select"
                label="{%- include 'modules/client/insites_database/label', form: form, name: 'reason_for_visit' -%}"
                name="{{ form.fields.properties.reason_for_visit.name }}"
                value="{{ form.fields.properties.reason_for_visit.value }}"
                error-message="{{ form.errors['properties.reason_for_visit'] }}"
                
                {%- if form.errors['properties.reason_for_visit'] != nil -%} has-error {%- endif -%}>
                <ins-select-option label="Browsing" value="Browsing"></ins-select-option>
                <ins-select-option label="Enquire about services" value="Enquire about services"></ins-select-option>
                <ins-select-option label="Looking for work" value="Looking for work"></ins-select-option>
            </ins-select>
        </div>
    
        <!-- Field: Personal Email -->
        <div class="column-2">
            <ins-input 
                data-type="string"
                data-ui="text"
                label="{%- include 'modules/client/insites_database/label', form: form, name: 'personal_email' -%}"
                name="{{ form.fields.properties.personal_email.name }}"
                value="{{ form.fields.properties.personal_email.value }}"
                error-message="{{ form.errors['properties.personal_email'] }}"
                
                {%- if form.errors['properties.personal_email'] != nil -%} has-error {%- endif -%} 
                >
            </ins-input>
        </div>
    
        <!-- Field: Primary Phone -->
        <div class="column-2">
            <ins-input-tel 
                no-areacode
                id="primary_phone"
                data-type="string"
                data-ui="phone"
                label="{%- include 'modules/client/insites_database/label', form: form, name: 'primary_phone' -%}"
                name="{{ form.fields.properties.primary_phone.name }}"
                phonenum-value="{{ form.fields.properties.primary_phone.value }}"
                error-message="{{ form.errors['properties.primary_phone'] }}"
                
                {%- if form.errors['properties.primary_phone'] != nil -%} has-error {%- endif -%} 
                >
            </ins-input-tel>
        </div>
    
        <!-- Field: Why did you leave your previous job? -->
        <div class="column-1">
            <ins-textarea 
                
                data-type="string"
                data-ui="multi_line"
                label="{%- include 'modules/client/insites_database/label', form: form, name: 'previous_job' -%}"
                name="{{ form.fields.properties.previous_job.name }}"
                value="{{ form.fields.properties.previous_job.value }}"
                error-message="{{ form.errors['properties.previous_job'] }}"
                
                {%- if form.errors['properties.previous_job'] != nil -%} has-error {%- endif -%}>
            </ins-textarea>
        </div>
    
        <!-- Field: Which of our services are you interested in? -->
        <div class="column-1">
            <div class="list-checkbox" 
                data-type="array" 
                data-ui="list_checkbox"  
                data-name="{{ form.fields.properties.service_of_interest.name }}"
                {%- if form.errors['properties.service_of_interest'] != nil -%} has-error="true" {%- endif -%}>
                <label class="list-checkbox_label">{%- include 'modules/client/insites_database/label', form: form, name: 'service_of_interest' -%}</label>
                <div class="list-checkbox-options">
                    <ins-checkbox
                        label="Design" value="Design" 
                        name="{{ form.fields.properties.service_of_interest.name }}"
                        {%- if form.fields.properties.service_of_interest.value contains 'Design' -%} checked {%- endif -%}>
                    </ins-checkbox>
                    <ins-checkbox
                        label="Software Development" value="Software Development" 
                        name="{{ form.fields.properties.service_of_interest.name }}"
                        {%- if form.fields.properties.service_of_interest.value contains 'Software Development' -%} checked {%- endif -%}>
                    </ins-checkbox>
                    <ins-checkbox
                        label="Marketing" value="Marketing" 
                        name="{{ form.fields.properties.service_of_interest.name }}"
                        {%- if form.fields.properties.service_of_interest.value contains 'Marketing' -%} checked {%- endif -%}>
                    </ins-checkbox>
                    <ins-checkbox
                        label="Technical Support " value="Technical Support" 
                        name="{{ form.fields.properties.service_of_interest.name }}"
                        {%- if form.fields.properties.service_of_interest.value contains 'Technical Support ' -%} checked {%- endif -%}>
                    </ins-checkbox>
                </div>
                <p class="list-checkbox_error">{{ form.errors['properties.service_of_interest'] }}</p>
            </div>
        </div>
    
        <!-- Field: Attach Documents -->
        <div class="column-1">
            <ins-input-file
                data-multiple="false"
                data-name="{{ form.fields.properties.attach_documents.name }}"
                data-type="upload"
                data-ui="media_file"
                data-prop="attach_documents"
                label="{%- include 'modules/client/insites_database/label', form: form, name: 'attach_documents' -%}"
                accepted-files=""
                capture=""
                error-message="{{ form.errors['properties.attach_documents'] }}"
                
                {%- if form.errors['properties.attach_documents'] != nil -%} has-error {%- endif -%}>
            </ins-input-file>
        </div>
    </div>
    
    </div>
    
    <div class="insites-form-grid grid-x">        
        <div class="insites-form-buttons column-1 text-right">
            <a href="/client-portal/questionnaires"><ins-button type="button" label="CANCEL" icon="icon-close-1"></ins-button></a>
            <ins-button type="submit" label="SAVE & NEXT" icon-right="icon-arrow-forward" solid ></ins-button>
        </div>
    </div>
    
{%- endform -%}
    
<script id="modules/client/questionnaires">
    InsitesFormProcessor.setFormProps("modules/client/questionnaires", "modules/client/questionnaires", {{ form.fields.properties }}, "", true);
</script>

<script>
    // Update `countryCode` and `phonenum-value` attribute of the telephone
    let primary_phone = document.getElementById('primary_phone');
    primary_phone.addEventListener('didLoad', function(e){            
        let countryCode = {{ form.fields.properties.primary_phone.value | split: ' ' | default: '[]' }};        
        if (Array.isArray(countryCode) && countryCode.length == 2){
            primary_phone.setCountryCode(countryCode[0]);
            primary_phone.setAttribute('phonenum-value', countryCode[1]);
        }
    });    
</script>