---
name: questionnaires_confirmation
resource: modules/client/questionnaires
resource_owner: anyone
redirect_to: /questionnaires
fields:
  properties:
    agreement:
      validation:
        presence: true
---

{%- graphql database_info = "modules/client/forms/get_database_info", $resource: "modules/client/questionnaires" | dig: "items","results" | first -%}
{%- assign groups = database_info.metadata.groups | sort_by: "weight" -%}
{%- assign fields = database_info.properties -%}
{%- assign form = form | add_hash_key: "metadata", fields -%}


{%- form
    html-autocomplete: "off"
    html-id: "questionnaires-form"
    html-class: 'insites-form insites-form-code questionnaires-form' 
    html-novalidate: true
    html-onsubmit: "return validateQuestionnairesForm(event)" -%}

    <div class="insites-form-grid">
    
    <div class="form-groups-tab">        
        {% include "modules/client/questionnaires/questionnaires-steps" %}
    </div>
    
    {% include "modules/client/questionnaires/questionnaires-confirmation-inputs", form %}
        
    </div>

    <div class="spacer x-large"></div>
    
    <div class="insites-form-grid">
        <div class="insites-form-buttons column-1 text-right">    
          {% comment %} Desktop view of buttons {% endcomment %}
          <div class="show-for-large">
            <ins-button type="button" label="CANCEL" class="cancel-btn" icon="icon-close-1" ></ins-button>
            <a href="/questionnaires-additional-details/{{context.params.slug2}}"><ins-button type="button" label="BACK" icon="icon-arrow-left" outlined ></ins-button></a>
            <ins-button type="button" label="SUBMIT" class="submit-btn mr-0" solid icon="icon-check-2" ></ins-button>
          </div>  

          {% comment %} Tablet and Mobile view of buttons {% endcomment %}
          <div class="hide-for-large mr-0">            
            <ins-button type="button" label="SUBMIT" class="submit-btn" solid icon="icon-check-2" ></ins-button>
            <div class="spacer"></div>
            <a href="/questionnaires-additional-details/{{context.params.slug2}}"><ins-button type="button" label="BACK" icon="icon-arrow-left" outlined ></ins-button></a>
            <div class="spacer"></div>
            <ins-button type="button" label="CANCEL" class="cancel-btn" icon="icon-close-1" ></ins-button>
          </div>
        </div>
    </div>
    
{%- endform -%}

{%- include 'modules/client/questionnaires/questionnaires-cancel-modal' -%}

<ins-modal 
  id="submit-modal"
  with-backdrop 
  confirmation value="DATA"
  width="400px" 
  height="auto"  
  no-button
  prevent-click-outside>

  <div id="myModalContent" class="text-center">    
    <div class="warning"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 168.33 168.33"><defs></defs><title>warning</title><g id="Layer_2" data-name="Layer 2"><g id="Layer_1-2" data-name="Layer 1"><path class="cls-1" d="M84.16,0a84.16,84.16,0,1,0,84.16,84.16A84.26,84.26,0,0,0,84.16,0Zm0,162.33a78.16,78.16,0,1,1,78.16-78.16A78.25,78.25,0,0,1,84.16,162.33ZM87.6,98.86,89,50.27H79.31l1.42,48.58Zm-3.44,8.2a6.28,6.28,0,0,0,0,12.55c3.64,0,6-2.73,6-6.28S87.81,107.05,84.16,107.05Z"></path></g></g></svg></div>
    <div class="spacer"></div>
    <h3 class="heading-3">Submit Questionnaire</h3>
    <div class="spacer"></div>
    <p>Once submitted, the form cannot be edited.</p>  
    <div class="spacer"></div>
    <ins-button type="submit" label="CANCEL" outlined icon="icon-close-1" onclick="submitModal.close()" ></ins-button>
    <span class="pl-16"></span>
    <ins-button type="submit" id="final-submit-btn" label="SUBMIT" solid icon="icon-check-2" onclick="validateQuestionnairesForm(event, true)"></ins-button>
  </div>

</ins-modal>

<script>
  <!-- Submit Modal -->
  let submitModal = document.getElementById('submit-modal');
  let finalSubmitBtn = document.getElementById('final-submit-btn');
  let submitBtn = document.querySelectorAll('.submit-btn');
      submitBtn.forEach(field => {
          field.addEventListener('insClick', () => {
            validateQuestionnairesForm(event);        
          });            
      });

  <!-- Submit Form -->
  let form = document.getElementById('questionnaires-form');   

  async function validateQuestionnairesForm(event, submit) {
    if(submit){
      finalSubmitBtn.loading = true;
      form.submit();
    }else{
      event.preventDefault();
      if (await App.validation.validateForm(form)) {
        submitModal.open();              
        return false;
      } else {
        finalSubmitBtn.loading = false;
        return false;
      }
    }                          
  }
</script>        