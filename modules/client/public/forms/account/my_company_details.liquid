---
name: my_company_details
resource: modules/insites_core/crm_company
resource_owner: anyone
flash_alert: Error-Company-Details
flash_notice: Success-Company-Details
redirect_to: my-company-details
fields:

  # CRM Company Fields 
  email_1:
    validation: 
      presence: true
      email: 
        message: Please use a valid email address 
    property_options:
      virtual: true     
  company_name:
    validation: 
      presence: true
    property_options:
      virtual: true
  registered_business_number:
    validation: 
      presence: true
    property_options:
      virtual: true           
  company_mobile_phone_country_code:
    property_options:
      virtual: true
  company_mobile_phone_number:
    property_options:
      virtual: true
  company_address_1:
    property_options:
      virtual: true
  company_address_2:
    property_options:
      virtual: true
  company_suburb:
    property_options:
      virtual: true
  company_state:
    property_options:
      virtual: true
  company_postcode:
    property_options:
      virtual: true
  company_country:
    property_options:
      virtual: true    

api_call_notifications:
  - modules/client/update_company
---

{%- form 
    html-id: "user-company-form"
    html-class: 'insites-form insites-form-code' 
    html-novalidate: true
    html-enctype="multipart/form-data"
    html-onsubmit:"return UserProfileScript.methods.validateForm(event);" -%}

  <div class="insites-form-grid">
    {% include 'modules/client/account/registration_company_details', data: data %}
  </div>

{%- endform -%}