---
name: register
resource: User
resource_owner: anyone
flash_alert: Sorry-Signup
flash_notice: Congratulations-Signup
redirect_to: register
fields:
  # User Fields
  email:
    validation: 
      unique:
        message: Email already exist
      presence:
        message: Please use a valid email address
      email: 
        message: Please use a valid email address      
  password:
    validation: 
      presence: 
        message: Invalid Password
  first_name:
    validation: 
      presence: 
        message: First name is required
  last_name:
    validation: 
      presence: 
        message: Last name is required
  
  # CRM Contact Fields        
  mobile_phone_country_code:
    property_options:
      virtual: true
  mobile_phone_number:
    property_options:
      virtual: true
  address_1:
    property_options:
      virtual: true
  address_2:
    property_options:
      virtual: true
  suburb:
    property_options:
      virtual: true
  state:
    property_options:
      virtual: true
  postcode:
    property_options:
      virtual: true
  country:
    property_options:
      virtual: true

  # CRM Company Fields        
  company_name:
    presence: true
    property_options:
      virtual: true
  registered_business_number:
    presence: true
    property_options:
      virtual: true
  email_1:
    presence: true
    property_options:
      virtual: true
  phone_1_country_code:
    property_options:
      virtual: true
  company_mobile_phone_country_code:
    property_options:
      virtual: true
  company_mobile_phone_number:
    property_options:
      virtual: true
  company_address_1:
    property_options:
      virtual: true
  company_address_2:
    property_options:
      virtual: true
  company_suburb:
    property_options:
      virtual: true
  company_state:
    property_options:
      virtual: true
  company_postcode:
    property_options:
      virtual: true
  company_country:
    property_options:
      virtual: true

  # Confirmation Fields
  agreement:
    presence: true
    property_options:
      virtual: true
      
api_call_notifications:
  - modules/client/update_contacts
  - modules/client/add_company 
---
{%- form 
    html-id: "register-form"
    html-class: 'insites-form insites-form-code' 
    html-novalidate: true
    html-enctype="multipart/form-data"
    html-onsubmit:"return Session.events.signUpHandler(event, 'personal-details-container');" -%}

  <div class="insites-form-grid">

  {% include 'modules/client/account/registration_personal_details' %}

  {% include 'modules/client/account/registration_company_details' %}

  {% include 'modules/client/account/registration_confirmation' %}
            
  </div>

{%- endform -%}