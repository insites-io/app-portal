---
name: questionnaires_form_auth
---
{% comment %} 
    URL cases:
        Add questionnaires      - /questionnaires-general?year=2023
        Edit questionnaires     - /questionnaires-general/123
                                - /questionnaires-additional-details/123
                                 /questionnaires-confirmation/123
{% endcomment %}
{%- liquid 

    if context.current_user.id == null
        echo false
    elsif context.params.slug2
        comment 
            Edit Questionnaire
        endcomment
        graphql data = "modules/client/questionnaires/get_questionnaires", user_id: context.current_user.id, id: context.params.slug2 | dig: "items","results" 

        if data.size > 0
            comment 
                Form cannot be edited once completed 
            endcomment
            if data[0].agreement[0] == "I understand and agree"
                echo false
            else
                echo true
            endif
        else
            comment 
                Cannot edit non existing questionnaires
            endcomment
            echo false
        endif
    elsif context.params.year

        assign current_year = 'now' | date: '%Y'
        if context.params.year > current_year
            comment 
                Do not allow advance questionnaires
            endcomment
            echo false
        else
            comment 
                Add Questionnaire
                - one questionnaire per user per year
            endcomment
            graphql data = "modules/client/questionnaires/get_questionnaires", user_id: context.current_user.id, year: context.params.year | dig: "items","results" 

            if data.size > 0
                comment 
                    Questionnaires for that user on that given year already exist
                endcomment
                echo false
            else
                echo true
            endif
        endif
    else
        echo false
    endif
-%}