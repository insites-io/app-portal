---
name: questionnaires_form_auth
---
{%- liquid 
    graphql data = "modules/client/get_questionnaires", id: {{context.params.slug3}} | dig: "items","results" | first

    if context.params.slug2 == "questionnaires-general"
        echo true
    elsif context.params.slug2 != "questionnaires-general" and context.params.slug3        
        if context.params.slug2 == "questionnaires-additional-details" and data.user_id
            echo true
        elsif context.params.slug2 == "questionnaires-confirmation" and data.contact_name
            echo true
        endif
    else
        echo false
    endif

    comment 
        Form cannot be edited once completed 
    endcomment
    if context.params.slug3 and data.agreement[0] == "I understand and agree"
        echo false
    endif
-%}