{%- if context.environment == "staging" -%}
<!-- start page: Pay a Bill  -->
{%- endif -%}

<div class="pay-bill">
        
    {%- if context.flash.notice == "Success-PayBill" -%}
      {% comment %} Payment Notice {% endcomment %} 
      {%  liquid
          if context.session.paybill_status == 'success'
              include 'modules/client/pay_bill/payment_notice_success', order_id: context.session.paybill_order_id,  payment_id: context.session.paybill_payment_id
          else
              include 'modules/client/pay_bill/payment_notice_failed'
          endif
      %}
    {%- else -%}
      {% comment %} Pay bill Form {% endcomment %}
      {%- include_form "modules/client/pay_bill" -%} 
    {%- endif -%}
    
</div>

{%- if context.environment == "staging" -%}
<!-- end page: Pay a Bill  -->
{%- endif -%}

<!-- Stripe Element -->
{%- include 'modules/client/forms/stripe_element',
    cc_field_id: "checkout-credit-card"
    email_field_id: "email" -%}
<!-- END Stripe Element -->

<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
{%- if context.environment == "staging" -%}
  <script src="{{ 'modules/client/scripts/pay-bill.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/services/stripeServices.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/services/apiServices.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/scripts/user-profile.js' | asset_url }}"></script>
{%- else -%}
  <script src="{{ 'modules/ecommerce/scripts/pay-bill.min.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/services/stripeServices.min.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/services/apiServices.min.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/scripts/user-profile.min.js' | asset_url }}"></script>
{%- endif -%} 