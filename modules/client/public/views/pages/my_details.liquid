---
slug: my-details
layout: modules/client/form
searchable: false
max_deep_level: 1
metadata: {
    "status": "published",
    "page_name": "My Details",
    "open_graph:url": "{{ context.exports.global.company_url | strip }}",
    "open_graph:type": "",
    "open_graph:image": "",
    "open_graph:title": "My Details",
    "open_graph:description": "My Details",
    "open_graph:site_name": "{{ context.exports.global.company_name | strip }}",
    "meta_title": "My Details",
    "page_title": "My Details | Insites",
    "meta_description": "My Details",
    "canonical_url": "",
    "is_visible_to_search_engines": false,
    "sitemap_enabled": false,
    "sitemap_priority": "1.0",## primary order (DESC)
    "sitemap_order": "0", ## secondary order (ASC)
    "sitemap_changefreq": "never",
    "heading": "My Details"
}
authorization_policies:
  - modules/client/is_user_logged_in
---

{%- graphql user = 'modules/client/account/get_current_user' | dig: 'current_user' -%}  
{% assign user_company_uuid =  user | dig: 'crm_contact' | first  %}

{% comment %} Check if CRM Contact was assigned already to CRM Company {% endcomment %}
{%- if user.crm_contact[0].company_uuid != user.client[0].company_uuid -%}
  {%- parse_json data -%}
  {
    "company_uuid": "{{ user_company_uuid.company_uuid }}",
    "contact_ids": {{ user.id }}
  }
  {%- endparse_json -%}
  {%- graphql assign_company_contact = 'modules/website/trigger_api_call', 
      name: 'modules/client/assign_company_contact', 
      data: data | dig: 'items','response','body' | parse_json -%}     
{%- endif -%}

{% comment %} Check if user verified their account {% endcomment %}
{%- liquid
    if user.client
        assign profile = user.client[0]
        if profile != blank and profile.is_activated
            assign verified = true
        else
            assign verified = false            
        endif
    endif    
-%}

{% comment %} Get CRM -> Contact from v5 API {% endcomment %}
{% parse_json data %} 
{
  "id": "{{user.external_id}}"
}
{% endparse_json %}
{% liquid
    graphql contact_api = 'modules/website/trigger_api_call', name: 'modules/client/get_contact', data: data 
    assign contact = contact_api.items.response.body | parse_json | dig: 'items','results' | first
%}


{% comment %} Get CRM -> Contact Address from v5 API {% endcomment %}
{% parse_json data %} 
{
  "contact_uuid": "{{ user.external_id }}"
}
{% endparse_json %}
{% liquid
    graphql contact_address_api = 'modules/website/trigger_api_call', name: 'modules/client/get_contact_address', data: data 
    assign contact_address = contact_address_api.items.response.body | parse_json | dig: 'items'

    if contact_address.total_entries == 0
      assign default_address = '' | parse_json
    else
      for item in contact_address.results
        if forloop.first == true
          assign default_address = item
        endif
        if item.properties.uuid == contact.contact[0].properties.default_address_uuid 
          assign default_address = item
        endif
      endfor
    endif

    assign contact = contact | add_hash_key: "default_address", default_address
%}


<div class="my-details">    

    <h2 class="heading-2">Account Information</h2>
    
     {%- if verified == false -%}
      <div class="small-12 cell text-center">
      </div>
    {%- endif -%} 
    <div class="spacer x-large"></div>
    {%- include_form 'modules/client/my_details', id: user.id, data: contact -%}
        
    {%- include_form 'modules/client/change_password', id: user.id -%}
    <div class="spacer x-large"></div>
</div>


{% comment %} Search Address Script {% endcomment %}
{% include 'modules/website/layout/googlemaps' %}

<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
{%- if context.environment == "staging" -%}
  <script src="{{ 'modules/client/scripts/address-lookup.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/scripts/user-profile.js' | asset_url }}"></script>
{%- else -%}
  <script src="{{ 'modules/client/scripts/address-lookup.min.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/scripts/user-profile.min.js' | asset_url }}"></script>
{%- endif -%}

{%- if context.flash and context.flash.notice == "Success-My-Details" -%}
<script>
setTimeout(() => {
    App.events.notyf('success', "Account details has been updated.");
}, 200);
</script>
{% endif -%}

{%- if context.flash and context.flash.alert == "Error-My-Details" -%}
<script>
setTimeout(() => {
    App.events.notyf('error', "Error updating account detail.");
}, 200);
</script>
{% endif -%}
