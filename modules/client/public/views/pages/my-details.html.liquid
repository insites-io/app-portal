---
slug: my-details
layout: modules/client/form_layout
# enable_profiler: true
searchable: false
max_deep_level: 1
metadata: {
    "status": "published",
    "page_type": "system", ## content, system or endpoint
    "page_name": "My Details",
    "og:url": "{{ context.exports.global.company_url | strip }}",
    "og:type": "",
    "og:image": "",
    "og:title": "My Details",
    "og:description": "My Details",
    "og:site_name": "{{ context.exports.global.company_name | strip }}",
    "meta_title": "My Details",
    "page_title": "My Details | Insites",
    "meta_description": "My Details",
    "canonical_url": "",
    "search_engine_visibility": false,
    "sitemap_enabled": false,
    "sitemap_priority": "1.0",## primary order (DESC)
    "sitemap_order": "0", ## secondary order (ASC)
    "sitemap_changefreq": "never",
    "heading": "My Details"
}
---
{%- liquid
    graphql user = 'modules/client/account/get_current_user' | dig: 'current_user'

    if user.client
        assign profile = user.client[0]
        if profile != blank and profile.is_activated
            assign verified = true
        else
            assign verified = false            
        endif
    endif    
-%}

<div class="my-details">    

    <h2 class="heading-2">Account Information</h2>
    
    {%- if verified == false -%}
      <div class="small-12 cell text-center">
        <div class="spacer"></div>
        {%- include_form "modules/client/resend_verification", id: context.current_user.id -%}
      </div>
    {%- endif -%}

    {%- include_form 'modules/client/my_details', id: user.id, external_id: user.external_id -%}
        
    {%- include_form 'modules/client/change_password', id: user.id -%}
    <div class="spacer xxxx-large"></div>
</div>


{% comment %} Search Address Script {% endcomment %}
{% include 'modules/client/layout/googlemaps' %}

<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
{%- if context.environment == "staging" -%}
  <script src="{{ 'modules/client/scripts/address-lookup.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/services/apiServices.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/scripts/user-profile.js' | asset_url }}"></script>
{%- else -%}
  <script src="{{ 'modules/client/scripts/address-lookup.min.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/services/apiServices.min.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/scripts/user-profile.min.js' | asset_url }}"></script>
{%- endif -%}

{%- if context.flash and context.flash.notice == "Success-UserProfile" -%}
<script>
setTimeout(() => {
    App.events.notyf('success', "Account details has been updated.");
}, 200);
</script>
{% endif -%}

{%- if context.flash and context.flash.alert == "Error-UserProfile" -%}
<script>
setTimeout(() => {
    App.events.notyf('error', "Error updating account detail.");
}, 200);
</script>
{% endif -%}