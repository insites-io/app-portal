---
slug: email-verification
layout: modules/website/system_pages
# enable_profiler: true
max_deep_level: 1
metadata: {
    "status": "published",
    "page_type": "system", ## content, system or endpoint
    "og:url": "{{ context.exports.global.company_url | strip }}",
    "og:type": "",
    "og:image": "",
    "og:title": "Email Verification | {{ context.exports.global.company_name | strip }}",
    "og:description": "Email Verification | {{ context.exports.global.company_name | strip }}",
    "og:site_name": "{{ context.exports.global.company_name | strip }}",
    "meta_title": "Email Verification | {{ context.exports.global.company_name | strip }}",
    "page_title": "Email Verification | {{ context.exports.global.company_name | strip }}",
    "meta_description": "Email Verification | {{ context.exports.global.company_name | strip }}",
    "canonical_url": "",
    "search_engine_visibility": false,
    "sitemap_enabled": false,
    "sitemap_priority": "1.0",## primary order (DESC)
    "sitemap_order": "0", ## secondary order (ASC)
    "sitemap_changefreq": "never"
}
---

{%- graphql g = 'modules/client/account/get_user_with_password_token', email: params.email -%}
{% assign token = context.location.search.token %}
{% assign user_id = g.users.results[0].id %}
{% assign token_valid = token | is_token_valid: user_id %}

{% if user_id == blank or token_valid == false or g.users.results[0].customer[0].verification_token != params.token %}

    <div class="sign-up">
        <div class="grid-x align-center">
            <div class="large-5 medium-9 samll-12 cell text-center">
                <div class="spacer xxx-large"></div>
                <div class="spacer x-large"></div>
                <p><strong>Unfortunately, provided token is not valid anymore.<br> Please request another verification instruction by trying to <a href="/sign-up">sign up</a> again.</strong></p>
                <div class="spacer section"></div>
            </div>
        </div>
    </div>

{% else %}
    {% graphql verifyResult = 'modules/client/account/verify_email', id: user_id, token: g.users.results[0].customer[0].verification_token %}

    {% if verifyResult.items  %}

        {%- parse_json messageInfo -%}
        {
            "title" : "Success",
            "type": "success",
            "message": "<p>Your email has been verified. You may now continue to <a href='/sign-in'><strong>sign in</strong></a>.</p>"
        }
        {%- endparse_json -%}
        {%- include 'modules/client/system/form_result', messageInfo: messageInfo -%}

    {% endif %}
    
{% endif %}

