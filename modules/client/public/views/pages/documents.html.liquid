---
slug: documents
layout: modules/client/form_layout
# enable_profiler: true
searchable: false
max_deep_level: 1
metadata: {
    "status": "published",
    "page_type": "content", ## content, system or endpoint
    "og:url": "",
    "og:type": "",
    "og:image": "",
    "og:title": "My Documents | Insites",
    "og:description": "My Documents | Insites",
    "og:site_name": "",
    "meta_title": "My Documents | Insites",
    "page_title": "My Documents | Insites",
    "meta_description": "My Documents | Insites",
    "canonical_url": "",
    "search_engine_visibility": true,
    "sitemap_enabled": true,
    "sitemap_priority": "1.0",## primary order (DESC)
    "sitemap_order": "1", ## secondary order (ASC)
    "sitemap_changefreq": "monthly",
    "heading": "My Documents"
}  
---

{%- if context.environment == "staging" -%}
<!-- start page: overview  -->
{%- endif -%}

{%- comment -%} Pagination and Filters {%- endcomment -%}
{%  liquid            
    assign page_num = context.params.page | default: 1 | plus: 0
    assign per_page = context.params.per_page | default: 6 | plus: 0
    assign year = context.params.year | default: ""
%}

{% parse_json filters %}
{
    "user_id": "{{context.current_user.id}}",
    "page": {{page_num}},
    "size": {{per_page}}      
    {% if context.params.year and context.params.year != '' %} 
    ,"year": "{{year}}"
    {% endif %} 
}
{% endparse_json %}

{%- graphql data = "modules/client/questionnaires/get_questionnaires", args: filters | dig: "items" -%}



{%- comment -%} New Questionnaire Button - Options {%- endcomment -%}
{%- graphql all_questionnaires = "modules/client/questionnaires/get_all_questionnaires", user_id: context.current_user.id | dig: "items","results" -%}

{%  liquid
    assign years = all_questionnaires | map: "year" | sort | reverse  
    assign latest_year = years[0]
    assign this_year = 'now' | date: '%Y'

    if this_year > latest_year
        assign year_options = ''
        for i in (latest_year..this_year)
            unless forloop.first
                assign year_options = year_options | append: i 
                unless forloop.last
                    assign year_options = year_options | append: ','
                endunless
            endunless
        endfor
    else
        assign year_options = 'No forms to complete'
    endif
%}

<div class="questionnaire">

    <div class="box">
        <p>Please upload your documents or files here.</p>
    </div>

    <div class="spacer xxx-large"></div>
    
    <div class="grid-x">
        <div class="cell large-5">
            <ins-button 
                id="new-questionnaire"
                label="Add Document" 
                icon="icon-plus" 
                solid 
                color="blue">
            </ins-button>
        </div>
        <div class="cell large-6 large-offset-1">
            <ins-input 
                id="filter-year"
                placeholder="Search by Description"
                icon="icon-search-1">
            </ins-input>
        </div>                
    </div>

    <div class="spacer"></div>

    <div class="grid-container">

        <div class="grid-x grid-padding-x grid-padding-y">                        
        {%- for item in data.results -%}
        <div class="large-4 medium-6 small-12 cell align-stretch">
            {%- include "modules/client/documents-card", item -%}
        </div>
        {%- endfor -%}
        </div>

        <div class="spacer"></div>        
        {%- include "modules/client/paginations", page_num, per_page -%}
        <div class="spacer xxxx-large"></div>
        
    </div>

</div>

<ins-modal 
  id="modal"
  with-backdrop 
  confirmation value="DATA"
  width="495px" 
  height="auto"  
  no-button
  prevent-click-outside>

  <div id="myModalContent" >        
    {% include_form 'modules/client/documents' %}
  </div>

</ins-modal>

<ins-button label="SUBMIT" solid id="openModalBtn" style="display: inline;" ></ins-button>

<script>
    var modal = document.getElementById('modal');
    var openModalBtn = document.getElementById('openModalBtn');
    openModalBtn.addEventListener('insClick', () => {
      modal.open();
    });

    
    setTimeout(() => {
        modal.open();
    }, 200);

    let year = "{{year}}";
    let keywordInput = document.getElementById("filter-year");
    if (keywordInput) {
        keywordInput.addEventListener('insInput', this.keywordInputEvent);
        keywordInput.addEventListener('insIconClick', this.keywordInputEvent);
    }
    function keywordInputEvent(event) {        
        if (event.detail.keyCode === 13) {            
            let url = window.location.href.replace("year="+year, "") + "&year="+event.detail.value;
            window.location = url;
        }
    }
</script>

{%- if context.environment == "staging" -%}
<!-- end page: overview  -->
{%- endif -%}