---
slug: pay-bills
layout: modules/client/form
searchable: false
max_deep_level: 1
metadata: {
    "status": "published",
    "page_name": "Pay a Bill",
    "open_graph:url": "",
    "open_graph:type": "",
    "open_graph:image": "",
    "open_graph:title": "Pay a Bill | Insites",
    "open_graph:description": "Pay a Bill | Insites",
    "open_graph:site_name": "",
    "meta_title": "Pay a Bill | Insites",
    "page_title": "Pay a Bill | Insites",
    "meta_description": "Pay a Bill | Insites",
    "canonical_url": "",
    "is_visible_to_search_engines": true,
    "sitemap_enabled": true,
    "sitemap_priority": "1.0",## primary order (DESC)
    "sitemap_order": "1", ## secondary order (ASC)
    "sitemap_changefreq": "monthly",
    "heading": "Pay a Bill"
}   
authorization_policies:
  - modules/client/is_user_logged_in
---
{% function get_stripe_settings = "modules/client/stripe/get_stripe_settings" %}

{% if get_stripe_settings.account_id != ''  %}
  <div class="pay-bills">
    {%- if context.flash.notice == "Success-PayBill" -%}
      {% comment %} Payment Notice {% endcomment %} 
      {%  liquid
          if context.session.paybill_status == 'success'
              include 'modules/client/pay_bills/payment_notice_success', order_id: context.session.paybill_order_id, payment_id: context.session.paybill_payment_id
          else
              include 'modules/client/pay_bills/payment_notice_failed'
          endif
      %}
    {%- else -%}
      {% comment %} Pay bill Form {% endcomment %}
      {%- include_form "modules/client/pay_bills" -%} 
    {%- endif -%}
    
  </div>
{% else %}
  <div id="no-card" class="empty-state text-center empty-box  {% if cards.total_entries > 0 %}hide{% endif %}" >
    Please set-up Stripe on your account.
  </div>
{% endif %}

<!-- Stripe Element -->
{%- include 'modules/client/stripe/stripe_element',
    cc_field_id: "checkout-credit-card"
    email_field_id: "email" -%}
<!-- END Stripe Element -->

<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
{%- if context.environment == "staging" -%}
  <script src="{{ 'modules/client/scripts/pay-bills.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/services/stripeServices.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/services/apiServices.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/scripts/user-profile.js' | asset_url }}"></script>
{%- else -%}
  <script src="{{ 'modules/client/scripts/pay-bills.min.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/services/stripeServices.min.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/services/apiServices.min.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/scripts/user-profile.min.js' | asset_url }}"></script>
{%- endif -%} 