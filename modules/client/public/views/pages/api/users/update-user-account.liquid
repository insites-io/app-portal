---
slug: api/update-user-account
method: post
searchable: false
layout: application
max_deep_level: 3
authorization_policies:
metadata: {
    page_name: "API - Update user Account",
}
--- 
{% assign details = context.params %}

{% comment %} ? Catch email with + {% endcomment %}
{%- assign email = details.email | replace: " ", "+" -%}

{% if details.actions == "change_permission_level" %}
    {% comment %} ? ACTION == user TOGGLE {% endcomment %}
    
    {% if details.custom_field_id != "" %}
        {% assign custom_field_id = details.custom_field_id %}
    {% else %}
        {% graphql create_contact_custom_field = "modules/client/account/create_contact_custom_field", contact_uuid: details.contact_uuid %}
        {% assign custom_field_id = create_contact_custom_field.items.id %}
    {% endif %}

    {% graphql update_user_account = 'modules/client/users/update_user_account', id: custom_field_id, permission_level: details.permission_level %}
    
    {% comment %} ? SET TOKEN PASSWORD FOR INVITED{% endcomment %}
    {%  liquid
        graphql generated_token = 'modules/client/account/generate_user_temporary_token', email: email | dig: 'items', 'results' | first
        if generated_token
            graphql set_profile = 'modules/client/users/set_profile_to_invited_users', id: generated_token.id, token: generated_token.temporary_token, company_uuid: details.company_uuid
            graphql set_password_token = 'modules/client/users/set_password_token_to_invited_users', id: generated_token.id, token: generated_token.temporary_token
        endif
    %}

    {%- graphql user_with_token = 'modules/client/account/get_user_with_password_token', email: email | dig: 'users','results' | first -%}
    {%- assign user_data_default = user_with_token.default | first -%}

    {% comment %} ? EMAIL NOTIF {% endcomment %}
    {% if details.permission_level != "No Access" %}
        {%- assign user_invitation = "modules/client/user_invitation" -%}
        {% parse_json data %}
        {
            "email": "{{ email }}",
            "name": "{{ details.name }}",
            "company": "{{ details.company }}",
            "password_token": "{{ user_data_default.password_token }}"
        }
        {% endparse_json %}
        {%- graphql trigger = "modules/website/trigger_email_notification", name: user_invitation, data: data -%}
    {% endif %}
{% else %}
    {% comment %} ? ACTION == ADD user {% endcomment %}
    {% if details.is_email_found == "false" %}
        {% assign is_email_found = false %}
    {% else %}
        {% assign is_email_found = true %} 
    {% endif %}

    {% if is_email_found == true %}
        {% comment %} ? UPDATE CRM {% endcomment %}
        
        {% parse_json update_crm_data %}
        {
            "id": "{{ details.user_id }}",
            "first_name": "{{ details.userFirstName }}",
            "last_name": "{{ details.userLastName }}",
            "email": "{{ email }}",
            "company_uuid": "{{ details.company_uuid }}",
            "mobile_phone_country_code": "{{ details.mobile_phone_country_code | default: 61 }}",
            "mobile_phone_number": "{{ details.mobile_phone_number }}",
            "permission_level": "{{ details.userPermission }}"
        }
        {% endparse_json %}
        {% comment %} ? UPDATE CRM FIRST {% endcomment %}
        {%  graphql add_crm_contact = 'modules/website/trigger_api_call', name: "modules/client/update_crm_via_invite_user",
        data: update_crm_data
        | dig: 'items','response','body'
        | parse_json  
        %}
    {% else %}
        {% comment %} ? SAVE NEW CRM {% endcomment %}
        {% parse_json add_crm_data %}
        {
            "first_name": "{{ details.userFirstName }}",
            "last_name": "{{ details.userLastName }}",
            "email": "{{ email }}",
            "company_uuid": "{{ details.company_uuid }}",
            "mobile_phone_country_code": "{{ details.mobile_phone_country_code | default: 61 }}",
            "mobile_phone_number": "{{ details.mobile_phone_number }}",
            "permission_level": "{{ details.userPermission }}"
        }
        {% endparse_json %}
        {% comment %} ? ADD CRM FIRST {% endcomment %}
        {%  graphql add_crm_contact = 'modules/website/trigger_api_call', name: "modules/client/add_crm_via_invite_user",
        data: add_crm_data
        | dig: 'items','response','body'
        | parse_json  
        %}
    {% endif %}   
    {% comment %} ? CLOSING ENDIF FOR INVITE user - EMAIL EXISTS OR NOT {% endcomment %}

    {% comment %} ? SET TOKEN PASSWORD FOR INVITED user {% endcomment %}
    {%  liquid
        graphql generated_token = 'modules/client/account/generate_user_temporary_token', email: email | dig: 'items', 'results' | first
        if generated_token
            graphql set_profile = 'modules/client/users/set_profile_to_invited_users', id: generated_token.id, token: generated_token.temporary_token, company_uuid: details.company_uuid
            graphql set_password_token = 'modules/client/users/set_password_token_to_invited_users', id: generated_token.id, token: generated_token.temporary_token
        endif
    %}
    {%- graphql user_with_token = 'modules/client/account/get_user_with_password_token', email: email | dig: 'users','results' | first -%}
    {%- assign user_data_default = user_with_token.default | first -%}

    {% comment %} ? EMAIL NOTIF {% endcomment %}
    {%- assign user_invitation = "modules/client/user_invitation" -%}
    {% parse_json data %}
    {
        "email": "{{ email }}",
        "name": "{{ details.userFirstName }} {{ details.userLastName }}",
        "company": "{{ details.company }}",
        "password_token": "{{ user_data_default.password_token }}"
    }
    {% endparse_json %}
    {%- graphql trigger = "modules/website/trigger_email_notification", name: user_invitation, data: data -%}
        
{% endif %}
{% comment %} ? CLOSING ENDIF FOR TOGGLE OR INVITE {% endcomment %}