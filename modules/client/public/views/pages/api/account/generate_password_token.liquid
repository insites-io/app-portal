---
slug: generate-password-token
layout: application
max_deep_level: 3
authorization_policies:
metadata: {
    page_name: "API - generate password token",
}
--- 

{%  liquid  
    assign email = context.current_user.email
    graphql generated_token = 'modules/client/account/generate_user_temporary_token', email: email | dig: 'items', 'results' | first

    if generated_token
    graphql res = 'modules/client/account/update_password_token', id: generated_token.id, token: generated_token.temporary_token
    endif

    graphql user_with_token = 'modules/client/account/get_user_with_password_token', email: email | dig: 'users','results' | first 
    assign user_data_default = user_with_token.default | first
    assign token = user_data_default.password_token | url_encode 
    assign url = '/password-reset?token=' |  append: token | append: '&amp;email=' |  append: email

    redirect_to url
%}
