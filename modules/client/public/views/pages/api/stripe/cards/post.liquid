{%- endcomment -%}
{%- graphql user_stripe_id = 'modules/client/customers/get_user_stripe_id', email: customer_email | dig: 'items','results' | first -%}

{%- assign user_id = user_stripe_id.id -%}
{%- assign external_id = user_stripe_id.external_id -%}
{% assign get_stripe_id = user_stripe_id | dig: 'profiles' | first %}

{% log user_id, type: "client > views > pages > stripe > cards > post.liquid == user_id" %}
{% log external_id, type: "client > views > pages > stripe > cards > post.liquid == external_id" %}
{% log customer_email, type: "client > views > pages > stripe > cards > post.liquid == customer_email" %}
{% log user_stripe_id, type: "client > views > pages > stripe > cards > post.liquid == user_stripe_id" %}
{% log get_stripe_id, type: "client > views > pages > stripe > cards > post.liquid == get_stripe_id" %}

{% if get_stripe_id.stripe_id %}
  
    {%- comment -%}Create new card object payload {%- endcomment -%}
    {% parse_json stripe_card %}
    {
        "contact_uuid": "{{ external_id }}",
        "payment_method_token":  "{{ get_stripe_id.stripe_id }}",
        "source": "{{ payload.stripe_credit_card }}"
    }
    {% endparse_json %}
    {%- comment -%} Bind Card to user {%- endcomment -%}
    {%- assign bind_card_user_id = user_id | default: blank -%}
    {%- comment -%}Create new card on Stripe API {%- endcomment -%}
    {%- capture new_stripe_credit_card -%}
        {%- include 'modules/client/stripe/credit_cards/create_credit_card', 
            stripe_card: stripe_card,
            user_id: bind_card_user_id
            return: true -%}
    {%- endcapture -%}
    {%- assign new_stripe_credit_card = new_stripe_credit_card | strip_newlines | strip -%}


    {%- comment -%}
        BEFORE: Step 1-A: Customer Stripe data exist. Proceed create stripe credit card 
    {%- endcomment -%}

    {%- comment -%}
        BEFORE: Step 1-A.1: Update customer model data
    {%- endcomment -%}

    {% comment %} 
        {%- graphql customer_model = "modules/client/customers/update_customer_model", 
        id: stripe_customer.id
        user_id: user_id,
        name: customer_name | dig: "items" -%} 
    {% endcomment %}

    {%- comment -%}
        BEFORE: Step 1-A.2: Customer Stripe data exist. Proceed create stripe credit card 
    {%- endcomment -%}
    
    {% comment %} 
        {%- assign stripe_customer_id = customer_model.properties.gateway_id -%}
        {%- assign check_new = payload.stripe_credit_card | split: '_' | first | downcase -%}
    {% endcomment %}





    {%- comment -%}
        NOW: Step 1-A: CRM Stripe ID data exist. Proceed create stripe credit card 
    {%- endcomment -%}


    {% comment %} 
        check stripe id
        tok = new card
        
    {% endcomment %}

    {% comment %} 
        create card
            pass email
            check stripe id
            if not exist
                create customer
            else
                create credit card    
            
    {% endcomment %}

{% else %}
    {% log get_stripe_id, type: "else" %}
    {%- comment -%}Step 1-B: New customer: Create Stripe customer data{%- endcomment -%}    
    {% parse_json "stripe_customer" %}
    {
        "email": "{{ customer_email }}",
        "name": "{{ customer_name }}",
        "description": ""
    }
    {% endparse_json %}
    {% graphql stripe_create_customer = 'modules/website/trigger_api_call', 
        name: "modules/client/create_customer",
        data: stripe_customer
        | dig: 'items' | dig: 'response' %}    

    {% log stripe_create_customer, type: "stripe_create_customer" %}
    
    {%- assign stripe_create_customer = stripe_create_customer.body | parse_json  -%}
    {%- assign stripe_customer_id = stripe_create_customer.id -%}

    {% comment %}
        Connect the Stripe ID to CRM
    {% endcomment %}
    {% parse_json connect_stripe_id %}
    {
        "id": "{{ user_id }}", 
        "email": "{{ customer_email }}",
        "stripe_id": "{{ stripe_customer_id }}"
    }
    {% endparse_json %}
    
    {% graphql update_contact = 'modules/website/trigger_api_call', name: 'modules/client/update_contact', data: connect_stripe_id | dig: 'items','response','body' | parse_json %}
    {% log update_contact, type: "client > views > pages > stripe > cards > post.liquid == update_contact" %} 

    {% parse_json stripe_card %}
    {
        "contact_uuid": "{{ external_id }}",
        "payment_method_token":  "{{ stripe_customer_id }}",
        "source": "{{ payload.stripe_credit_card }}"
    }
    {% endparse_json %}

    {% log stripe_card, type: "client > views > pages > stripe > cards > post.liquid == stripe_card" %} 

    {%- include 'modules/client/stripe/credit_cards/create_credit_card', 
        stripe_card: stripe_card -%}

{% endif %}



