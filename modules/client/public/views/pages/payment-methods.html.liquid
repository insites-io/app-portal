---

{%- if context.environment == "staging" -%}
<!-- start page: Payment Methods  -->
{%- endif -%}


<div class="payment-methods">    
    
    <div class="grid-x">
        <h2 class="heading-2 large-8">Credit Card Details</h2>
        <ins-button id="add-credit-card" class="large-4 vertical-align-middle align-right" label="Add credit card" icon="icon-plus" ></ins-button>
    </div>

    <div class="spacer xx-large"></div>

    {%- liquid 
        assign verified =true
        
    -%}

    {%- if verified -%}
        
        {%- if context.current_user.id -%}
            {%- graphql cards = "modules/client/credit_card/get_credit_card", 
                user_id: context.current_user.id
                size: 50 | dig: 'items' -%}
            {% comment %} if cards.total_entries > 0 {% endcomment %}
            {%- if true -%}          
                <div id="card-options-list" class="grid-x grid-padding-x">
                {% comment %} for card in cards.results {% endcomment %}
                {% comment %}  for card in (1..3)  {% endcomment %}
                    <div class="large-4 medium-6 small-12 cell card-options">
                        <ins-credit-card data-id="{{ card.id }}" 
                            brand="{{ card.brand }}"
                            last-four="{{ card.last4 }}"
                            expiry-month="{{ card.exp_month }}"
                            expiry-year="{{ card.exp_year }}"
                            full-year
                            value="{{ card.gateway_id }}">
                        </ins-credit-card>
                    </div>
                    <div class="large-4 medium-6 small-12 cell card-options">
                        <ins-credit-card data-id="{{ card.id }}" 
                            brand="visa"
                            last-four="3456"
                            expiry-month="6"
                            expiry-year="2019"
                            full-year
                            value="card_128kjh21387kasd2h">
                        </ins-credit-card>
                    </div>
                    <div class="large-4 medium-6 small-12 cell card-options">
                        <ins-credit-card data-id="{{ card.id }}" 
                            active
                            brand="amex"
                            last-four="1234"
                            expiry-month="10"
                            expiry-year="2023"
                            full-year
                            value="card_128kjh21387kasd2h">
                        </ins-credit-card>
                    </div>
                {% comment %} {%- endfor -%} {% endcomment %}
                </div>
            {%- else -%}
                <div class="empty-box">
                    <p>Add Credit Card / Debit Card</p>            
                </div>
            {%- endif -%}
        {%- endif -%}
        

    {%- else -%}
        <div class="empty-box">
            <p>To view / modify your Credit Cards please verify your account.</p>            
        </div>
    {%- endif -%}

</div>



{%- if context.environment == "staging" -%}
<!-- end page: Payment Methods  -->
{%- endif -%}

{%- include 'modules/client/forms/stripe_element', email_field_id: "email" -%}

<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
{%- if context.environment == "staging" -%}
  <script src="{{ 'modules/client/services/stripeServices.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/services/apiServices.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/scripts/user-profile.js' | asset_url }}"></script>
{%- else -%}
  <script src="{{ 'modules/client/services/stripeServices.min.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/services/apiServices.min.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/scripts/user-profile.min.js' | asset_url }}"></script>
{%- endif -%}