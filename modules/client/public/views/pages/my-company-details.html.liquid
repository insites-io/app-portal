{%- graphql user = 'modules/client/account/get_current_user' | dig: 'current_user' -%}

{% comment %} Get CRM -> Company from v5 API {% endcomment %}
{% parse_json data %} 
{
  "id": "{{user.client[0].company_uuid}}"
}
{% endparse_json %}
{% liquid
    graphql company_api = 'modules/website/trigger_api_call', name: 'modules/client/get_company', data: data 
    assign company = company_api.items.response.body | parse_json | dig: 'items','results' | first
%}



{% comment %} Get CRM -> Company Address from v5 API {% endcomment %}
{% parse_json data %} 
{
  "company_uuid": "{{ company.properties.uuid }}"
}
{% endparse_json %}
{% liquid
    graphql company_address_api = 'modules/website/trigger_api_call', name: 'modules/client/get_company_address', data: data 
    assign company_address = company_address_api.items.response.body | parse_json | dig: 'items','results'

    for item in company_address
      if forloop.first == true
        assign default_address = item
      endif
      if item.properties.uuid == company.properties.default_address_uuid 
        assign default_address = item
      endif
    endfor

    assign company = company | add_hash_key: "default_address", default_address
%}


{% comment %} {% parse_json payload %} 
{
  "uuid": "{{company.default_address.properties.uuid}}",
  "company_uuid": "{{ company.properties.uuid }}",
  "address_label": "{{ default_address.properties.address_1 }}",
  "default_address": true,
  "address_1": "{{ default_address.properties.address_1 }}",
  "address_2": "{{ default_address.properties.address_2 }}",
  "suburb": "{{ default_address.properties.suburb }}",
  "state": "{{ default_address.properties.state }}",    
  "postcode": "{{ default_address.properties.postcode }}",
  "country": "{{ default_address.properties.country }}"
}
{% endparse_json %} {% endcomment %}



