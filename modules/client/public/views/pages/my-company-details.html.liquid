---
slug: my-company-details
layout: modules/client/form_layout
# enable_profiler: true
searchable: false
max_deep_level: 1
metadata: {
    "status": "published",
    "page_type": "system", ## content, system or endpoint
    "page_name": "My Company Details",
    "og:url": "{{ context.exports.global.company_url | strip }}",
    "og:type": "",
    "og:image": "",
    "og:title": "My Company Details",
    "og:description": "My Company Details",
    "og:site_name": "{{ context.exports.global.company_name | strip }}",
    "meta_title": "My Company Details",
    "page_title": "My Company Details | Insites",
    "meta_description": "My Company Details",
    "canonical_url": "",
    "search_engine_visibility": false,
    "sitemap_enabled": false,
    "sitemap_priority": "1.0",## primary order (DESC)
    "sitemap_order": "0", ## secondary order (ASC)
    "sitemap_changefreq": "never",
    "heading": "My Company Details"
}
---
    
{%- graphql user_data = 'modules/client/account/get_current_user' -%}
{%- assign user = user_data.current_user -%}

{%- if user.client -%}
  {%- assign prof = user.client[0] -%}
  {%- if prof != blank  -%}
    {%- if prof.is_activated -%}
      {%- assign verified = true -%}
    {%- else -%}
      {%- assign verified = false -%}
    {%- endif -%}  
  {%- endif -%}
{%- endif -%}

{% comment %} 
  Get CRM -> Company from v5 API
{% endcomment %}
{% parse_json data %} 
{
  "id": "{{user.client[0].company_uuid}}"
}
{% endparse_json %}

{% liquid
    graphql company = 'modules/website/trigger_api_call', name: 'modules/client/get_company', data: data 
    assign response = company.items.response.body | parse_json | dig: 'items','results' | first
%}

{%- include_form 'modules/client/my_company_details', id: response.id, data: response -%}


{% comment %} Search Address Script {% endcomment %}
{% include 'modules/client/layout/googlemaps' %}

<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
{%- if context.environment == "staging" -%}
  <script src="{{ 'modules/client/scripts/address-lookup.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/services/apiServices.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/scripts/user-profile.js' | asset_url }}"></script>
{%- else -%}
  <script src="{{ 'modules/client/scripts/address-lookup.min.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/services/apiServices.min.js' | asset_url }}"></script>
  <script src="{{ 'modules/client/scripts/user-profile.min.js' | asset_url }}"></script>
{%- endif -%}

{%- if context.flash and context.flash.notice == "Success-Company-Details" -%}
<script>
setTimeout(() => {
    App.events.notyf('success', "Company details updated.");
}, 200);
</script>
{% endif -%}

{%- if context.flash and context.flash.alert == "Error-Company-Details" -%}
<script>
setTimeout(() => {
    App.events.notyf('error', "Error updating company details.");
}, 200);
</script>
{% endif -%}