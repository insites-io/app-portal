{%- comment -%}
By adding the global content to the top of the layout
It can be accessed in the includes without calling the GraphQL again
It IS NOT accessable in {{content_for_layout}} which includes the specific page
{%- endcomment -%}
{%- include "modules/website/data/global_content" -%}
{%- assign global = context.exports.global -%}

{%- comment -%} Used by the fragment cache in the layout {%- endcomment -%}
{%- include "modules/website/layout_fragment_cache_key" -%}

{%- comment -%}
The `homepage` layout is dedicated layout for homepage only.
{%- endcomment -%}
<!doctype html>
<html class="no-js" lang="en">
{%- if context.environment == "staging" -%}
<!-- start layout: homepage  -->
{%- endif -%}

<head>
    {%- comment -%}
    We try to limit assets that are part of the head / technical head to
    minimize page size & improve page performance.

    Assets like 'Google Map API', should only be referenced as needed.
    - Managed on the 'page / layout' level
    {%- endcomment -%}
    {%- capture head_key -%} {{ context.exports.layout_cache_key.cache_key | append: "-head" }} {%- endcapture -%}
    {% include 'modules/website/layout/head' %}
    <link rel="stylesheet" href="{{ 'modules/client/styles/client.min.css' | asset_url }}" >

    <script type="module" src="https://components.insites.io/v2/latest/insites.esm.js"></script>
    <script nomodule src="https://components.insites.io/v2/latest/insites.js"></script>
    {%- include 'modules/client/insites_database/insites_database_form_scripts' -%}
</head>

<body>
    <div class="main-wrap">
        {%- if context.current_user and context.modules.ecommerce.name != blank -%}
        {% include 'modules/website/layout/header' %}
        {%- else -%}
        {%- capture header_key -%} {{ context.exports.layout_cache_key.cache_key | append: "-header" }} {%- endcapture -%}
        {%- cache header_key -%}
        {% include 'modules/website/layout/header' %}
        {%- endcache -%}
        {%- endif -%}

        {%- if true -%}
        <div class="wrapper bg-color-main">
            <div class="grid-container">
                <div class="spacer xxx-large"></div>
                <h1 class="heading-1">{{context.page.metadata.heading}}</h1>
                <div class="spacer xxx-large"></div>
            </div>
        </div>
        {%- else -%}
        {%- comment -%} Carousel - Slider {%- endcomment -%}
        {%- include 'modules/client/banner', size: 10 -%}  
        {%- endif -%}      

        <div class="wrapper">
            <div class="grid-container">
                <div class="grid-x gutter-medium grid-padding-x">
                    <div class="large-3 medium-5 small-12 cell bg-color-ui-02">
                        {% include 'modules/client/layout/sidebar' %}
                    </div>
                    <div class="large-9 medium-7 small-12 cell bg-color-ui-01">
                        <div class="spacer xxxx-large"></div>
                        {{ content_for_layout }}
                    </div>
                </div>
                <div class="spacer x-large"></div>
            </div>
        </div>
        
        {%- capture foot_key -%} {{ context.exports.layout_cache_key.cache_key | append: "-footer_section"}} {%- endcapture -%}
        {%- cache foot_key -%}        
    </div>

    {% include 'modules/website/layout/footer' %}
    {% include 'modules/website/layout/foot' %}

    

    <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
    <script src="{{ 'modules/website/services/formServices.js' | asset_url }}"></script>

    {%- endcache -%}

</body>
{%- if context.environment == "staging" -%}
<!-- end layout: homepage  -->
{%- endif -%}

</html>