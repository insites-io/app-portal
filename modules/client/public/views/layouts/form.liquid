---
metadata: {
    layout_name: form
}
---
{%- comment -%} Used by the fragment cache in the layout {%- endcomment -%}

{% comment %} ? Enable Fragment cache after Installation {% endcomment %}
{% comment %} {%- include "modules/website/cache/layout_fragment_cache_key" -%} {% endcomment %}

<!doctype html>
<html class="no-js" lang="en">
<head>
    {% comment %} 
        ? Enable Caching for Head after Installation
        ? Remove the comment once Installed and Menu Database is Populated 
        {%- capture head_key -%} {{ context.exports.layout_cache_key.cache_key | append: "-head" }} {%- endcapture -%}
        {%- cache head_key -%}
            {% include 'modules/website/layout/head' %}
        {%- endcache -%}
    {% endcomment %}

    {% comment %} ? Delete line of code below this comment once Installed and Menu Database is Populated {% endcomment %}
    {% include 'modules/website/layout/head' %}

    <script type="module" src="https://components.insites.io/v2/latest/insites.esm.js"></script>
    <script nomodule src="https://components.insites.io/v2/latest/insites.js"></script>
    {%- include 'modules/client/insites_database/insites_database_form_scripts' -%}
    {%- include 'modules/insites_forms/form_scripts' -%}

</head>
<body>
    <div class="main-wrap">

        {% comment %} 
            ? Enable Caching for Header after Installation
            ? Remove the comment once Installed and Menu Database is Populated 
                {%- capture header -%} {{ context.current_user.id }}-{{ context.exports.layout_cache_key.cache_key }}-header {%- endcapture -%}
                {%- cache header -%}
                    {% include 'modules/website/layout/header' %}
                {%- endcache -%}
        {% endcomment %}

        {% comment %} ? Delete line of code below this comment once Installed and Menu Database is Populated {% endcomment %}
        {% include 'modules/website/layout/header_default' %} 
        
        {% comment %} 
            ? Enable Caching for Header after Installation
            ? Remove the comment once Installed and Menu Database is Populated 
                {%- capture header-mobile -%} {{ context.current_user.id }}-{{ context.exports.layout_cache_key.cache_key }}-header-mobile {%- endcapture -%}
                {%- cache header-mobile -%}
                    {% include 'modules/website/layout/header_mobile' %}
                {%- endcache -%}
        {% endcomment %}

        {% comment %} ? Delete line of code below this comment once Installed and Menu Database is Populated {% endcomment %}
        {% include 'modules/website/layout/header_mobile_default' %}
        
        <div class="wrapper bg-color-main">
            <div class="grid-container">
                <div class="spacer x-large"></div>
                {%- liquid
                    if context.page.metadata.heading == "Questionnaire Form"
                        if params.slug2
                            assign heading = "Edit Questionnaire"
                        else
                            assign heading = "Add Questionnaire"
                        endif
                    else
                        assign heading = context.page.metadata.heading
                    endif
                -%}
                <h1 class="heading-1">{{ heading }}</h1>
                <div class="spacer x-large"></div>
            </div>
        </div>

        <div class="wrapper client-portal">
            <div class="grid-container">
                <div class="grid-x gutter-medium grid-padding-x">
                    <div class="large-3 medium-5 small-12 cell bg-color-ui-02">
                        {% include 'modules/client/layouts/sidebar' %}
                    </div>
                    <div class="large-9 medium-7 small-12 cell bg-color-ui-01 main-content">
                        <div class="spacer xxxx-large"></div>
                        {{ content_for_layout }}
                        <div class="spacer xxxx-large"></div>
                    </div>
                </div>
            </div>
        </div>                       
    </div>

    {% comment %} 
        ? Enable Caching for Footer after Installation
        ? Remove the comment once Installed and Menu Database is Populated 
        {%- capture foot_key -%} {{ context.exports.layout_cache_key.cache_key | append: "-footer_section"}} {%- endcapture -%}
        {%- cache foot_key -%} 
            {% include 'modules/website/layout/footer' %}
        {%- endcache -%}
    {% endcomment %}
    
    {% comment %} ? Delete line of code below this comment once Installed and Menu Database is Populated {% endcomment %}
    {% include 'modules/website/layout/footer' %}

</body>
</html>