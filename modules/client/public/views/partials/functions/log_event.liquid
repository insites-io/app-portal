{%- comment -%}
    datetime
    description
    font_icon
    font_icon_color
    details
    log
{%- endcomment -%}

{%- parse_json data -%}
{
    "font_icon": "{{ info.font_icon | default: "icon-info" }}",
    "font_icon_color": "{{ info.font_icon_color | default: "#451278" }}",
    "description": "{{ info.description | default: "" }}",
    "details": "{{ info.details | default: "" }}"    
}
{%- endparse_json -%}
{%- assign data = data | add_hash_key: "log", info.log -%}

{%- liquid
    graphql create_event_log = 'modules/website/trigger_api_call', name: "modules/client/add_events", data: data | dig: 'items','response'    
-%}