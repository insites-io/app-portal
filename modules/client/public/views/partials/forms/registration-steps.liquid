
{%- liquid

    graphql data = "modules/client/get_questionnaires", id: {{context.params.slug3}} | dig: "items","results" | first

    if context.params.slug == "register"
        assign statusPersonal = "active"
        assign statusCompany = "disabled"
        assign statusConfirmation = "disabled"
        assign statusVerify = "disabled"
        if context.params.slug3
            if data.contact_name
                assign statusAdditional = "complete"
            endif
            if data.agreement[0] == "I understand and agree"
                assign statusConfirmation = "complete"
            endif
        endif
    elsif context.params.slug == "register-company-details"
        assign statusPersonal = "complete"
        assign statusCompany = "active"
        assign statusConfirmation = "disabled"
        assign statusVerify = "disabled"
        if context.params.slug3
            if data.agreement[0] == "I understand and agree"
                assign statusConfirmation = "complete"
            endif
        endif
    elsif context.params.slug == "register-confirmation"
        assign statusPersonal = "complete"
        assign statusCompany = "complete"
        assign statusConfirmation = "active"
        assign statusVerify = "disabled"
    elsif context.params.slug == "register-verify"
        assign statusPersonal = "complete"
        assign statusCompany = "complete"
        assign statusConfirmation = "complete"
        assign statusVerify = "active"
    endif

    export data, namespace: 'questionnaires'
-%}

<div class="form-groups-tab">        
    <ins-steps clickable id="insStepsClickEl" style="width: 100%;">
        <ins-step description="Personal Details" {{statusPersonal}} link="/client-portal/register"></ins-step>
        <ins-step description="Company Details" {{statusCompany}} link="/client-portal/register-company-details"></ins-step>
        <ins-step description="Confirmation" {{statusConfirmation}} link="/client-portal/register-confirmation"></ins-step>
        <ins-step description="Verify" {{statusVerify}} link="/client-portal/register-verify"></ins-step>
    </ins-steps>
</div>

<script>
    //Clickable Steps    
    function prevForm(event){
        let link = event.detail.currentStep.getAttribute('link');
        window.location=link;               
    }    
    insStepsClickEl.addEventListener('insClick', this.prevForm);    
</script>