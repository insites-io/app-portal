{%- form html-class: 'insites-form insites-form-code' html-novalidate: 'novalidate' html-data-form: 'modules/client/questionnaire' -%}

    <div class="insites-form-grid">
    
    <div class="form-groups-tab">
        <div class="form-tab" data-group-id="a0d922fb-3269-4417-999d-6543f36785aa" active style="width: 33.33%;">
            <div data-group-id="a0d922fb-3269-4417-999d-6543f36785aa" class="form-checkbox"></div>
            <div class="form-group-name">General</div>
        </div>
        <div class="form-tab" data-group-id="51a431b3-a1ec-4907-a541-4ab7d9d968c2" style="width: 33.33%;">
            <div data-group-id="51a431b3-a1ec-4907-a541-4ab7d9d968c2" class="form-checkbox"></div>
            <div class="form-group-name">Additional Details</div>
        </div>
        <div class="form-tab" data-group-id="cdf25c4d-40f9-45f6-9f6c-3052e98c0108" style="width: 33.33%;">
            <div data-group-id="cdf25c4d-40f9-45f6-9f6c-3052e98c0108" class="form-checkbox"></div>
            <div class="form-group-name">Confirmation</div>
        </div>
    </div>
    
    <!-- Form Group: General -->
    <div class="form-group" data-group-id="a0d922fb-3269-4417-999d-6543f36785aa" active>
        <!-- Field: Have you ever heard about Insites? -->
        <div class="{%- if form.metadata.properties.have_you_heard.two_columns == true -%}column-2{%- else -%}column-1{%- endif -%}">
            <ins-input 
                data-type="string"
                data-ui="text"
                label="{%- include 'modules/insites_database/form_code/label', form: form, name: 'have_you_heard' -%}"
                name="{{ form.fields.properties.have_you_heard.name }}"
                value="{{ form.fields.properties.have_you_heard.value }}"
                error-message="{{ form.errors['properties.have_you_heard'] }}"
                {%- include 'modules/insites_database/form_code/placeholder', form: form, name: 'have_you_heard' -%}
                {%- include 'modules/insites_database/form_code/validation/required', form: form, name: 'have_you_heard' -%}
                {%- if form.errors['properties.have_you_heard'] != nil -%} has-error {%- endif -%} 
                {%- include 'modules/insites_database/form_code/validation/type', form: form, name: 'have_you_heard' -%} 
                {%- include 'modules/insites_database/form_code/validation/length', form: form, name: 'have_you_heard' -%}>
            </ins-input>
        </div>
    
        <!-- Field: How did you learn about Insites? -->
        <div class="{%- if form.metadata.properties.howd_you_learn.two_columns == true -%}column-2{%- else -%}column-1{%- endif -%}">
            <ins-input 
                data-type="string"
                data-ui="text"
                label="{%- include 'modules/insites_database/form_code/label', form: form, name: 'howd_you_learn' -%}"
                name="{{ form.fields.properties.howd_you_learn.name }}"
                value="{{ form.fields.properties.howd_you_learn.value }}"
                error-message="{{ form.errors['properties.howd_you_learn'] }}"
                {%- include 'modules/insites_database/form_code/placeholder', form: form, name: 'howd_you_learn' -%}
                {%- include 'modules/insites_database/form_code/validation/required', form: form, name: 'howd_you_learn' -%}
                {%- if form.errors['properties.howd_you_learn'] != nil -%} has-error {%- endif -%} 
                {%- include 'modules/insites_database/form_code/validation/type', form: form, name: 'howd_you_learn' -%} 
                {%- include 'modules/insites_database/form_code/validation/length', form: form, name: 'howd_you_learn' -%}>
            </ins-input>
        </div>
    
        <!-- Field: What is the main reason you visit our website?  -->
        <div class="{%- if form.metadata.properties.reason_for_visit.two_columns == true -%}column-2{%- else -%}column-1{%- endif -%}">
            <ins-input 
                data-type="string"
                data-ui="text"
                label="{%- include 'modules/insites_database/form_code/label', form: form, name: 'reason_for_visit' -%}"
                name="{{ form.fields.properties.reason_for_visit.name }}"
                value="{{ form.fields.properties.reason_for_visit.value }}"
                error-message="{{ form.errors['properties.reason_for_visit'] }}"
                {%- include 'modules/insites_database/form_code/placeholder', form: form, name: 'reason_for_visit' -%}
                {%- include 'modules/insites_database/form_code/validation/required', form: form, name: 'reason_for_visit' -%}
                {%- if form.errors['properties.reason_for_visit'] != nil -%} has-error {%- endif -%} 
                {%- include 'modules/insites_database/form_code/validation/type', form: form, name: 'reason_for_visit' -%} 
                {%- include 'modules/insites_database/form_code/validation/length', form: form, name: 'reason_for_visit' -%}>
            </ins-input>
        </div>
    
        <!-- Field: Personal Email -->
        <div class="{%- if form.metadata.properties.personal_email.two_columns == true -%}column-2{%- else -%}column-1{%- endif -%}">
            <ins-input 
                data-type="string"
                data-ui="text"
                label="{%- include 'modules/insites_database/form_code/label', form: form, name: 'personal_email' -%}"
                name="{{ form.fields.properties.personal_email.name }}"
                value="{{ form.fields.properties.personal_email.value }}"
                error-message="{{ form.errors['properties.personal_email'] }}"
                {%- include 'modules/insites_database/form_code/placeholder', form: form, name: 'personal_email' -%}
                {%- include 'modules/insites_database/form_code/validation/required', form: form, name: 'personal_email' -%}
                {%- if form.errors['properties.personal_email'] != nil -%} has-error {%- endif -%} 
                {%- include 'modules/insites_database/form_code/validation/type', form: form, name: 'personal_email' -%} 
                {%- include 'modules/insites_database/form_code/validation/length', form: form, name: 'personal_email' -%}>
            </ins-input>
        </div>
    
        <!-- Field: Primary Phone -->
        <div class="{%- if form.metadata.properties.primary_phone.two_columns == true -%}column-2{%- else -%}column-1{%- endif -%}">
            <ins-input 
                data-type="string"
                data-ui="text"
                label="{%- include 'modules/insites_database/form_code/label', form: form, name: 'primary_phone' -%}"
                name="{{ form.fields.properties.primary_phone.name }}"
                value="{{ form.fields.properties.primary_phone.value }}"
                error-message="{{ form.errors['properties.primary_phone'] }}"
                {%- include 'modules/insites_database/form_code/placeholder', form: form, name: 'primary_phone' -%}
                {%- include 'modules/insites_database/form_code/validation/required', form: form, name: 'primary_phone' -%}
                {%- if form.errors['properties.primary_phone'] != nil -%} has-error {%- endif -%} 
                {%- include 'modules/insites_database/form_code/validation/type', form: form, name: 'primary_phone' -%} 
                {%- include 'modules/insites_database/form_code/validation/length', form: form, name: 'primary_phone' -%}>
            </ins-input>
        </div>
    
        <!-- Field: Why did you leave your previous job? -->
        <div class="{%- if form.metadata.properties.previous_job.two_columns == true -%}column-2{%- else -%}column-1{%- endif -%}">
            <ins-input 
                data-type="string"
                data-ui="text"
                label="{%- include 'modules/insites_database/form_code/label', form: form, name: 'previous_job' -%}"
                name="{{ form.fields.properties.previous_job.name }}"
                value="{{ form.fields.properties.previous_job.value }}"
                error-message="{{ form.errors['properties.previous_job'] }}"
                {%- include 'modules/insites_database/form_code/placeholder', form: form, name: 'previous_job' -%}
                {%- include 'modules/insites_database/form_code/validation/required', form: form, name: 'previous_job' -%}
                {%- if form.errors['properties.previous_job'] != nil -%} has-error {%- endif -%} 
                {%- include 'modules/insites_database/form_code/validation/type', form: form, name: 'previous_job' -%} 
                {%- include 'modules/insites_database/form_code/validation/length', form: form, name: 'previous_job' -%}>
            </ins-input>
        </div>
    
        <!-- Field: Which of our services are you interested in? -->
        <div class="{%- if form.metadata.properties.service_of_interest.two_columns == true -%}column-2{%- else -%}column-1{%- endif -%}">
            <ins-input-multiple 
                data-type="array"
                data-ui="input_multiple"
                label="{%- include 'modules/insites_database/form_code/label', form: form, name: 'service_of_interest' -%}"
                name="{{ form.fields.properties.service_of_interest.name }}"
                value="{{ form.fields.properties.service_of_interest.value }}"
                error-message="{{ form.errors['properties.service_of_interest'] }}"
                {%- include 'modules/insites_database/form_code/placeholder', form: form, name: 'service_of_interest' -%}
                {%- include 'modules/insites_database/form_code/validation/required', form: form, name: 'service_of_interest' -%}
                {%- if form.errors['properties.service_of_interest'] != nil -%} has-error {%- endif -%}></ins-input-multiple>
        </div>
    
        <!-- Field: Attach Documents -->
        <div class="{%- if form.metadata.properties.attach_documents.two_columns == true -%}column-2{%- else -%}column-1{%- endif -%}">
            <ins-input-file
                data-multiple="false"
                data-name="{{ form.fields.properties.attach_documents.name }}"
                data-type="upload"
                data-ui="media_file"
                data-prop="attach_documents"
                label="{%- include 'modules/insites_database/form_code/label', form: form, name: 'attach_documents' -%}"
                accepted-files=""
                capture=""
                error-message="{{ form.errors['properties.attach_documents'] }}"
                {%- include 'modules/insites_database/form_code/validation/file', form: form, name: 'attach_documents' -%}
                {%- include 'modules/insites_database/form_code/validation/required', form: form, name: 'attach_documents' -%}
                {%- if form.errors['properties.attach_documents'] != nil -%} has-error {%- endif -%}>
            </ins-input-file>
        </div>
    </div>
    
    <!-- Form Group: Additional Details -->
    <div class="form-group" data-group-id="51a431b3-a1ec-4907-a541-4ab7d9d968c2">
        <!-- Field: Name of the Contact Person -->
        <div class="{%- if form.metadata.properties.contact_name.two_columns == true -%}column-2{%- else -%}column-1{%- endif -%}">
            <ins-input 
                data-type="string"
                data-ui="text"
                label="{%- include 'modules/insites_database/form_code/label', form: form, name: 'contact_name' -%}"
                name="{{ form.fields.properties.contact_name.name }}"
                value="{{ form.fields.properties.contact_name.value }}"
                error-message="{{ form.errors['properties.contact_name'] }}"
                {%- include 'modules/insites_database/form_code/placeholder', form: form, name: 'contact_name' -%}
                {%- include 'modules/insites_database/form_code/validation/required', form: form, name: 'contact_name' -%}
                {%- if form.errors['properties.contact_name'] != nil -%} has-error {%- endif -%} 
                {%- include 'modules/insites_database/form_code/validation/type', form: form, name: 'contact_name' -%} 
                {%- include 'modules/insites_database/form_code/validation/length', form: form, name: 'contact_name' -%}>
            </ins-input>
        </div>
    
        <!-- Field: Contact Number -->
        <div class="{%- if form.metadata.properties.contact_number.two_columns == true -%}column-2{%- else -%}column-1{%- endif -%}">
            <ins-input 
                data-type="string"
                data-ui="text"
                label="{%- include 'modules/insites_database/form_code/label', form: form, name: 'contact_number' -%}"
                name="{{ form.fields.properties.contact_number.name }}"
                value="{{ form.fields.properties.contact_number.value }}"
                error-message="{{ form.errors['properties.contact_number'] }}"
                {%- include 'modules/insites_database/form_code/placeholder', form: form, name: 'contact_number' -%}
                {%- include 'modules/insites_database/form_code/validation/required', form: form, name: 'contact_number' -%}
                {%- if form.errors['properties.contact_number'] != nil -%} has-error {%- endif -%} 
                {%- include 'modules/insites_database/form_code/validation/type', form: form, name: 'contact_number' -%} 
                {%- include 'modules/insites_database/form_code/validation/length', form: form, name: 'contact_number' -%}>
            </ins-input>
        </div>
    
        <!-- Field: Would you like us to update your site or would you like to be responsible for updates?  -->
        <div class="{%- if form.metadata.properties.update_site.two_columns == true -%}column-2{%- else -%}column-1{%- endif -%}">
            <ins-input 
                data-type="string"
                data-ui="text"
                label="{%- include 'modules/insites_database/form_code/label', form: form, name: 'update_site' -%}"
                name="{{ form.fields.properties.update_site.name }}"
                value="{{ form.fields.properties.update_site.value }}"
                error-message="{{ form.errors['properties.update_site'] }}"
                {%- include 'modules/insites_database/form_code/placeholder', form: form, name: 'update_site' -%}
                {%- include 'modules/insites_database/form_code/validation/required', form: form, name: 'update_site' -%}
                {%- if form.errors['properties.update_site'] != nil -%} has-error {%- endif -%} 
                {%- include 'modules/insites_database/form_code/validation/type', form: form, name: 'update_site' -%} 
                {%- include 'modules/insites_database/form_code/validation/length', form: form, name: 'update_site' -%}>
            </ins-input>
        </div>
    
        <!-- Field: Is there anything else you'd like to tell us?  -->
        <div class="{%- if form.metadata.properties.notes.two_columns == true -%}column-2{%- else -%}column-1{%- endif -%}">
            <ins-input 
                data-type="string"
                data-ui="text"
                label="{%- include 'modules/insites_database/form_code/label', form: form, name: 'notes' -%}"
                name="{{ form.fields.properties.notes.name }}"
                value="{{ form.fields.properties.notes.value }}"
                error-message="{{ form.errors['properties.notes'] }}"
                {%- include 'modules/insites_database/form_code/placeholder', form: form, name: 'notes' -%}
                {%- include 'modules/insites_database/form_code/validation/required', form: form, name: 'notes' -%}
                {%- if form.errors['properties.notes'] != nil -%} has-error {%- endif -%} 
                {%- include 'modules/insites_database/form_code/validation/type', form: form, name: 'notes' -%} 
                {%- include 'modules/insites_database/form_code/validation/length', form: form, name: 'notes' -%}>
            </ins-input>
        </div>
    </div>
    
    <!-- Form Group: Confirmation -->
    <div class="form-group" data-group-id="cdf25c4d-40f9-45f6-9f6c-3052e98c0108">
        <!-- Field: I understand and agree -->
        <div class="{%- if form.metadata.properties.agreement.two_columns == true -%}column-2{%- else -%}column-1{%- endif -%}">
            <ins-input-multiple 
                data-type="array"
                data-ui="input_multiple"
                label="{%- include 'modules/insites_database/form_code/label', form: form, name: 'agreement' -%}"
                name="{{ form.fields.properties.agreement.name }}"
                value="{{ form.fields.properties.agreement.value }}"
                error-message="{{ form.errors['properties.agreement'] }}"
                {%- include 'modules/insites_database/form_code/placeholder', form: form, name: 'agreement' -%}
                {%- include 'modules/insites_database/form_code/validation/required', form: form, name: 'agreement' -%}
                {%- if form.errors['properties.agreement'] != nil -%} has-error {%- endif -%}></ins-input-multiple>
        </div>
    </div>
    
    </div>
    
    <div class="insites-form-grid">
        <div class="insites-form-buttons column-1 text-right">
            <ins-button type="button" onclick="InsitesFormProcessor.back()" label="BACK" class="form-group-button form-back" outlined></ins-button>
            <ins-button type="button" onclick="InsitesFormProcessor.next()" label="NEXT" class="form-group-button form-next" style="display: inline;" solid></ins-button>
            <ins-button type="submit" label="SAVE & NEXT" class="form-group-button form-submit" solid></ins-button>
        </div>
    </div>
    
    {%- endform -%}
    
    <script id="{{ form.name }}">
        InsitesFormProcessor.setFormProps("{{ form.name }}", "{{ form.system_fields.parent_resource_id }}", {{ form.fields.properties }}, {{ form.metadata.form_groups | default: '[]' }}, true);
    </script>