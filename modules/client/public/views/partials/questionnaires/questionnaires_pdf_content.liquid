{% parse_json filters %}
{
    "user_id": "{{context.current_user.id}}",
    "id": "{{questionnaire_id}}"       
}
{% endparse_json %}
{%- graphql data = "modules/client/questionnaires/get_questionnaires", args: filters | dig: "items","results" | first -%}

<!DOCTYPE html>
<html>
<head>
<title>Questionnaire {{data.year}}</title>
<style type="text/css">
    table {
        background-color: transparent; 
        width: 100%;
        border-collapse: collapse;
        border-spacing: 0;
        border: none;	
    }
    
    @media print {
        body {
            -webkit-print-color-adjust: exact;
        }
    }

    @page {
        margin: 10mm 8mm;
    }
    
    h1, h2, h3{
        margin-bottom: 8px;
    }

    table td, p {
        font-size: 10px;
        line-height: 14px;
        padding-top: 7px;
        padding-bottom: 7px;
    }

    hr {
        padding-top: 15px;
        border-top: 0;
        border-right: 0;
        border-bottom: 1px solid #cacaca;
        border-left: 0;
    }
</style>
</head>
<body>
<page style="font-size: 12pt">
    <div style="padding: 24px; border: 1px solid;">
        <h2>Questionnaire 2023</h2> 
        <p>Submitted on {{ data.created_at | date: "%Y-%m-%d" }}</p>
        <hr>

        <h2>General Information</h2>                
        <div style="padding: 0px 8px;">
            <table class="other-details">
            <tbody>
              <tr>
                <td>Have you ever heard about Insites?</td>
                <td>{{data.have_you_heard}}</td>
              </tr>
              <tr>
                <td>How did you learn about Insites?</td>
                <td>{{data.howd_you_learn}}</td>
              </tr>
              <tr>
                <td>What is the main reason you visit our website?</td>
                <td>{{data.reason_for_visit}}</td>
              </tr>
              <tr>
                <td>Personal Email</td>
                <td>{{data.personal_email}}</td>
              </tr>
              <tr>
                <td>Primary Phone</td>
                <td>{{data.primary_phone}}</td>
              </tr>
              <tr>
                <td colspan="2">Why did you leave your previous job?</td>
              </tr>
              <tr>
                <td colspan="2" style="padding-left: 24px;"> - {{data.previous_job | default: 'N/A'}}</td>
              </tr>
              <tr>
                <td>Which of our services are you interested in?</td>
                <td>{{data.service_of_interest | join: ', '}}</td>
              </tr>
            </tbody>
            </table>
        </div>

        <h2>Additional Details</h2>        
        <div style="padding: 0px 8px;">
            <table class="other-details">
            <tbody>
              <tr>
                <td>Name of the Contact Person</td>
                <td>{{data.contact_name}}</td>
              </tr>
              <tr>
                <td>Contact Number</td>
                <td>{{data.contact_number}}</td>
              </tr>
              <tr>
                <td>Would you like us to update your site or would you like to be responsible for updates?</td>
                <td>{{data.update_site}}</td>
              </tr>
              <tr>
                <td colspan="2"><h3>Other Relevant Notes</h3></td>
              </tr>    
              <tr>
                <td colspan="2">Is there anything else you'd like to tell us?</td>
              </tr>              
              <tr>
                <td colspan="2" style="padding-left: 24px;"> - {{data.notes | default: 'N/A'}}</td>
              </tr>             
            </tbody>
            </table>
        </div>

    </div>
</page>
</body>
</html>