{% graphql stripe_create_card = 'modules/website/trigger_api_call', 
    name: "modules/client/create_card",
    data: stripe_card
    | dig: 'items' | dig: 'response' %}

    {%- assign stripe_create_card = stripe_create_card.body | parse_json -%}
    {% parse_json credit_card %}
    {
        "uuid": "",
        "user_id":  "{{ user_id }}",
        "currency": "",
        "bank_name": "",
        "card_brand": "",
        "company_uuid": "",
        "contact_uuid": "{{ external_id }}",
        "bank_account_bsb": "",
        "card_expiry_year": "{{ stripe_create_card.exp_year }}",
        "bank_account_name": "",
        "card_expiry_month": " {{ stripe_create_card.exp_month }}",
        "payment_method_name": "Stripe",
        "payment_method_token":  "{{ stripe_create_card.id }}",
        "card_last_four_digits": "{{ stripe_create_card.last4 }}",
        "bank_account_last_four_digits": ""
    }
    {% endparse_json %}
    {% comment %} Create pOS credit card model {% endcomment %}
    {% graphql card_model = "modules/client/credit_cards/create_credit_card"
        args: credit_card | dig: "items" %}
    

{%- comment -%}Return Stripe Card ID{%- endcomment -%}
{%- if return == true -%}
    {{ stripe_create_card.id }}
{%- endif -%}