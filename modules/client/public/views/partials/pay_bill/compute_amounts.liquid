{% comment %} Payload: total_amount {% endcomment %}

{%  liquid
    assign amount = total_amount | divided_by: 1.017
    assign cc_surcharge = amount | times: 0.017
%}

{% parse_json computed %}
{
    "amount": {{ amount }},
    "cc_surcharge": {{ cc_surcharge }},
    "total_amount": {{ total_amount }}
}
{% endparse_json %}

{% liquid return computed %}