{%  liquid
    assign amount = amount
    assign cc_surcharge = amount | times: 0.017
    assign total_amount = amount | plus: cc_surcharge 
%}

{% parse_json computed %}
{
    "amount": {{ amount }},
    "cc_surcharge": {{ cc_surcharge }},
    "total_amount": {{ total_amount }}
}
{% endparse_json %}

{% liquid return computed %}