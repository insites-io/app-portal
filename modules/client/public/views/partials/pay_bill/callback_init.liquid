{%- comment -%} Get Gateway Settings from eCommerce settings  {%- endcomment -%}
{%- graphql settings = "modules/ecommerce/system/get_settings" | dig: 'items' | dig: 'results' | first -%}

{% comment %} Compute values {% endcomment %}
{%- assign amountPayable = form.properties.product_price | times: 100 -%}

{% comment %} Static - 1.7% fix visa/master surcharge charge {% endcomment %}
{%- assign ccSurcharge = amountPayable | times: 0.017 -%} 

{% comment %} Static - Tax 10% {% endcomment %}
{%- assign taxAmount = amountPayable | plus: ccSurcharge -%}
{%- assign taxAmount = taxAmount | times: 0.1  -%}

{% comment %} Total amount = Input value payable inclusive of Tax + CC bill amount {% endcomment %}
{%- assign totalAmount = amountPayable | plus: ccSurcharge | plus: taxAmount -%}

{% parse_json payable %}
{
    "cc_charge_amount": {{ ccSurcharge | default: 0 }},
    "tax_amount": {{ taxAmount | default: 0 }},
    "product_price": {{ amountPayable | default: 0 }},
    "total_amount": {{ totalAmount | default: 0 }}
}
{% endparse_json %}

{% comment %} Check session / user id {% endcomment %}
{%- graphql user_data = 'modules/ecommerce/account/get_current_user' -%}
{%- assign user = user_data.current_user -%}
{%- if user -%}
    {%- assign user_id = user.id -%}
{%- else -%}
    {%- assign user_id = context.session.session_id -%}
{%- endif -%}


{%- comment -%}START: Payment callback process
    - Create cart entry for 'cc charge'
    - Update cart amount to 100 for Stripe amount as centavos
    - Create order 
    - API call to Stripe (Payment)
    - Create / Update models
    - Trigger Email & API callback via GraphQL
{%- endcomment -%}

{% comment %} Step 1: Create cart record for 'cc bill amount 1.7%' {% endcomment %}
{%- graphql cc_cart = "modules/ecommerce/cart/create_cart", 
    user_id: user_id,
    quantity: 1,
    product_name: "Credit Card Surcharge",
    product_price: payable.cc_charge_amount 
    | dig: "items" -%}

{% comment %} Step 2:  Update cart amount as 'Stripe amount' centavos {% endcomment %}
{%- graphql updated_cart = "modules/ecommerce/cart/update_cart", 
    id: form.id,
    user_id: user_id,
    quantity: 1,
    product_price: payable.product_price,
    tax_amount: payable.tax_amount 
    | dig: "items" -%}

{% comment %} Step 3: Create order {% endcomment %}
{%- assign date_time = "now" | date: "%Y-%m-%dT%H:%M:%SZ" -%}
{%- assign currency = settings.currency | default: 'AUD' -%}
{%- assign order_value = payable.product_price | plus: payable.cc_charge_amount -%}

{%- graphql order = "modules/ecommerce/orders/create_order", 
    date_time: date_time,
    user_id: user_id,
    billing_first_name: form.properties.billing_first_name,
    billing_last_name: form.properties.billing_last_name,
    billing_email: form.properties.billing_email,
    billing_phone: form.properties.billing_phone,
    billing_address_1: form.properties.billing_address_1,
    billing_address_2: form.properties.billing_address_2,
    billing_address_3: form.properties.billing_address_3,
    billing_city: form.properties.billing_city,
    billing_county: form.properties.billing_county,
    billing_district: form.properties.billing_district,
    billing_suburb: form.properties.billing_suburb,
    billing_state: form.properties.billing_state,
    billing_country: form.properties.billing_country,
    billing_postcode: form.properties.billing_postcode,
    currency: currency,
    shipping_amount: 0.0,
    order_value: order_value,
    tax_amount: payable.tax_amount,
    total_amount: payable.total_amount,
    amount_due: payable.total_amount,
    billing_company_name: form.properties.company_name,
    order_status: "Open",
    order_payment_status: "Open"
    | dig: "items" -%}

{%- assign properties = order 
    | dig: 'properties'
    | add_hash_key: "skip_shipping_address", true
    | add_hash_key: "billing_address_id", form.properties.billing_address_id
    | add_hash_key: "stripe_credit_card", form.properties.stripe_credit_card  -%}
{%- assign order = order | add_hash_key: 'properties', properties -%}

{%- assign cart_ids = "" | split: ',' -%}
{%- assign form_id = form.id | append: '' -%}
{%- assign cart_ids = cart_ids | add_to_array: form_id -%}
{%- assign cart_ids = cart_ids | add_to_array: cc_cart.id -%}


{% log "==== Processing checkout and payment ====" %}

{%- comment -%}GET Cart data{%- endcomment -%}
{% include 'modules/ecommerce/checkout/compute_order_summary',
    cart_ids: cart_ids %}

{%- comment -%}
Step 1: Get gateway settings from INS Ecommerce settings and process payment
{%- endcomment -%}
{%- graphql settings = "modules/ecommerce/system/get_settings" | dig: 'items' | dig: 'results' | first -%}
{%- assign gateway = settings.gateway_name | downcase -%}
{%- assign payment_status = "Failed" -%}
{%- case gateway -%}
    {%- when 'stripe' -%}
        {%- comment -%}Step 1-A: Stripe payment process{%- endcomment -%}
        {%- include 'modules/ecommerce/stripe/payment/checkout_payment_paybill', 
            form: order,
            user_id: context.exports.user_id,
            company_id: context.exports.company_id,
            company_name: context.exports.company_name -%}
        {%- comment -%}
        If new / other payment gateways are supported, insert process here:
        {%- endcomment -%}

    {%- else -%}
        {% log "ERROR: Payment gateway invalid / not set. Please check INS Ecommerce settings." %}
{%- endcase -%}

    {%- comment -%}
    Capture gateway reposnse and set status
    {%- endcomment -%}
    {%- assign status = context.exports.payment_response.status | downcase -%}
    {%- assign user_id = context.exports.user_id | downcase -%}
    {%- assign order_id = order.id | downcase -%}
    {%- if status == 'succeeded' -%}
        {%- assign status = 'success' -%}
        {%- assign cart_status = "Paid" -%}
        {%- assign order_payment_status = "Paid" -%}
        {%- assign order_status = "Complete" -%}
    {%- else -%}
        {%- assign status = 'failed' -%}
        {%- assign cart_status = "Failed" -%}
        {%- assign order_payment_status = "Failed" -%}
        {%- assign order_status = "Open" -%}
    {%- endif -%}


{%- comment -%}
Step 2: Update inventory, cart and order models.
{%- endcomment -%}
{% include 'modules/ecommerce/checkout/callback_update_models'
    status: status,
    cart_status: cart_status,
    order_status: order_status,
    order_payment_status: order_payment_status,
    user_id: user_id,
    order_id: order_id,
    form: order,
    settings: settings %}


{%- comment -%}
Step 3: (optional) Create address models
{%- endcomment -%}
{%- if context.current_user.id -%}
    {% include 'modules/ecommerce/pay_bills/callback_create_address', 
        user_id: user_id,
        form: order %}
{%- endif -%}



{% graphql order = "modules/ecommerce/orders/get_order_details",
    id: order_id 
    | dig: 'items' | dig: 'results' | first %}
{% graphql cart = "modules/ecommerce/cart/get_cart",
    order_id: order_id 
    | dig: 'items' | dig: 'results' %}

{%- comment -%}
Step 4: Trigger autoresponder, workflow email, API, Event Stream 
{%- endcomment -%}
{% parse_json customer_info %}
{
    "email": "{{ order.billing_email }}",
    "first_name": "{{ order.billing_first_name }}",
    "last_name": "{{ order.billing_last_name }}"
}
{% endparse_json %}
{% parse_json data %}
{
    "payment_response": {{ context.exports.payment_response }},
    "customer_info": {{ context.current_user | default: customer_info }},
    "cart_ids": {{ context.exports.order.cart_ids }},
    "cart": {{ cart }},
    "order_id": {{ order_id }},
    "order_info": {{ context.exports.updated_order.items }},
    "order": {{ order }}
}
{% endparse_json %}
{% log "==== Email & API: status ====" %}

{%- comment -%}Step 4.1 Workflow & Email Notification{%- endcomment -%}
{% include 'modules/ecommerce/pay_bills/callback_email_notifications', 
    status: status,
    data: data %}

{%- comment -%}Step 4.2 Create Event Stream{%- endcomment -%}
{% include 'modules/ecommerce/event/pay_bills_event', 
    status: status,
    data: data %}
