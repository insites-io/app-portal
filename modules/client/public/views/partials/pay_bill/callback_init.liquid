{% comment %} 
  Steps:
    1. Gateway / Create Payment
    2. Update models/records (Payment, Order)
    3. Email Notification
{% endcomment %}


{% comment %} Get Gateway Settings from Ecommerce settings {% endcomment %}
{% function settings = "modules/client/pay_bill/get_settings" %}
{% assign gateway = settings.gateway_name | downcase %}

{% comment %} Step 1: Gateway / Create Payment {% endcomment %}
{% case gateway %}
    {% when 'stripe' %}
        {% comment %}Step 1-A: Stripe payment process{% endcomment %}
        {% include 'modules/client/stripe/payment/checkout_payment_paybill', 
            form: form %}
        {% comment %}
        If new / other payment gateways are supported, insert process here:
        {% endcomment %}

    {% else %}
        {% log "ERROR: Payment gateway invalid / not set. Please check INS Ecommerce settings." %}
{% endcase %}


{% comment %} Capture gateway response {% endcomment %}
{% assign status = context.exports.payment_response.status | downcase %}
{% assign order_id = form.id | downcase %}


{% comment %} Step 2. Update models/records {% endcomment %}
{% include 'modules/client/pay_bill/callback_update_models'
    status: status,
    order_id: order_id,
    form: form,
    settings: settings %}


{% comment %} Step 3. Email Notification {% endcomment %}
{% parse_json customer_info %}
{
    "email": "{{ context.current_user.email }}",
    "first_name": "{{ context.current_user.first_name }}",
    "last_name": "{{ context.current_user.last_name }}"
}
{% endparse_json %}
{% parse_json data %}
{
    "payment_response": {{ context.exports.payment_response }},
    "customer_info": {{ customer_info }},
    "order_id": {{ order_id }},
    "order_info": {{ context.exports.update_order.items }}
}
{% endparse_json %}

{% include 'modules/client/pay_bill/callback_email_notifications', 
    status: status,
    data: data %} 