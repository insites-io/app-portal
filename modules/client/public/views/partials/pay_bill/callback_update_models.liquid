{% comment %} 
  Steps:
    1. Create Payment record on POS
    2. Update Order record
{% endcomment %}


{% comment %} Set status based on Stripe Charge (Create Payment) response {% endcomment %}
{%  liquid

    if status == "succeeded"
        assign status = "success"
        assign order_payment_status = "Paid"
        assign order_status = "Complete"
    else
        assign status = "failed"
        assign order_payment_status = "Failed"
        assign order_status = "Open"
    endif
%}

{% comment %} Compute amounts {% endcomment %}
{% liquid

    function computed = "modules/client/pay_bill/compute_amounts", total_amount: form.properties.order_value
    
    if status == 'success'
        assign amount_due = 0.0
    else
        assign amount_due = computed.total_amount
    endif
%}

{% comment %} Stripe Charge (Create Payment) response {% endcomment %}
{% assign stripe_payment_response = context.exports.payment_response %}
{% parse_json card %}
{
    "last4": "{{ stripe_payment_response.source.last4 }}",
    "brand": "{{ stripe_payment_response.source.brand }}",
    "exp_month": "{{ stripe_payment_response.source.exp_month }}",
    "exp_year": "{{ stripe_payment_response.source.exp_year }}"
}
{% endparse_json %}


{% comment %} Step 1: Create Payment record on POS {% endcomment %}
{% parse_json data %}
{
    "order_id": "{{order_id}}",
    "payment_source": "Payment Gateway",
    "payment_status": "{{order_payment_status}}",
    "payment_gateway_name": "{{settings.gateway_name}}",
    "date_time": "{{ 'now' | date: '%Y-%m-%dT%H:%M:%SZ' }}",
    "last_updated_by_id": "{{context.current_user.id}}",
    "is_enabled": true,
    "card_last4": "{{card.last4}}",
    "card_brand": "{{card.brand}}",
    "card_exp_month": "{{card.exp_month}}",
    "card_exp_year": "{{card.exp_year}}",
    "currency": "{{settings.currency}}",
    "order_value": {{computed.total_amount}},
    "amount": {{computed.total_amount}},
    "amount_due": {{amount_due}}
}
{% endparse_json %}
{% assign data = data | add_hash_key: "payment_gateway_details", stripe_payment_response %}

{%  graphql add_payment = 'modules/website/trigger_api_call', 
    name: "modules/client/ecommerce/add_payment",
    data: data
    | dig: 'items','response','body'
    | parse_json %}   

{%- liquid
    session paybill_payment_id = add_payment.items.id
    session paybill_status = status

    if status == 'failed'
        session paybill_error = stripe_payment_response
    endif
-%}
{% log "==== Payment Created ====" %}


{% comment %} Step 2: Update Order record {% endcomment %}
{% parse_json data %}
{
    "id": "{{ form.id }}",
    "order_number": "{{ form.properties.order_number }}",
    "user_id": "{{ context.current_user.id }}",
    "order_status": "{{ order_status }}",
    "order_payment_status" : "{{ order_payment_status }}",
    "amount_due" : {{ amount_due }},
    "total_amount" : {{ computed.total_amount }},
    "shipping_amount": 0,
    "tax_amount": 0,
    "order_value" : {{ computed.total_amount }},
    "order_first_name": "{{ context.current_user.first_name }}", 
    "order_last_name": "{{ context.current_user.last_name }}",
    "last_updated_by_id": "{{ context.current_user.id }}"
}
{% endparse_json %}
{%  graphql update_order = 'modules/website/trigger_api_call', 
    name: "modules/client/ecommerce/update_order",
    data: data
    | dig: 'items','response','body'
    | parse_json %}

{%- session paybill_order_id = update_order.items.id -%}
{% log "==== Order Updated ====" %}


{% export update_order %}