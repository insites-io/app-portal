{%- if user_id -%}
    {%- comment -%}Optional parameter to get specific user's cart{%- endcomment -%}
    {%- assign user_id = user_id -%}
{%- else -%}
    {%- unless order_id -%}
        {%- comment -%}Automatically get & set user_id parameter {%- endcomment -%}
        {%- if context.current_user.id -%}
            {%- assign user_id = context.current_user.id -%}
        {%- else -%}
            {%- assign user_id = context.session.session_id -%}
        {%- endif -%}
    {%- endunless -%}
{%- endif -%}


{%- if order_id -%}
    {%- assign discount_debited = true -%}
{%- else -%}
    {%- assign discount_debited = false -%}
{%- endif -%}

{% comment %} STEP 1: Get discount object, and create array for discounts info {% endcomment %}

{%- 
    liquid
    assign cart_discount_codes_list = "" | split: ","
-%}

{% comment %} Step 2: Get Cart items {% endcomment %}
{%- unless order_id -%}
    {%- assign status = "Cart" -%}
{%- endunless -%} 

{% graphql cart = 'modules/ecommerce/cart/get_cart', 
    is_compute: true, id: cart_id, ids: cart_ids, user_id: user_id, order_id: order_id, status: status | dig: 'items' | dig: 'results' %}

{%- assign cart_ids = "" | split: ',' %}
{%- assign cart_discount_code_ids = "" | split: ',' %}
{%- assign discount_code_ids = "" | split: ',' %}
{%- assign free_shipping = false -%}


{% comment %} INFO: Partial variables used inside as global {% endcomment %}
{% comment %} INFO: Discounted variables {% endcomment %}
{%- assign cart_shipping_discount = 0 -%}
{%- assign cart_product_discount = 0 -%}
{%- assign cart_discounted_shipping_tax = 0 -%}
{%- assign cart_discounted_product_tax = 0 -%}
{%- assign cart_discounted_product_total = 0 -%}
{%- assign cart_discounted_shipping_total = 0 -%}
{% comment %} INFO: Undiscounted variables {% endcomment %}
{%- assign cart_product_amount = 0 -%}
{%- assign cart_shipping_amount = 0 -%}
{%- assign cart_undiscounted_product_tax = 0 -%}
{%- assign cart_undiscounted_shipping_tax = 0 -%}
{%- assign cart_undiscounted_product_total = 0 -%}
{%- assign cart_undiscounted_shipping_total = 0 -%}


{%- for item in cart -%}
    {% comment %} Step 2-A: Reiterate cart Items {% endcomment %}
    {% comment %} DEV NOTES:
        - 'cart_discount_codes_list' is an array of all discount codes applied to cart/checkout
        - Uf a discount code is set to apply_to == 'all', it will have the cart IDs in it 
        - Here, we're checking from the array, if the 'cart id' we're looping exists/matches from the discount code's list of cart ids eligible for its discount to be applied to,
        - If we get an object returned, we save it on 'discount_code' variable. This means the cart entry is discountable, and computation is adjusted accordingly
        - Discount is accumulative, meaning if 2 or more discount applies for the same product, both will add up. 
        - Computation will always base from the original product amount (ie. for % discount)
    {% endcomment %}
    {%- assign discount = cart_discount_codes_list | detect: cart_id: item.id -%}
    {%- assign max_shipping_discount_value = item.shipping_amount -%}
    {%- assign max_price_discount_value = item.product_price -%}

    {%- assign item_amount = item.product_price -%}

    {% comment %} Note: Quantity doesn't affect shipping {% endcomment %}
    {%- 
        liquid
        assign item_product_amount = item.product_price
        assign item_product_qty = item.quantity
        assign item_product_discount = 0
        assign item_product_amount_sub = item_product_amount | times: item_product_qty
        
        assign item_shipping_amount = item.shipping_amount
        assign item_shipping_qty = 1
        assign item_shipping_discount = 0
        assign item_shipping_amount_sub = item_shipping_amount | times: item_shipping_qty

        assign item_tax = item.tax_amount | divided_by: 100 
    -%}

    {% comment %} Trigger: Check Shipping {% endcomment %}
    {%- if item.free_shipping == true -%}
        {%- assign item_shipping = 0 -%}
        {%- assign item_shipping_amount = 0 -%}
    {%- else -%}
        {%- assign item_shipping = item.shipping_amount -%}
    {%- endif -%}
    {%- assign cart_ids = cart_ids | add_to_array: item.id -%}
    
    {% comment %} Step 2-B: Check/Iterate Discount Applicable {% endcomment %}
    {%- if discount -%}
        {% comment %} Trigger: Discountable {% endcomment %}
        {%- for code in cart_discount_codes_list -%}
            {%- assign discount_code = false -%}
            {%- assign cart_discount_code_ids = cart_discount_code_ids | add_to_array: code.discount_cart_id | uniq -%}

            {%- if code.cart_id == item.id and code.apply_to_total == false -%}
                {% comment %} Trigger: If we get cart_id == item.id, means cart entry is discountable {% endcomment %}

                {%- assign discount_code_ids = discount_code_ids | add_to_array: code.discount_code_id | uniq -%}
                {%- assign discount_code = code -%}
                {%- assign discount_code = discount_code.discount_code -%}
                {%- assign type = discount_code.discount_type | downcase -%}

                {% comment %}Trigger: Check discount type: "Fixed Value / Percent Value" {% endcomment %}
                {%- if type contains "fix" -%}
                    {%- assign discount_value = discount_code.discount_value | times: 100 -%}
                {%- elsif type contains "percent" -%}
                    {%- assign discount_value = discount_code.discount_value | divided_by: 100 -%}
                {%- endif -%}

                {%- unless forloop.first -%}
                    {%- assign has_been_discounted = true -%}
                {%- endunless -%}

                {% comment %}Trigger: Check if discount is multipliable by cart qty {% endcomment %}
                {%- if code.multiply_by_quantity -%}
                    {%- assign prod_discount_qty = item_product_qty -%}
                    {%- assign ship_discount_qty = item_shipping_qty -%}
                {%- else -%}
                    {%- assign prod_discount_qty = 1 -%}
                    {%- assign ship_discount_qty = 1 -%}
                {%- endif -%}

                {% comment %}Trigger: Check discount type: "Shipping / Product Amount" {% endcomment %}
                {%- if type contains "shipping" -%}

                    {% comment %} START: DISCOUNT FOR SHIPPING {% endcomment %}
                    {%- 
                        liquid
                        assign discount_amount = 0 

                        if type contains "fix" and free_shipping == false
                            assign discount_amount = discount_value | times: ship_discount_qty
                        elsif type contains "percent" and free_shipping == false
                            assign pre_computed_shipping = item_shipping_amount | times: ship_discount_qty
                            assign discount_amount = pre_computed_shipping | times: discount_value
                        elsif type contains 'free shipping'
                            assign discount_amount = item_shipping_amount | times: item_shipping_qty
                            if discount_code.apply_to == 'all'
                                assign free_shipping = true
                            endif
                        endif

                        if discount_amount > item_product_amount_sub
                            assign discount_amount = item_product_amount_sub
                        endif

                        assign item_shipping_discount = item_shipping_discount | plus: discount_amount
                    -%}
                    {% comment %} END: DISCOUNT FOR SHIPPING {% endcomment %}

                {%- else -%}

                    {% comment %} START: DISCOUNT IS FOR PRODUCT {% endcomment %}
                    {%- 
                        liquid
                        assign discount_amount = 0 

                        if type contains "fix" and free_shipping == false
                            assign discount_amount = discount_value | times: prod_discount_qty
                            
                        elsif type contains "percent" and free_shipping == false
                            assign pre_computed_product = item_product_amount | times: prod_discount_qty
                            assign discount_amount = pre_computed_product | times: discount_value
                            
                        endif

                        if discount_amount > item_product_amount_sub
                            assign discount_amount = item_product_amount_sub
                        endif

                        assign item_product_discount = item_product_discount | plus: discount_amount
                    -%}
                    {% comment %} END DISCOUNT FOR AMOUNT {% endcomment %}

                {%- endif -%}

            {%- else -%}
                {% comment %} Trigger: Discount is for 'overall total' and will be computed at the end {% endcomment %}
            {%- endif -%}

        {%- endfor -%}


        {% comment %} CHECKER: Make sure no value is above the limit {% endcomment %}
        {%- 
            liquid

            if item_shipping_discount > item_shipping_amount_sub
                assign item_shipping_discount = item_shipping_amount_sub
            endif
            if item_product_discount > item_product_amount_sub
                assign item_product_discount = item_product_amount_sub
            endif
        -%}

    {%- else -%}

        {% comment %} Trigger: Not discountable {% endcomment %}
        {% comment %} <br>----- No discount: Compute regular price ----<br> {% endcomment %}
        
    {%- endif -%}

    {%- comment -%} STEP: Compute discounted Price, Tax, and this items subtotals {%- endcomment -%}
    {% comment %}
        DEV NOTES:
        - Both Price and Shipping are applied tax separately
        - The amount of task is computed after discount have been applied
            - This can be changed to get the tax from the undiscounted price
    {% endcomment %}
    {%- 
        liquid
        assign item_discounted_price_sub_total = item_product_amount_sub | minus: item_product_discount
        assign item_discounted_shipping_sub_total = item_shipping_amount_sub | minus: item_shipping_discount

        if item_discounted_price_sub_total < 0
            assign item_discounted_price_sub_total = 0
        endif
        if item_discounted_shipping_sub_total < 0
            assign item_discounted_shipping_sub_total = 0
        endif

        assign item_discounted_product_tax = item_discounted_price_sub_total | times: item_tax
        assign item_discounted_shipping_tax = item_discounted_shipping_sub_total | times: item_tax
        
        assign item_discounted_product_total = item_discounted_price_sub_total | plus: item_discounted_product_tax
        assign item_discounted_shipping_total = item_discounted_shipping_sub_total | plus: item_discounted_shipping_tax

        assign item_undiscounted_product_tax =  item_product_amount_sub | times: item_tax
        assign item_undiscounted_shipping_tax = item_shipping_amount_sub | times: item_tax
        
        assign item_undiscounted_product_total = item_product_amount_sub | plus: item_undiscounted_product_tax
        assign item_undiscounted_shipping_total = item_shipping_amount_sub | plus: item_undiscounted_shipping_tax
                
    -%}

    {% comment %} STEP: Add to Partial Variables {% endcomment %}
    {% comment %} DISCOUNT / DISCOUNTED {% endcomment %}
    {%- assign cart_product_discount = cart_product_discount | plus: item_product_discount -%}
    {%- assign cart_shipping_discount = cart_shipping_discount | plus: item_shipping_discount -%}

    {%- assign cart_discounted_shipping_tax = cart_discounted_shipping_tax | plus: item_discounted_shipping_tax -%}
    {%- assign cart_discounted_product_tax = cart_discounted_product_tax | plus: item_discounted_product_tax -%}
    {%- assign cart_discounted_product_total = cart_discounted_product_total | plus:  item_discounted_product_total -%}
    {%- assign cart_discounted_shipping_total = cart_discounted_shipping_total | plus: item_discounted_shipping_total -%}

    {% comment %} NOT DISCOUNTED {% endcomment %}
    {%- assign cart_product_amount = cart_product_amount | plus: item_product_amount_sub -%}
    {%- assign cart_shipping_amount = cart_shipping_amount | plus: item_shipping_amount_sub -%}

    {%- assign cart_undiscounted_product_tax = cart_undiscounted_product_tax | plus: item_undiscounted_product_tax -%}
    {%- assign cart_undiscounted_shipping_tax = cart_undiscounted_shipping_tax | plus: item_undiscounted_shipping_tax -%}
    {%- assign cart_undiscounted_product_total = cart_undiscounted_product_total | plus: item_product_amount_sub -%}
    {%- assign cart_undiscounted_shipping_total = cart_undiscounted_shipping_total | plus: item_shipping_amount_sub -%}

{%- endfor -%}


{% comment %} STEP: Compute total to ready for total deductions and reference... {% endcomment %}
{%- assign order_total_discount = cart_product_discount | plus: cart_shipping_discount -%}

{%- assign order_undiscounted_reference = cart_undiscounted_product_total | plus: cart_undiscounted_shipping_total  -%}
{%- assign order_discounted_reference = cart_discounted_product_total | plus: cart_discounted_shipping_total -%}
{%- assign order_undiscounted_tax = cart_undiscounted_product_tax | plus: cart_undiscounted_shipping_tax -%}
{%- assign order_discounted_tax = cart_discounted_product_tax | plus: cart_discounted_shipping_tax -%}
{%- assign order_undiscounted_amount = order_undiscounted_reference  -%}
{%- assign order_discounted_amount = order_discounted_reference -%}



{% comment %} STEP: Get Discount for overall total {% endcomment %}
{% graphql total_discounts = 'modules/ecommerce/discount_code/get_cart_discount_codes', 
    size: 50, user_id: user_id, order_id: order_id, discount_debited: discount_debited | dig: 'items' | dig: 'results' %}

{% comment %} 
    NOTE:
    - The tax is set via each Products
    - Value of total percent discount is computed from 'order_discounted_reference' value.
        - This value is the total of the cart with the discount applied to each product
        - This is not however affected by the Fix Total Order Discount
    - Deductions of overall discounts affects the order_discounted_amount
        - order_discounted_amount = cart_discounted_product_total + cart_discounted_shipping_total
{% endcomment %}

{% comment %} Info: Variable to collect the  {% endcomment %}
{%- assign total_discount_deductions = 0 -%}
{%- 
    liquid 
    
    for code in total_discounts
        assign apply_to_total = code.discount_codes.apply_to_total 
        if order_id 
            assign discount_code = code 
        else
            assign discount_code = code.discount_codes
        endif

        if apply_to_total == true
            assign type = discount_code.discount_type | downcase
            if type contains "free shipping"
                assign free_shipping = true
                assign cart_shipping_discount = cart_shipping_amount
                assign cart_discounted_shipping_total = 0
                assign cart_discounted_shipping_tax = 0
                
            elsif type contains "fix"
                assign discount_value = discount_code.discount_value | times: 100
                assign total_discount_deductions = total_discount_deductions | plus: discount_value
                                
            elsif type contains "percent"
                assign discount_value = discount_code.discount_value | divided_by: 100
                if discount_value > 1
                    assign discount_value = 1
                endif
                assign amount_discount_value = order_discounted_reference | times: discount_value
                assign total_discount_deductions = total_discount_deductions | plus: amount_discount_value

            endif
        endif
        
    endfor 

-%}

{% comment %} STEP: Recompute the amounts now with the total deductions {% endcomment %}

{% comment %} STEP: Apply overall shiping discount (if any) {% endcomment %}
{%- assign order_discounted_amount = cart_discounted_product_total | plus: cart_discounted_shipping_total -%}
{% comment %} STEP: Apply overall order discount (if any) {% endcomment %}
{%- assign order_discounted_amount = order_discounted_amount | minus: total_discount_deductions -%}
{% comment %} CHECKER: Prevent negative total value {% endcomment %}
{%- if order_discounted_amount < 0 -%}
    {%- assign order_discounted_amount = 0 -%}
{%- endif -%}


{% comment %} STEP: Compute total discount applied (if any) {% endcomment %}
{%- assign order_total_discount = cart_product_discount | plus: cart_shipping_discount | plus: total_discount_deductions -%}
{% comment %} CHECKER: Prevent total discount to exceed original amount values{% endcomment %}
{%- if order_total_discount > order_undiscounted_reference -%}
    {%- assign order_total_discount = order_undiscounted_reference -%}
{%- endif -%}


{% parse_json order %}
{
    "cart_ids": {{ cart_ids | default: "[]" }},
    "sub_total": {{ cart_undiscounted_product_total | default: 0.0 }},
    "shipping_amount": {{ cart_undiscounted_shipping_total | default: 0.0 }},
    "tax_amount": {{ order_discounted_tax | default: 0.0 }},
    "total_amount": {{ order_discounted_amount | default: 0.0 }},
    "free_shipping": {{ free_shipping | default: false }},
    "cart_discount_code_ids": {{ cart_discount_code_ids | default: "[]" }},
    "discount_code_ids": {{ discount_code_ids | default: "[]" }},
    "total_discount_amount": {{ order_total_discount | default: 0.0 }}
}
{% endparse_json %}

{% export order %}