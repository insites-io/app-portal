{% comment %} 
  Steps:
    1. Gateway / Create Payment
    2. Update models/records (Payment, Order)
    3. Email Notification
{% endcomment %}

{% log form, type: "Form" %}

{% comment %} Get Gateway Settings from Ecommerce settings {% endcomment %}
{% function settings = "modules/client/pay_bills/get_settings" %}
{% assign gateway = settings.gateway_name | downcase %}

{% comment %} Step 1: Gateway / Create Payment {% endcomment %}
{% case gateway %}
    {% when 'stripe' %}
        {% comment %}Step 1-A: Stripe payment process{% endcomment %}
        {% include 'modules/client/stripe/payments/checkout_payment_paybill', 
            form: form %}
        {% comment %}
        If new / other payment gateways are supported, insert process here:
        {% endcomment %}

    {% else %}
        {% log "ERROR: Payment gateway invalid / not set. Please check INS Ecommerce settings." %}
{% endcase %}

{% comment %} Capture gateway response {% endcomment %}
{% assign status = context.exports.payment_response.status | downcase %}
{% assign order_id = form.id | downcase %}

{% comment %} Step 2. Update models/records {% endcomment %}
{% include 'modules/client/pay_bills/callback_update_models'
    status: status,
    order_id: order_id,
    form: form,
    settings: settings %}


{% comment %} Step 3. Email Notification {% endcomment %}
{% parse_json customer_info %}
{
    "email": "{{ context.current_user.email }}",
    "first_name": "{{ context.current_user.first_name }}",
    "last_name": "{{ context.current_user.last_name }}"
}
{% endparse_json %}

{% parse_json data %}
{
    "payment_response": {{ context.exports.payment_response }},
    "customer_info": {{ customer_info }},
    "order_id": {{ order_id }}
}
{% endparse_json %}

{% include 'modules/client/pay_bills/callback_email_notifications', 
    status: status,
    data: data %} 

{% comment %} ? UPDATE DISCOUNT USAGE COUNT {% endcomment %}
{% if form.properties.is_discount_code_enabled == "true" %}
    {% assign discount_id = form.properties.discount_id %}
    {% assign usage_count = form.properties.discount_usage_count | default: 0 %}
    {% assign usage_count = usage_count | plus: 1 %}
    
    {% log discount_id, type:"discount_id" %}
    {% log usage_count, type:"usage_count" %}
    
    {% graphql update_usage_count = 'modules/client/discount/update_discount_usage_limit', id: discount_id, usage_count: usage_count %}
    
    {% log update_usage_count, type:"update_usage_count" %}    
{% endif %}