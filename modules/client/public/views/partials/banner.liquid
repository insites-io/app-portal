{%- graphql data = "modules/client/get_banner", size: 10 | dig: "items","results" -%}

{%- if data.size > 0 -%}
<div class="homepage-banner-wrap">
    <ins-carousel no-carousel-button loop
        autoplay
        layout="1" 
        bind-to="homepage-banner"
        transition="700"
        duration="5000"
        data-test="homepage-slider">
        <div id="homepage-banner">

                {%- for item in data -%}
                    <div class="slide-container" >
                        {%- comment -%}Slide Image{%- endcomment -%}
                        {%- if item.desktop_image.url -%}
                        <div class="img-wrap">   
                            {%- if context.device.device_type != "smartphone" -%}
                            <!-- desktop image -->
                            <img src="{{ item.desktop_image.url | replace: ' ', '%20' }}" alt="{{ item.main_text }}" >
                            {%- else -%}
                            <!-- mobile image -->
                            <img src="{{ item.mobile_image.url | replace: ' ', '%20' }}" alt="{{ item.main_text }}" >
                            {%- endif -%}
                        </div>
                        {%- endif -%}
                        
                        {%- comment -%}Slide Text{%- endcomment -%}
                        <div class="slide-content wrapper vertical-align-middle">
                            <div class="grid-x grid-container">
                                <div class="large-6 large-offset-1 medium-12 small-12 cell">
                                    <h1 class="heading heading-1">{{ item.main_text }}</h1>
                                    <div class="spacer"></div>
                                    <p>{{ item.sub_text }}</p>
                                    {%- if item.button_link and item.button_link != '' -%}
                                        <div class="spacer large"></div>
                                        <a href="{{ item.button_link }}" >
                                            <ins-button solid
                                                label="{{item.button_label}}">
                                            </ins-button>
                                        </a>
                                    {%- endif -%}
                                </div>
                                <div class="large-1 medium-1 small-1 cell"></div>
                            </div>
                        </div>
                    </div>
                {%- endfor -%}
            
        </div>
    </ins-carousel>
</div>
{%- endif -%}