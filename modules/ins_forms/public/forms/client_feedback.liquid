      target_id: '2046409'
      belongs_to:
      target_type: CustomModelType
      default_value:
      attribute_type: string
    form_step: 9e96cf3e-c23f-4118-ab5e-f0ed9899ccef
    conditions: []
    field_type: string
    ui_element: radio
    column_size:
    field_label: May we display your feedback as a testimonial on our website?
    orientation: horizontal
    field_weighting: 0
    is_field_hidden: false
    validation_rules: {}
  - id: '18401338'
    name: full_name
    rawData:
      id: '18401338'
      name: full_name
      options: {}
      metadata:
        label: Full Name
        weight: 2
        group_id: 53f9c2ff-7458-4834-8f0b-ec25d72828fe
        ui_element: input
        is_required: true
        is_searchable: true
        is_shown_in_table: true
      target_id: '2046409'
      belongs_to:
      target_type: CustomModelType
