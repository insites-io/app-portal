resource: modules/website/feedback
resource_owner: anyone
---
{%- parse_json localisation -%}{%- include 'modules/insites_forms/form_localisation' -%}{%- endparse_json -%}
{%- assign form_uuid = '' | uuid -%}
<div class="insites-form-wrap">
{%- form html-class: 'insites-form insites-form-code' html-novalidate: 'novalidate' html-data-uuid: form_uuid -%}

<ins-alert-box type="error" class="validation-error" close-icon="icon-close-1" hidden>
	<div>Failed to submit form. Please fix the error(s) found.</div>
</ins-alert-box>
<ins-alert-box type="error" class="api-error" close-icon="icon-close-1" hidden>
	<div>Failed to submit form. Please try again.</div>
</ins-alert-box>

<div class="insites-form-grid">

	<!-- Field: May we display your feedback as a testimonial on our website? -->
	<div class="allow_display_on_website column-1">
		<ins-radio-group 
			data-type="string" 
			data-ui="radio" 
			data-properties="properties.allow_display_on_website" 
			check-load check-value
			horizontal
			data-name="{{ form.fields.properties.allow_display_on_website.name }}"
			label="May we display your feedback as a testimonial on our website?"
			error-message="{{ form.errors['properties.allow_display_on_website'] }}"
			{% if form.errors['properties.allow_display_on_website'] != nil %} has-error {% endif %}>
			<div>
				<ins-radio
					label="Yes" value="Yes"
					name="{{ form.fields.properties.allow_display_on_website.name }}">
				</ins-radio>
				<ins-radio
					label="No" value="No"
					name="{{ form.fields.properties.allow_display_on_website.name }}">
				</ins-radio>
			</div>
		</ins-radio-group>
	</div>

	<!-- Field: Full Name -->
	<div class="full_name column-2">
		<ins-input 
			data-type="string"
			data-ui="input"
			data-properties="properties.full_name"
			label="Full Name*"
			check-load check-value
			name="{{ form.fields.properties.full_name.name }}"
			value="{{ form.fields.properties.full_name.value }}"
			error-message="{{ form.errors['properties.full_name'] }}"
			required 
			{% if form.errors['properties.full_name'] != nil %} has-error {% endif %}  >
		</ins-input>
	</div>

	<!-- Field: Location -->
	<div class="location column-2">
		<ins-input 
			data-type="string"
			data-ui="input"
			data-properties="properties.location"
			label="Location*"
			check-load check-value
			name="{{ form.fields.properties.location.name }}"
			value="{{ form.fields.properties.location.value }}"
			error-message="{{ form.errors['properties.location'] }}"
			required 
			{% if form.errors['properties.location'] != nil %} has-error {% endif %}  >
		</ins-input>
	</div>

	<!-- Field: Message -->
	<div class="message column-1">
		<ins-textarea  
			data-type="string"
			data-ui="multi_line"
			data-properties="properties.message"
			label="Message*"
			check-load check-value
			name="{{ form.fields.properties.message.name }}"
			value="{{ form.fields.properties.message.value }}"
			error-message="{{ form.errors['properties.message'] }}"
			required 
			{% if form.errors['properties.message'] != nil %} has-error {% endif %}>
		</ins-textarea>
	</div>

</div>

<div class="insites-form-grid">
	<div class="insites-form-buttons column-1 right">
		<ins-button type="submit" label="Submit Feedback" icon="icon-check-2" solid class="form-type-submit"></ins-button>
	</div>
</div>

{%- endform -%}
</div>

<script id="{{ form_uuid }}">
	InsitesFormProcessor.initialize("{{ form_uuid }}", "{{ context.authenticity_token }}", {%- include "modules/insites_forms/form_properties", form: form -%}, {{ form.metadata.form_steps | default: "[]" }}, {%- include "modules/insites_forms/form_redirect", name: form.name -%});
</script>