---
from: Insites <notification@insites.io>
layout: modules/insites_core/insites_internal_email_layout
metadata:
  type: workflow
  design:
  email_design: cms_layout
reply_to: notification@insites.io
subject: Form Submission Received
to: '{%- include "modules/insites_cms/globals" -%} {{- context.exports.global.company_email_1
  -}}'
trigger_condition: 'true'
unique_args: ''
---
{%- function default = 'modules/insites_core/functions/insites_brand' -%}
{%- assign assigned_title = title | default: "Form Submission Received" -%}
{%- graphql form_record = 'modules/insites_core/utilities/get_record_for_email', 
    id: form.id -%}
{% capture default_subtitle -%}Log in to {{ default.branding_name }} to view further information about this submission, add comments, and assign it to an administrator.{%- endcapture -%}
{%- assign assigned_subtitle = subtitle | default: default_subtitle -%}
{%- assign assigned_cta_label = cta_label | default: "View Submission" -%}
{%- capture default_cta_link -%}{{ platform_context.host }}/admin/insites#/databases/{{ form_record.items.results[0].table_id }}/items/{{ form.id }}{%- endcapture -%}
{%- assign assigned_cta_link = cta_link | default: default_cta_link -%}
{%- capture default_greeting -%}<strong>Submission Details</strong>{%- endcapture -%}
{%- assign assigned_greeting = greeting | default: default_greeting -%}
{%- if content != blank -%}
  {%- assign assigned_content = content -%}
{%- elsif content == blank and form_fields != blank -%}
  {%- capture test_parse -%}
    {%- parse_json value -%}{{ form_fields }}{%- endparse_json -%}
  {%- endcapture -%}
  {%- assign test_parse = test_parse | split: "ParseJsonTagError:" -%}
  {%- if test_parse[0] != "" -%}{%- assign fields = form_fields | parse_json -%}{%- endif -%}
  {%- capture assigned_cta_link -%}{{ platform_context.host }}/admin/insites#/databases/{{ database_id }}/items/{{ form.id }}{%- endcapture -%}
  {% function assigned_content = 'modules/insites_forms/email_notifications/test_content_data', fields: fields, data: data -%}
{%- else -%}
  {% function assigned_content = 'modules/insites_forms/email_notifications/content_data', form_data: form, form_name: "modules/ins_forms/contact_us" -%}
{%- endif -%}
<table class="module" role="module" data-type="code" border="0" cellpadding="0"
  cellspacing="0" width="100%" style="table-layout: fixed;"
  data-muid="52b13222-862e-4477-bb7c-c33655513549">
  <tbody>
    <tr>
      <td height="100%" valign="top" role="module-content">
        <table style="width:100%;background-color:#F7F7F7;" cellpadding="0"
          cellspacing="0" border="0">
          <tr style="width:100%;">
            <td
              style="padding:56px 0px 0px 0px;background:#FDFDFD;border-radius:8px 8px 0px 0px;">
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </tbody>
</table>
<table class="module" role="module" data-type="text" border="0" cellpadding="0"
  cellspacing="0" width="100%" style="table-layout: fixed;"
  data-muid="9a6f2278-aafa-434e-9a1f-1bb56840e20e" data-mc-module-version="2019-10-22">
  <tbody>
    <tr>
      <td style="padding:0px 40px 0px 40px; line-height:40px; text-align:inherit;"
        height="100%" valign="top" bgcolor="" role="module-content">
        <div>
          <div style="font-family: inherit; text-align: left"><span
              style="font-size: 32px; color: #0d0d0d; font-weight: 600">{{- assigned_title -}}</span></div>
          <div></div>
        </div>
      </td>
    </tr>
  </tbody>
</table>
{% include 'modules/insites_forms/email_notifications/spacer_table_body' %}
<table class="module" role="module" data-type="text" border="0" cellpadding="0"
  cellspacing="0" width="100%" style="table-layout: fixed;"
  data-muid="887789ce-ea31-48d2-abd4-462cea9ecab3.1" data-mc-module-version="2019-10-22">
  <tbody>
    <tr>
      <td style="padding:0px 40px 0px 40px; line-height:26px; text-align:inherit;"
        height="100%" valign="top" bgcolor="" role="module-content">
        <div>
           <div style="font-family: inherit; text-align: inherit"><span
            style="white-space-collapse: preserve; text-wrap: wrap">You received a new Contact us submission.</span></div>
            <div style="padding:0px 0px 32px 0px;"></div>
          <div style="font-family: inherit; text-align: inherit"><span
            style="white-space-collapse: preserve; text-wrap: wrap">{{- assigned_subtitle -}}</span></div>
          <div></div>
        </div>
      </td>
    </tr>
  </tbody>
</table>
{% include 'modules/insites_forms/email_notifications/spacer_table_body' %}
<table class="module" role="module" data-type="text" border="0" cellpadding="0"
  cellspacing="0" width="100%" style="table-layout: fixed;"
  data-muid="fa0dab93-144a-4b01-a832-59e0e2cf3d71" data-mc-module-version="2019-10-22">
  <tbody>
    <tr>
      <td style="padding:0px 40px 0px 40px; line-height:38px; text-align:inherit;"
        height="100%" valign="top" bgcolor="" role="module-content">
        <div>
          <div style="font-family: inherit; text-align: inherit"><span
              style="white-space-collapse: preserve; text-wrap: wrap; color: #0d0d0d; font-size: 24px; font-weight: 600">{{- assigned_greeting -}}</span></div>
          <div></div>
        </div>
      </td>
    </tr>
  </tbody>
</table>
{{ assigned_content | html_safe }}
{% include 'modules/insites_forms/email_notifications/spacer_table_body' %}
<table class="module" role="module" data-type="code" border="0" cellpadding="0"
  cellspacing="0" width="100%" style="table-layout: fixed;"
  data-muid="4645f9d0-c468-47a1-8ecb-557d3ba660bf">
  <tbody>
    <tr>
      <td height="100%" valign="top" role="module-content">
        <table style="width:100%;background:#FDFDFD;" cellpadding="0" cellspacing="0"
          border="0">
          <tr style="width:100%;">
            <td align="center"
              style="width:100%;border-radius:6px;padding:0px 40px;font-size:16px; text-align:center;">
              <table style="width:100%;background:#FDFDFD;" cellpadding="0"
                cellspacing="0" border="0">
                <tr style="width:100%;">
                  <td align="center"
                    style="width:100%;border-radius:6px;padding:0px 40px;font-size:16px; text-align:center; background-color:#3044FF">
                    <a href="{%- if content == blank and form_fields != blank -%}#{%- else -%}{{- assigned_cta_link -}}{%- endif -%}"
                      style="background-color:#3044FF; border:0px solid #3044FF; border-radius:4px; border-width:0px; color:#ffffff; display:inline-block; font-size:16px; font-weight:600; letter-spacing:0px; line-height:normal; padding:16px 0px 16px 0px; text-align:center; text-decoration:none; border-style:solid; font-family:inherit; width:100%;"
                      {% if content == blank and form_fields != blank %}{% else %}target="_blank"{% endif %}>{{- assigned_cta_label -}}</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </tbody>
</table>
{% include 'modules/insites_forms/email_notifications/spacer_table_body' %}
