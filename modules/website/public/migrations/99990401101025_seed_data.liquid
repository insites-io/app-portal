{%- comment -%} FAQS {%- endcomment -%}
{%- assign category = "FAQ Topic 1" -%}
{%- assign question = "Why use a client portal?" -%}
{%- assign slug = "why-use-a-client-portal" -%}
{%- assign answer = "A client portal is an online system that allows clients to securely access information from a company. It is generally used to provide clients with access to their data, such as invoices or contracts, as well as any resources or support materials the company may have." -%}
{%- assign sort_order = "1" -%}
{%- assign sub_title_topic_1 = "How do I update the colour style guide?" -%}
{%- assign sub_title_details_1 = "Select an element on your design. Select a color tile from the editor toolbar to bring up the color panel. Your brand color palettes should appear there. Select a color from the color palette to apply it to the element." -%}
{%- assign sub_title_topic_2 = "How do I update the button styles?" -%}
{%- assign sub_title_details_2 = "We have crafted the button style for you, you can change the button style in the Insites style guide and components pages for the developer guide. Also we have crafter the button variants for you!" -%}
{%- assign sub_title_topic_3 = "Can I change the components?" -%}
{%- assign sub_title_details_3 = "Update components. To make sure Figma applies changes to all instances of a component, you will need to edit the main component" -%}
{%- assign sub_title_topic_4 = "How do I restyle the web blocks?" -%}
{%- assign sub_title_details_4 = "Block styles work by adding a CSS class to the block and applying styles to the new selector. When you have selected a block style, you can open the Advanced section of the block settings sidebar and see that WordPress adds the class in the Additional CSS" -%}

{%- for i in (1..3) -%}
    {%- assign sort_order = i -%}
    {%- graphql create_faq_entry = "modules/website/faqs/create_faqs" 
        category: category,
        question: question,
        slug: slug,
        answer: answer,
        sort_order: sort_order,
        sub_title_topic_1: sub_title_topic_1,
        sub_title_details_1: sub_title_details_1,
        sub_title_topic_2: sub_title_topic_2,
        sub_title_details_2: sub_title_details_2,
        sub_title_topic_3: sub_title_topic_3,
        sub_title_details_3: sub_title_details_3,
        sub_title_topic_4: sub_title_topic_4,
        sub_title_details_4: sub_title_details_4
    -%}
{%- endfor -%}

