{% comment %} ? MENU {% endcomment %}
{% assign menu = '[
    {"label": "About us", "order": "0", "slug": "about", "show_in_menu": true},
    {"label": "Services", "order": "1", "slug": "services", "show_in_menu": true},
    {"label": "FAQ", "order": "2", "slug": "faqs", "show_in_menu": true},
    {"label": "News", "order": "3", "slug": "news", "show_in_menu": true},
    {"label": "Contact", "order": "", "slug": "contact", "show_in_menu": true}
]' | parse_json %}

{% for item in menu %}
    {%- graphql create_menu = "modules/website/menu/create_menu"
        label: {{item.label}},
        order: {{item.order}},
        slug: {{item.slug}}
    -%}
{% endfor %}

{%- graphql get_menu = 'modules/website/menu/get_parent_menu' | dig: 'items', 'results'-%}

{% comment %} ? SUB MENU - SERVICES {% endcomment %}
{% for sub_menu in get_menu %}
    {% if sub_menu.label == 'Services' %}
        {% parse_json sub_menu_services %}
        [
            {"label": "Customizable Style Guide", "order": "1", "slug": "customizable-style-guide"},
            {"label": "Web Block Variations", "order": "2", "slug": "web-block-variations"},
            {"label": "Web Components", "order": "3", "slug": "web-components"},
            {"label": "Content Types", "order": "4", "slug": "content-types"},
            {"label": "Fully Responsive", "order": "5", "slug": "fully-responsive"},
            {"label": "Pre Built Pages", "order": "6", "slug": "pre-built-pages"}
        ]
        {% endparse_json %}
    
        {% for item in sub_menu_services %}
            {%- graphql create_menu = "modules/website/menu/create_menu"
                label: {{item.label}},
                order: {{item.order}},
                slug: {{item.slug}},
                parent: {{sub_menu.id}}
            -%}
        {% endfor %}
    {% endif %}
{% endfor %}

