{%- comment -%} FAQS {%- endcomment -%}
{%- assign question = "This is sample question " -%}
{%- assign answer = "Lorem ipsum dolor sit amet consectetur adipisicing elit.
    Consequatur voluptatem pariatur inventore incidunt, 
    doloremque libero officia debitis dignissimos porro qui numquam placeat similique, 
    dolores aliquam ullam provident eveniet voluptates cupiditate." 
-%}

{%- for i in (1..3) -%}
    {%- assign question_appended = question | append: i -%}
    {%- assign faq_sort_order = i -%}
    {%- graphql create_faq_entry = "modules/website/create_faq" 
        question: question_appended,
        answer: answer
    -%}
{%- endfor -%}
