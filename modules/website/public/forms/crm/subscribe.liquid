---
name: subscribe
resource: modules/website/subscriptions
resource_owner: anyone
redirect_to: /subscribe-success
# spam_protection:
#    recaptcha_v2:
fields:
  properties:
    email:
      validation:
        email: 
          message: Please use a valid email address
        presence: 
          message: Please use a valid email address
callback_actions: >
    {%- include 'modules/insites_core/insites_create_crm_on_submit',
        email: form.properties.email,
        model_id: form.id -%}
---

{%- include 'modules/website/data/global_content' -%}
<div class="wrapper">
  <div class="grid-container" id="newsletter">
    <div class="spacer section"></div>
    <div class="grid-x grid-padding-x">
      <div class="large-5 medium-6 small-12 cell">
        <h2 class="font-h2">Stay up to date with {{ context.exports.global.company_name }}</h2>
        <div class="spacer"></div>
        <p>Subscribe to our newsletter for the latest news and product updates straight to your inbox.</p>
        <div class="spacer large show-for-small-only"></div>
      </div>


      <div class="large-6 large-offset-1 medium-6 small-12 cell">
        {%- comment -%}
        To add 'html element properties' on pOS form, prepend 'html-<property>'
        ie. html-class, html-id, etc..
        {%- endcomment -%}
        {%- form 
 html-id: "subscribe-form"
 html-onSubmit: "return validateForm(event)"
 html-novalidate: true -%}

          <div class="grid-x grid-padding-x">
            <div class="grid-y cell large-10">
              <div class="cell">
                <ins-input
                  validate
                  field="email"
                  class="auto cell subscribe-component"
                  data-test="subscribe-form-field-email"
                  name="{{ form.fields.properties.email.name }}"
                  placeholder="Enter email address"
                  error-message="{{ form.fields.properties.email.validation.rules.email.message }}"></ins-input>
              </div>
              <div class="cell">
                {%- comment -%} IF your form / instance have recaptcha enabled, uncommment this code {%- endcomment -%}
                {% comment %} <div
                  id="recaptcha-v2-wrapper"
                  class="large-6 medium-6 small-12 cell form-field-wrapper"
                  data-test="subscribe-recaptcha-container">
                  {% spam_protection "recaptcha_v2" %}
                  <div class="ins-form-error"></div>
                </div> {% endcomment %}
                <div class="spacer small"></div>
              </div>
            </div>
            <div class="cell large-1">
              <ins-button
                id="submit-btn"
                class="shrink cell text-right subscribe-component"
                data-test="subscribe-form-button-submit"
                solid
                color="blue"
                label="SUBSCRIBE"
                type="submit"></ins-button>
            </div>

          </div>
        {%- endform -%}
      </div>

    </div>

    <div class="spacer section"></div>
  </div>
</div>

<script>
  let submitBtn = document.getElementById('submit-btn');
  let form = document.getElementById('subscribe-form');

  async function validateForm(event) {
    event.preventDefault();
    submitBtn.loading = true;

    let captcha = form.querySelectorAll("#recaptcha-v2-wrapper").length == 1
      ? App.validation.checkRecaptcha()
      : true;

    if (await App.validation.validateForm(form) && captcha) {
      form.submit();
      return true;
    } else {
      submitBtn.loading = false;
      return false;
    }
  }
</script>