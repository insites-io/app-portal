---
metadata: {
    layout_name: website_default_dark
}
---
{%- comment -%} Used by the fragment cache in the layout {%- endcomment -%}
    {%- include "modules/website/cache/layout_fragment_cache_key" -%}

<!doctype html>
<html class="no-js" lang="en">
<head>
    {%- if context.page.slug == '/' or context.page.slug == '' -%}
        <link rel="preload" as="image" href="{{ 'modules/website/images/home/hero-banner-d.webp' | asset_url }}" fetchpriority="high" media="(min-width: 640px)">
        <link rel="preload" as="image" href="{{ 'modules/website/images/home/hero-banner-m.webp' | asset_url }}" fetchpriority="high" media="(max-width: 639px)">
    {%- endif -%}
    {%- capture head_key -%} {{ context.exports.layout_cache_key.cache_key | append: "-head" }} {%- endcapture -%}
    {%- cache head_key -%}
        {% include 'modules/website/layout/head' %}
    {%- endcache -%}
</head>
<body>
    <div class="main-wrap">
        {% comment %} ? Ecommerce promo banner strip — above the header, kept outside the header cache {% endcomment %}
        {% if context.constants.ecommerce_addon == 'true' %}
            {% include 'modules/ecommerce/banners/promo_banner' %}
        {% endif %}

        {%- capture header -%} {{ context.current_user.id }}-{{ context.exports.layout_cache_key.cache_key }}-header {%- endcapture -%}
        {% cache header %}
            {% include 'modules/website/layout/header', dark: true %}
        {% endcache %}

        {%- capture header-mobile -%} {{ context.current_user.id }}-{{ context.exports.layout_cache_key.cache_key }}-header-mobile {%- endcapture -%}
        {% cache header-mobile %}
            {% include 'modules/website/layout/header_mobile' %}
        {% endcache %}

        {{ content_for_layout }}

        {% comment %} ? For ecommerce cart drawer + promotional popup {% endcomment %}
        {% if context.constants.ecommerce_addon == 'true' %}
            {% include 'modules/ecommerce/carts/cart_drawer' %}            
            {% include 'modules/ecommerce/popups/promo_popup' %}
        {% endif %}
    </div>
    
    {%- capture foot_key -%} {{ context.exports.layout_cache_key.cache_key | append: "-footer_section"}} {%- endcapture -%}
    {%- cache foot_key -%} 
        {% include 'modules/website/layout/footer' %}
    {%- endcache -%}


</body>
</html>