---
metadata: {
    partial_name: 'Website | Forms | Contact Event Steam'
}
---
{% assign props = form.properties %}
{% assign phone = form.properties.mobile_phone %}
{% assign parts = phone | split: ' ' %}
{% assign area_code = parts[0] | remove: '+'  %}
{% assign phone_number = parts[1] %}

{%- parse_json new_user_data -%}
{
    "email": "{{ form.properties.email }}",
    "first_name": "{{ form.properties.first_name }}",
    "last_name": "{{ form.properties.last_name }}",
    "mobile_phone_country_code": "{{ area_code | strip | replace: '"', '' }}",
    "mobile_phone_number": "{{ phone_number | strip | replace: '"', '' }}"
}
{%- endparse_json -%}
{% comment %} NOTE: Create CRM -> Contact via Controller {% endcomment %}
{% function add_contact = "crm/controller/contacts/create", params: new_user_data %}

{%- graphql get_contact_us_data = "modules/portal/contact_us/get_contact_us_data", id: form.id | dig: "items", "results" | first -%}
{%- graphql get_table_data = "modules/website/get_table_info", table_name: "modules/website/contact_us" | dig: "admin_model_schemas", "results" | first -%}

{% comment %} Create Event Stream {% endcomment %}
{%- graphql user = "modules/portal/account/get_user_by_email" 
email: form.properties.email 
| dig: "items" | dig: "results" | first -%}
{%- assign crm_contact = user.crm_contact | first -%}
{%- assign current_user_name = user.first_name | append: ' ' | append: user.last_name | default: user.email -%}
{%- capture description -%}
    <a target="_blank" href="/admin/insites/#/crm/contacts/{{ user.id }}">{{ current_user_name| default: user.email }}</a> 
    sent an <a href="https://{{context.location.host}}/admin/insites#/databases/{{ get_table_data.id }}/items/{{ form.id }}/view">enquiry</a>
{%- endcapture -%}

{%- assign payload = '{}' | parse_json -%}
{%- assign payload = payload | add_hash_key: "description", description -%}
{%- assign payload = payload | add_hash_key: "font_icon", "icon-message-square" -%}
{%- assign payload = payload | add_hash_key: "font_icon_color", "#E1B000" -%}
{%- assign payload = payload | add_hash_key: "administrator_uuid", user.uuid  -%}

{% capture log_info -%}
    {
        "action": "contact_us",
        "data": {
            "items": { 
                "contact": {
                    "id": "{{ user.id }}",
                    "email": "{{ user.email }}",
                    "first_name": "{{ user.first_name }}",
                    "last_name": "{{ user.last_name }}"
                },
                "inquiry": {
                    "message": "{{ form.properties.message |  default: "" }}",
                    "attachment": "{{ get_contact_us_data.document.url |  default: "" }}"
                },
                "contact_uuid": "{{ user.uuid }}"
            }
        }
    }
{%- endcapture %}

{%- assign log_info_json = log_info | parse_json -%}
{%- assign info = payload | add_hash_key: "log", log_info_json -%}
{% include 'modules/portal/events/log_event', info %}
 