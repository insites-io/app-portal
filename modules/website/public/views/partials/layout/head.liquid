---
metadata: {
    partial_name: 'Website | Layout | Head'
}
---

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, height=device-height, initial-scale=1.0, viewport-fit=cover">
<meta content="authenticity_token" name="csrf-param">
<meta content="{{ context.authenticity_token }}" name="csrf-token">
<meta http-equiv="X-UA-Compatible" content="ie=edge">

<!-- Preconnect to critical origins for LCP and network dependency (fonts in google-fonts/insites-assets, CDN) -->
<link rel="preconnect" href="https://components.insites.io" crossorigin>
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
{%- assign _acdn = 'modules/website/styles/vendor/foundation.min.css' | asset_url | split: '/' -%}
{%- assign _acdn_origin = _acdn[0] | append: '//' | append: _acdn[2] -%}
<link rel="preconnect" href="{{ _acdn_origin }}">
<link rel="dns-prefetch" href="{{ _acdn_origin }}">

<!-- Critical CSS: inlined to allow default.css to load async without FOUC -->
<style>
:root{font-size:16px;--color-main:#3044FF;--color-sub1:#8C1EE3;--color-sub2:#E3361E;--color-bg1:#05051D;--color-main-hover:#3044FF;--color-sub1-hover:#7E16D0;--color-sub2-hover:#D32F19;--color-main-hover-light:rgba(48,68,255,0.06);--color-sub1-hover-light:rgba(126,22,208,0.1);--color-sub2-hover-light:rgba(211,47,25,0.1);--font-color-link-hovered:#FFFFFF99;--success:#0CAC52;--error:#F24B4B;--warning:#FFA639;--info:#436CF2;--neutral:#84848F;--success-hover:#2B8D6F;--error-hover:#D83333;--warning-hover:#CC8700;--info-hover:#2331B7;--neutral-hover:#636368;--success-hover-light:rgba(55,182,143,0.1);--error-hover-light:rgba(255,51,102,0.1);--warning-hover-light:rgba(255,166,57,0.1);--info-hover-light:rgba(67,108,242,0.1);--neutral-hover-light:rgba(132,132,143,0.1);--font-color-head:#05051D;--font-color-sub:#323232;--font-color-body:#575757;--font-color-link:#ffffff;--font-color-visited:#670099;--font-color-inv:#FFFFFF;--color-ui-01:#FFFFFF;--color-ui-02:#F9FAFB;--color-ui-03:#F3F4F4;--color-ui-04:#DFDFDF;--color-ui-05:#84848F;--color-ui-06:#575757;--color-ui-07:#436CF2;--color-ui-08:#000000;--color-gradiant1:linear-gradient(90deg,#1E4AA2 0%,#1B78CC 100%);--color-gradiant2:linear-gradient(90deg,#8C1EE3 0%,#C71EE3 100%);--color-gradiant3:linear-gradient(90deg,#E3351E 0%,#F07B26 100%);--font-family-01:'DM Sans',sans-serif;--font-family-02:'Archivo',sans-serif;--font-family-03:'Cabin',sans-serif;--font-huge:4.5rem;--font-xxxx-large:3rem;--font-xxx-large:2.5rem;--font-xx-large:2rem;--font-x-large:1.5rem;--font-large:1.125rem;--font-medium:1rem;--font-small:0.875rem;--font-x-small:0.75rem;--font-xx-small:0.625rem;--gutter:12px;--gutter-medium:20px;--container-max-width:1440px;--container-max-width-half:616px;--container-padding-xx-large:48px;--container-padding-x-large:48px;--container-padding-large:48px;--container-padding-medium:32px;--container-padding-small:24px}
body{background-color:var(--color-ui-01)}
body,p,.body-paragraph{font-family:var(--font-family-02,"Archivo");font-size:16px;font-style:normal;font-weight:400;line-height:150%}
body,header,footer{padding-left:env(safe-area-inset-left);padding-right:env(safe-area-inset-right)}
.gutter-medium.grid-padding-x>.cell{padding-left:var(--gutter-medium);padding-right:var(--gutter-medium)}
.gutter-medium.grid-padding-y>.cell{padding-top:var(--gutter-medium);padding-bottom:var(--gutter-medium)}
.grid-container:not(.full) .grid-padding-x.gutter-medium{margin-right:calc(-1 * var(--gutter-medium));margin-left:calc(-1 * var(--gutter-medium))}
.grid-container:not(.full) .grid-padding-y.gutter-medium{margin-top:calc(-1 * var(--gutter-medium));margin-bottom:calc(-1 * var(--gutter-medium))}
.bg-color-ui-01{background-color:var(--color-ui-01)}
.bg-color-ui-02{background-color:var(--color-ui-02)}
.logo-accounts{width:auto!important;max-height:35px!important}
.portal-wrap{min-height:initial}
.sidebar-padding{padding:80px 24px 80px 48px!important}
.main-content{padding:80px 48px 80px 24px}
.layout-background{background-image:url("{{ 'modules/website/images/login-bg.webp' | asset_url }}");background-repeat:no-repeat;background-size:cover}
.account-body{height:calc(100vh)}
.account-container-logo{padding:0px 128px}
.account-container{padding:0px 128px;align-content:center;height:calc(70vh)}
.create-account-container{padding:0px 40px 0px 128px}
</style>

{% liquid
    include 'modules/insites_cms/seo'
    include 'modules/website/layout/technical-head/google-fonts'
    include 'modules/website/layout/technical-head/favicons'
    include 'modules/website/layout/technical-head/msapplication'
    include 'modules/website/layout/technical-head/vendor-assets'
    include 'modules/website/layout/technical-head/insites-assets'
    include 'modules/website/layout/project_assets'
    include 'modules/website/layout/pixel_tracking'
%}


