{%- if context.environment == "staging" -%}
<!-- start partial:layout/header  -->
{%- endif -%}

<header class="navigation-04 header" data-test="main-header" id="main-header">
  <div class="wrapper">
    <div class="header-top-bar grid-container grid-x align-middle">
      <div class="large-2 medium-3 small-9 cell">
        <a href="/">
          <img class="logo" src="{{ 'modules/website/images/ins-logo.png' | asset_url }} " alt="logo" />
        </a>
      </div>
      <div class="show-for-large large-10 medium-6 small-12 cell text-right">
        <div class="header-links">
          <a class="color-main color-font-head" href="/about-us">
            About us
          </a>
          <a class="color-main color-font-head" href="/services">
          <ins-dropdown 
          label="Services"
          class="customNav">
            {% comment %} connect services to graphql {% endcomment %}
            {%- graphql get_services = 'modules/website/content/get_services' -%}
            {% comment %} assign var to fetch the result {% endcomment %}
            {%- assign res_services = get_services | dig: 'items', 'results' -%}
            
            {% for item in res_services %}
              <ins-dropdown-item
                link="/services/{{ item.slug }}"
                label="{{ item.service_name }}">
              </ins-dropdown-item>
            {% endfor %} 
        </ins-dropdown>
          </a>
          <a class="color-main color-font-head" href="/faqs">
            FAQ
          </a>
          <a class="color-main color-font-head" href="/news">
            News
          </a> 
          <a class="color-main color-font-head" href="/contact-us"> 
            Contact
          </a>
          
          {% if context.current_user == nil %}
            <a href="/sign-in"> 
              Sign in
            </a>
            <a href="/register"> 
              <ins-button class="hide-for-small-only" href="/register" solid label="Register">
              </ins-button>
            </a>
          {% else %} 
            <a class="color-main color-font-head" href=""> 
              <ins-dropdown 
              label="{{ context.current_user.first_name }} {{ context.current_user.last_name }}"
              class="profileNav">
                  <ins-dropdown-item
                    link=""
                    label="My Details">
                  </ins-dropdown-item>

                  <ins-dropdown-item
                    link=""
                    label="Change Password">
                  </ins-dropdown-item>

                  <ins-dropdown-item
                    link=""
                    label="">
                    {% include_form 'modules/client/sign_out' %}
                  </ins-dropdown-item>
              </ins-dropdown>
            </a>
          {% endif %}

        </div>  
      </div>
      
      <div  class="hide-for-large mobile-menu-toggle large-0 medium-6 small-3 cell vertical-align-middle align-right">
        <div id="mobile-menu-btn" class="icon-menu-1"></div>
      </div>
    </div>
  </div>
</header>




{%- if context.environment == "staging" -%}
<!-- end partial:layout/header  -->
{%- endif -%}

