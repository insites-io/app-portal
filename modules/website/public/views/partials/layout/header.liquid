---
metadata: {
    partial_name: 'Website | Layout | Header'
}
---

{% comment %} ? GET GLOBAL CONTENT {% endcomment %}
{%- include "modules/insites_cms/globals" -%}
{%- assign global = context.exports.global -%}

<header  id="main-header" 
  {% if dark == blank %} class="light-header {%  if border == true %} border-bottom-nav  {% endif %}" {% else %} class="no-light-header" {% endif %}
  
  >
  <div id="mainHeaderWrapper" class="wrapper">
    <div class=" grid-container grid-x align-middle">
      <div class="large-1 medium-3 small-7 cell">
        <a href="/">
          {% comment %} ? SETTING LOGO BY DEFAULT {% endcomment %}
          {% if global.company_logo == nil or global.company_logo contains "client-logo.png" %}
              {% comment %} ? DEFAULT {% endcomment %}
              <img class="logo" src="{{ 'modules/website/images/default-images/logo/insites-logo.png' | asset_url }}" alt="Logo" height="56" width="119">
          {% else %}
              {% comment %} ? FETCHED FROM IIA -> CMS -> GLOBALS {% endcomment %}
              {% if dark == blank %} 
                  <img class="logo" src="{{ global.company_logo }}" alt="Logo" height="56" width="119">
                {% else %}
                  <img class="logo" src="{{ global.alternate_company_logo }}" alt="Logo" height="56" width="119">
              {% endif %}
          {% endif %}
        </a>
      </div>

      {%- assign menus = '[]' | parse_json -%}
      {%- graphql get_menu = 'modules/website/menu/get_parent_menu' | dig: 'items', 'results'-%}

      {% assign menu_data = get_menu | parse_json %}
    
      {% for menu_item in menu_data %}
        {%- assign parent = '{}' | parse_json -%}
        {%- assign parent = parent | add_hash_key: "label", menu_item.label -%}
        {%- assign parent = parent | add_hash_key: "slug", menu_item.slug -%}

        {%- graphql get_child_menu = 'modules/website/menu/get_child_menu', parent_id: menu_item.id | dig: 'items', 'results' -%}
        {%- assign parent = parent | add_hash_key: "child", get_child_menu -%}
        {%- assign menus = menus | add_to_array: parent -%}
      {% endfor %}

      {%- graphql get_features = 'modules/website/features/get_features' -%}
      {%- assign features =  get_features | dig: 'items', 'results'  -%}

      <div class="large-11 medium-3 small-8 cell hide-nav-medium">
          <div class="navlinks">

            {% if context.constants.ecommerce_addon == 'true' %}
              <ins-button id="mega-menu-btn" label="Shop" icon-right="icon-angle-down"></ins-button>
            {% endif %}

            {% for menu in menus %}
              {%- if menu.slug == "features" -%}
                <a class="nav-dropdown-link" href="/{{menu.slug}}">
                <ins-dropdown 
                  label="{{menu.label}}"
                  >
                    {% for item in features %}
                      <ins-dropdown-item
                        link="/{{menu.slug}}/{{ item.slug }}"
                        label="{{ item.card_title }}">
                      </ins-dropdown-item>
                    {% endfor %} 
                </ins-dropdown>
              </a>
              {% else %}
    
              <a href="/{{menu.slug}}">
                {{menu.label}}
              </a>
              {% endif %}
            {% endfor %}
            <a class="nav-sign-in-btn" href="/sign-in">Sign in</a>
            <a class="nav-register-btn" href="">Create account</a>

          </div>
      </div>

      <div class="mobile-menu-toggle large-0 medium-3 small-5 cell ">
        {% if context.current_user == blank %}
          <a class="nav-sign-in-btn" href="/sign-in">Sign in</a>
        {% endif %}
        <div id="mobile-menu-btn" class="icon-menu-1"></div>
      </div>

      
    </div>
  </div>
</header>

{% if context.constants.ecommerce_addon == 'true' %}
  {% include 'modules/ecommerce/menu/mega_menu' %}
{% endif %}

{% if context.constants.ecommerce_addon == 'true' %}
  <script src="{{ 'modules/ecommerce/scripts/mega_menu_close.js' | asset_url }}"></script>
<script>
  const guestUserEl = document.getElementById('guest-user-flag'); 

  if (guestUserEl && window.localStorage) {
    const guestUserFlag = guestUserEl.value

    if (guestUserFlag === 'true') {
      // Get Cart Count from LocalStorage
      const guest_cart = localStorage.getItem('carts');

      if (guest_cart) {
        const parsedCart = JSON.parse(guest_cart);
        const cartCount = parsedCart.length;

        // Update the cart count dynamically in the HTML
        const cartCountElement = document.getElementById('cart-count');
        if (cartCountElement) {
          cartCountElement.innerHTML = cartCount; // Update the displayed cart count
          if (cartCount === 0) {
            cartCountElement.classList.add('hide'); // Apply the 'zero-cart-count' class if empty
          } else {
            cartCountElement.classList.remove('hide'); // Remove the class if cart has items
          }
        }
      }
    } 
  }  
</script>
{% endif %}