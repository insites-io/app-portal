---
metadata: {
    partial_name: 'Website | Layout | Footer'
}
---

{% comment %} ? GET GLOBAL CONTENT {% endcomment %}
{%- include "modules/insites_cms/globals" -%}
{%- assign global = context.exports.global -%}

{% comment %} NOTE: Set Global Content if empty {% endcomment %}
{% if global.company_logo == nil or global.company_logo contains "client-logo.png" %}
    {% assign company_logo = 'modules/website/images/ins-marketplace.png' | asset_url %}
{% else %}
    {% assign company_logo = global.company_logo %}
{% endif %}

{% assign has_any_global_link = false %}
{% if global.facebook_link != '' and global.facebook_link != null or global.twitter_link != '' and global.twitter_link != null or global.linkedin_link != '' and global.linkedin_link != null or global.instagram_link != '' and global.instagram_link != null or global.pinterest_link != '' and global.pinterest_link != null or global.other_1_link != '' and global.other_1_link != null or global.other_2_link != '' and global.other_2_link != null or global.youtube_link != '' and global.youtube_link != null %}
    {% assign has_any_global_link = true %}
{% endif %}

{% if has_any_global_link %}
    {% assign facebook_link = global.facebook_link | default: '' %}
    {% assign twitter_link = global.twitter_link | default: '' %}
    {% assign linkedin_link = global.linkedin_link | default: '' %}
    {% assign instagram_link = global.instagram_link | default: '' %}
    {% assign pinterest_link = global.pinterest_link | default: '' %}
    {% assign other_1_link = global.other_1_link | default: '' %}
    {% assign other_2_link = global.other_2_link | default: '' %}
    {% assign youtube_link = global.youtube_link | default: '' %}
{% else %}
    {% assign facebook_link = 'https://www.facebook.com/insites.io' %}
    {% assign twitter_link = 'https://www.twitter.com/insites.io' %}
    {% assign linkedin_link = 'https://www.linkedin.com/insites.io' %}
    {% assign instagram_link = 'https://www.instagram.com/insites.io' %}
    {% assign pinterest_link = 'https://www.pinterest.com/insites.io' %}
    {% assign other_1_link = 'https://www.insites.io' %}
    {% assign other_2_link = 'https://www.insites.io' %}
    {% assign youtube_link = 'https://www.youtube.com/insites.io' %}
{% endif %}

<hr>
<footer class="blocks-footer-05 footer bg-color-ui-01">
    <div class="spacer xxxx-large"></div>
    <div class="wrapper top-footer footerSubItems">
        <div class="grid-container">
            
            <div class="footer-links-wrap">

                <!-- LOGO FOOTER -->
                <div class="">
                    <div class="img-logo img-full">
                        <a href="/">
                            <img class="logo logo-footer" src="{{ company_logo }}" alt="{{ global.company_name }}" height="56" width="119">
                        </a>
                    </div>
                </div>

                <!-- QUICK LINKS -->
                <div class="wrap right-group">
                    <div class="spacer x-large show-for-small-only"></div>
                    <nav aria-labelledby="footer-nav-quicklinks">
                    <h3 id="footer-nav-quicklinks" class="footer-link-main-label" data-test="">Quick links</h3>
                    <div class="spacer"></div>
                    <ul class="vertical menu">
                        <li class="">
                            <a class="footer-links color-font-head" data-test="" href="/about-us">About us</a>
                        </li>
                        {% if context.constants.locator_addon == 'true' %}
                        <li>
                            <a class="footer-links color-font-head" data-test="" href="#">Find a partner</a>
                        </li>
                        {% endif %}
                        <li>
                            <a class="footer-links color-font-head" data-test="" href="/faqs">FAQ</a>
                        </li>
                        <li>
                            <a class="footer-links color-font-head" data-test="" href="/news">News</a>
                        </li>
                        <li>
                            <a class="footer-links color-font-head" data-test="" href="/contact-us">Contact</a>
                        </li>
                    </ul>
                    </nav>
                </div>

                {% comment %} Events Addon {% endcomment %}
                {% if context.constants.events_addon == 'true' %}
                    <div class="wrap">
                        <div class="spacer x-large show-for-small-only"></div>
                        <nav aria-labelledby="footer-nav-events">
                        <h3 id="footer-nav-events" class="footer-link-main-label">Events</h3>
                        <div class="spacer"></div>
                        <ul class="vertical menu">
                            <li class="">
                                <a class="footer-links color-font-head" href="/upcoming-events">Upcoming events</a>
                            </li>
                            <li>
                                <a class="footer-links color-font-head" href="/previous-events">Previous events</a>
                            </li>
                        </ul>
                        </nav>
                    </div>
                {% endif %}
    
                <!-- FEATURES -->
                <div class="wrap">
                    <div class="spacer x-large show-for-small-only"></div>

                    {%- graphql get_features = 'modules/website/features/get_features' -%}
                    {%- assign features =  get_features | dig: 'items', 'results'  -%}

                    <nav aria-labelledby="footer-nav-features">
                    <h3 id="footer-nav-features" class="footer-link-main-label" data-test="">Features</h3>
                    <div class="spacer"></div>
                    <ul class="vertical menu">
                        {% for item in features %}
                        <li>
                            <a href="/features/{{ item.slug }}" class="footer-links color-font-head" data-test="">{{ item.card_title }}</a>
                        </li>
                        {% endfor %}
                    </ul>
                    </nav>
                </div>

                <!-- EXTERNAL LINKS -->
                <div class="wrap">
                    <div class="spacer x-large show-for-small-only"></div>
                    
                    <nav aria-labelledby="footer-nav-external">
                    <h3 id="footer-nav-external" class="footer-link-main-label" data-test="">External links</h3>
                    <div class="spacer"></div>
                    <ul class="vertical menu">
                    <li>
                        <a href="https://www.insites.io/" target="_blank" rel="noopener noreferrer" class="footer-links color-font-head" data-test="" aria-label="Website (opens in new tab)">
                        <span>Website</span>
                        <i class="icon-external-link1" aria-hidden="true"></i>
                        </a>
                    </li>
                    <li>
                        <a href="https://console.insites.io/" target="_blank" rel="noopener noreferrer" class="footer-links color-font-head" data-test="" aria-label="Console (opens in new tab)">
                        <span>Console</span>
                        <i class="icon-external-link1" aria-hidden="true"></i>
                        </a>
                    </li>
                    <li>
                        <a href="https://docs.insites.io/" target="_blank" rel="noopener noreferrer" class="footer-links color-font-head" data-test="" aria-label="Resources (opens in new tab)">
                        <span>Resources</span>
                        <i class="icon-external-link1" aria-hidden="true"></i>
                        </a>
                    </li>
                    </ul>
                    </nav>
                </div>

            </div>
        </div>
    </div>

    <div class="spacer xxxx-large show-for-medium"></div>
    <div class="spacer x-large hide-for-medium"></div>
    <div class="wrapper bottom-footer footerSubItems" >
        <div class="grid-container">
            <hr>
            <div class="spacer"></div>
            <div class="grid-x align-justify">
                <div class="large-6 medium-6 small-12 cell grid-x grid-margin-x">
                    <div class="medium-shrink cell">
                        <a href="/privacy-policy" class="footer-links">Privacy policy</a>
                    </div>
                    <div class="cell spacer show-for-small-only"></div>
                    <div class="medium-shrink cell">
                        <a href="/terms-and-conditions"  class="footer-links">Terms and conditions</a>
                    </div>
                </div>
                <div class="cell spacer show-for-small-only"></div>
                <div class="large-6 medium-6 small-12 cell">
                    <div>
                    <ul class="menu social">
                        {% if facebook_link != '' %}<li><a class="footer-links iconHover" href="{{ facebook_link }}" data-test="footer-link-facebook" target="_blank" rel="noopener noreferrer" aria-label="{{ global.company_name }} on Facebook (opens in new tab)"><i class="icon-facebook-square" aria-hidden="true"></i></a></li>{% endif %}
                        {% if twitter_link != '' %}<li><a class="footer-links iconHover" href="{{ twitter_link }}" data-test="" target="_blank" rel="noopener noreferrer" aria-label="{{ global.company_name }} on X / Twitter (opens in new tab)"><i class="icon-social-x-square" aria-hidden="true"></i></a></li>{% endif %}
                        {% if linkedin_link != '' %}<li><a class="footer-links iconHover" href="{{ linkedin_link }}" data-test="" target="_blank" rel="noopener noreferrer" aria-label="{{ global.company_name }} on LinkedIn (opens in new tab)"><i class="icon-linkedin" aria-hidden="true"></i></a></li>{% endif %}
                        {% if instagram_link != '' %}<li><a class="footer-links iconHover" href="{{ instagram_link }}" data-test="" target="_blank" rel="noopener noreferrer" aria-label="{{ global.company_name }} on Instagram (opens in new tab)"><i class="icon-instagram-square" aria-hidden="true"></i></a></li>{% endif %}
                        {% if youtube_link != '' %}<li><a class="footer-links iconHover" href="{{ youtube_link }}" data-test="" target="_blank" rel="noopener noreferrer" aria-label="{{ global.company_name }} on YouTube (opens in new tab)"><i class="icon-youtube-square" aria-hidden="true"></i></a></li>{% endif %}
                        {% if pinterest_link != '' %}<li><a class="footer-links iconHover" href="{{ pinterest_link }}" data-test="" target="_blank" rel="noopener noreferrer" aria-label="{{ global.company_name }} on Pinterest (opens in new tab)"><i class="icon-pinterest-square" aria-hidden="true"></i></a></li>{% endif %}
                        {% if other_1_link != '' %}<li><a class="footer-links iconHover" href="{{ other_1_link }}" data-test="" target="_blank" rel="noopener noreferrer" aria-label="{{ global.company_name }} — additional link (opens in new tab)"><i class="icon-share-2" aria-hidden="true"></i></a></li>{% endif %}
                        {% if other_2_link != '' %}<li><a class="footer-links iconHover" href="{{ other_2_link }}" data-test="" target="_blank" rel="noopener noreferrer" aria-label="{{ global.company_name }} — additional link (opens in new tab)"><i class="icon-share-2" aria-hidden="true"></i></a></li>{% endif %}
                    </ul>
                    </div>
                </div>
            </div>
            <div class="spacer"></div>
            <div class="grid-x">
                <div class="large-6 medium-6 small-12 cell medium-text-left text-center">
                    <p class="subHeading footer-p">Copyright © <span id="year-container"></span> {{ global.company_name  }} </p>
                </div>
                <div class="small-12 cell spacer show-for-small-only"></div>
                <div class="large-6 medium-6 small-12 cell medium-text-right text-center">
                    <p class="subHeading footer-p"> Powered by <a class="footer-links" target="_blank" rel="noopener noreferrer" href="https://www.insites.io/" aria-label="Insites (opens in new tab)">Insites</a>.</p>
                </div>
            </div>
        </div>
    </div>
    <div class="spacer"></div>
</footer>

<script>
    document.getElementById("year-container").innerHTML = new Date().getFullYear();
</script>

{%- comment -%}
Technical footer:
Contains all the scripts imported right before the </body> tag
{%- endcomment -%}
{%- include 'modules/website/layout/technical_foot' -%}
