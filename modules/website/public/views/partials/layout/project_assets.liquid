---
metadata: {
    partial_name: 'Website | Layout | Project assets'
}
---

{%- comment -%}
Project Assets - Holds app css and js
{%- endcomment -%}

{%- if context.environment == "staging" -%}
    <link rel="preload" as="style" href="{{ 'modules/website/styles/default.css' | asset_url }}" >
    <link rel="stylesheet" href="{{ 'modules/website/styles/default.css' | asset_url }}" >
    {% comment %} <link rel="preload" as="style" href="{{ 'modules/website/styles/custom.css' | asset_url }}" >
    <link rel="stylesheet" href="{{ 'modules/website/styles/custom.css' | asset_url }}" > {% endcomment %}
    {% comment %} <link rel="preload" as="style" href="{{ 'modules/website/styles/breakpoint.css' | asset_url }}" >
    <link rel="stylesheet" href="{{ 'modules/website/styles/breakpoint.css' | asset_url }}" > {% endcomment %}
{%- else -%}
    {%- comment -%} Minified version will be used in the production environment {%- endcomment -%}
    <link rel="preload" as="style" href="{{ 'modules/website/styles/default.min.css' | asset_url }}" >
    <link rel="stylesheet" href="{{ 'modules/website/styles/default.min.css' | asset_url }}" >
    {% comment %} <link rel="preload" as="style" href="{{ 'modules/website/styles/breakpoint.min.css' | asset_url }}" >
    <link rel="stylesheet" href="{{ 'modules/website/styles/breakpoint.min.css' | asset_url }}" > {% endcomment %}
{%- endif -%}

{% if context.constants.ecommerce_addon == 'true' %}
    {%- if context.environment == "staging" -%}
        <link rel="preload" as="style" href="{{ 'modules/ecommerce/styles/ecommerce.css' | asset_url }}" onload="this.onload=null;this.rel='stylesheet'">
        <noscript><link rel="stylesheet" href="{{ 'modules/ecommerce/styles/ecommerce.css' | asset_url }}"></noscript>
    {%- else -%}
        <link rel="preload" as="style" href="{{ 'modules/ecommerce/styles/ecommerce.min.css' | asset_url }}" onload="this.onload=null;this.rel='stylesheet'">
        <noscript><link rel="stylesheet" href="{{ 'modules/ecommerce/styles/ecommerce.min.css' | asset_url }}"></noscript>
    {%- endif -%}
    {%- comment -%} Critical CSS for the promo banner strip. ecommerce.css is async-loaded
        (preload+onload swap above), so the banner (rendered above the header in
        website_default) would paint unstyled until it applies. These rules live in
        <head> so the strip paints correctly on first paint — no flash, no layout
        shift. Tokens resolve from the render-blocking default.css. Kept here (head)
        rather than inline in the partial because <style> is invalid in <body> (W3C). {%- endcomment -%}
    <style>
        .promo-banner { position: relative; display: flex; align-items: center; justify-content: center; gap: 10px; padding: 16px 48px; background: var(--color-sub1-hover); color: var(--font-color-inv); font-family: var(--font-family-02); font-size: 16px; line-height: 1.5; text-align: center; }
        .promo-banner__viewport { display: flex; align-items: center; justify-content: center; }
        .promo-banner__slide { display: none; align-items: center; justify-content: center; gap: 8px; }
        .promo-banner__slide.is-active { display: flex; }
        .promo-banner__link { color: var(--font-color-inv); font-weight: 600; text-decoration: underline; }
        .promo-banner__close { position: absolute; right: 24px; top: 50%; transform: translateY(-50%); display: inline-flex; align-items: center; margin: 0; padding: 4px; border: 0; background: none; color: var(--font-color-inv); font-size: 18px; line-height: 1; cursor: pointer; }
        @media screen and (max-width: 639px) { .promo-banner { padding: 12px 40px; font-size: 14px; } .promo-banner__slide { flex-wrap: wrap; } .promo-banner__close { right: 12px; } }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js" defer></script>
    <script src="{{ 'modules/ecommerce/services/apiServices.min.js' | asset_url }}" defer></script>
{%- endif -%}

{% if context.constants.events_addon == 'true' %}
    {%- if context.environment == "staging" -%}
        <link rel="preload" as="style" href="{{ 'modules/events/styles/events.css' | asset_url }}" onload="this.onload=null;this.rel='stylesheet'">
        <noscript><link rel="stylesheet" href="{{ 'modules/events/styles/events.css' | asset_url }}"></noscript>
    {%- else -%}
        <link rel="preload" as="style" href="{{ 'modules/events/styles/events.min.css' | asset_url }}" onload="this.onload=null;this.rel='stylesheet'">
        <noscript><link rel="stylesheet" href="{{ 'modules/events/styles/events.min.css' | asset_url }}"></noscript>
    {%- endif -%}
{%- endif -%}

{% if context.constants.locator_addon == 'true' %}
    {%- if context.environment == "staging" -%}
        <link rel="preload" as="style" href="{{ 'modules/locator/styles/locator.css' | asset_url }}" onload="this.onload=null;this.rel='stylesheet'">
        <noscript><link rel="stylesheet" href="{{ 'modules/locator/styles/locator.css' | asset_url }}"></noscript>
        <script src="{{ 'modules/locator/scripts/locator.js' | asset_url }}" defer></script>
    {%- else -%}
        <link rel="preload" as="style" href="{{ 'modules/locator/styles/locator.min.css' | asset_url }}" onload="this.onload=null;this.rel='stylesheet'">
        <noscript><link rel="stylesheet" href="{{ 'modules/locator/styles/locator.min.css' | asset_url }}"></noscript>
        <script src="{{ 'modules/locator/scripts/locator.min.js' | asset_url }}" defer></script>
    {%- endif -%}
{%- endif -%}