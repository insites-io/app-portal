---
metadata: {
    partial_name: 'Website | Layout | Project assets'
}
---

{%- comment -%}
Project Assets - Holds app css and js
{%- endcomment -%}

{%- if context.environment == "staging" -%}
    <link rel="preload" as="style" href="{{ 'modules/website/styles/default.css' | asset_url }}" >
    <link rel="stylesheet" href="{{ 'modules/website/styles/default.css' | asset_url }}" > 
    {% comment %} <link rel="preload" as="style" href="{{ 'modules/website/styles/custom.css' | asset_url }}" >
    <link rel="stylesheet" href="{{ 'modules/website/styles/custom.css' | asset_url }}" > {% endcomment %}
    {% comment %} <link rel="preload" as="style" href="{{ 'modules/website/styles/breakpoint.css' | asset_url }}" >
    <link rel="stylesheet" href="{{ 'modules/website/styles/breakpoint.css' | asset_url }}" > {% endcomment %}
{%- else -%}
    {%- comment -%} Minified version will be used in the production environment {%- endcomment -%}
    <link rel="preload" as="style" href="{{ 'modules/website/styles/default.min.css' | asset_url }}" >
    <link rel="stylesheet" href="{{ 'modules/website/styles/default.min.css' | asset_url }}" >
    {% comment %} <link rel="preload" as="style" href="{{ 'modules/website/styles/breakpoint.min.css' | asset_url }}" >
    <link rel="stylesheet" href="{{ 'modules/website/styles/breakpoint.min.css' | asset_url }}" > {% endcomment %}
{%- endif -%}

{% if context.constants.ecommerce_addon == 'true' %}
    {%- if context.environment == "staging" -%}
        <link rel="stylesheet" href="{{ 'modules/ecommerce/styles/ecommerce.css' | asset_url }}" >
    {%- else -%}
        <link rel="stylesheet" href="{{ 'modules/ecommerce/styles/ecommerce.min.css' | asset_url }}" >
    {%- endif -%}

    {%- if context.params.slug2 -%}

        {%- if slug_type == 'product' -%}
            <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
            {%- if context.environment == "staging" -%}
                <script src="{{ 'modules/ecommerce/services/apiServices.js' | asset_url }}"></script>
                <script src="{{ 'modules/ecommerce/scripts/product-detail.js' | asset_url }}"></script>
            {%- else -%}
                <script src="{{ 'modules/ecommerce/services/apiServices.min.js' | asset_url }}"></script>
                <script src="{{ 'modules/ecommerce/scripts/product-detail.min.js' | asset_url }}"></script>
            {%- endif -%}
        {%- else -%}
        <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
            {%- if context.environment == "staging" -%}
                <script src="{{ 'modules/ecommerce/services/apiServices.js' | asset_url }}"></script>
            {%- else -%}
                <script src="{{ 'modules/ecommerce/services/apiServices.min.js' | asset_url }}"></script>
            {%- endif -%}
        {%- endif -%}
    
    {%- else -%}
        <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
        {%- if context.environment == "staging" -%}
            <script src="{{ 'modules/ecommerce/services/apiServices.js' | asset_url }}"></script>
        {%- else -%}
            <script src="{{ 'modules/ecommerce/services/apiServices.min.js' | asset_url }}"></script>
        {%- endif -%}
    {%- endif -%}
{%- endif -%}