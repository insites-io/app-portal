{% liquid
    assign key = ""
    graphql google_key = 'modules/website/system/get_google_api'

    assign google_key_first = google_key.items.results | first
%}
    {%- if context.environment == "staging" -%}
        {% comment %} Insert code for staging Google key {% endcomment %}
        {%- if google_key.items.results.size > 0 -%}
            {%- assign key = google_key_first.value -%}
        {%- endif -%}
    {%- else -%}
        {% comment %} Insert code for production Google key {% endcomment %}
        {%- if google_key.items.results.size > 0 -%}
            {%- assign key = google_key_first.value -%}
        {%- endif -%}
    {%- endif -%}
    
    <!-- Google Maps API -->
    <link rel="preload" as="script" href="//maps.googleapis.com/maps/api/js?key={{key}}&libraries=places&v=3.exp" >
    <script src="//maps.googleapis.com/maps/api/js?key={{key}}&libraries=places&v=3.exp"></script>
