---
metadata: {
    partial_name: 'Cache | Layout Fragment Cache Key'
}
---
{%- parse_json models -%}
    [
        "modules/insites_site_manager/insites_global_content",
        "modules/website/main_menu",
        "modules/insites_core/insites_system_fields",
        "modules/website/header",
        "modules/website/feedback",
        "modules/website/news",
        "modules/website/menu",
        "modules/website/faqs"
    ]
{%- endparse_json -%}

{% if context.constants.ecommerce_addon == 'true' %}
    {%  assign models = models | array_add: 'modules/insites_ecommerce/cart' %}
    {%  assign models = models | array_add: 'modules/insites_ecommerce/cart_item' %}
{% endif %}

{% liquid
    capture cache_key 
        include "modules/website/cache/generate_cache_key", models: models 
    endcapture

    export cache_key, namespace: 'layout_cache_key'
 %}