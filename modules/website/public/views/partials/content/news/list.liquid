---
metadata: {
    page_slug: "news",
    page_title: "News",
    layout: "list"
}
---
{% comment %} ? THIS IS TO SET DEFAULT VALUES FOR NEWS IMAGE {% endcomment %}
{% comment %} ? THIS BLOCK OF CODE UNDER THIS COMMENT CAN BE DELETED ONCE IMAGES ON NEWS DATABASE IS POPULATED BY THE USER{% endcomment %}
{% parse_json news_list %}
[
    {
        "image": "{{ 'modules/website/images/default-images/news/news_1.jpg' | asset_url }}",
        "slug": "the-beginners-guide-to-website-development"
    },
    {
        "image": "{{ 'modules/website/images/default-images/news/news_2.jpg' | asset_url }}",
        "slug": "advantages-of-working-remotely"
    },
    {
        "image": "{{ 'modules/website/images/default-images/news/news_3.jpg' | asset_url }}",
        "slug": "how-to-reach-customers-everywhere-with-mobile-seo"
    },
    {
        "image": "{{ 'modules/website/images/default-images/news/news_4.jpg' | asset_url }}",
        "slug": "elevate-your-brand-with-expert-design"
    },
    {
        "image": "{{ 'modules/website/images/default-images/news/news_5.jpg' | asset_url }}",
        "slug": "design-as-storytelling-crafting-narratives-through-visuals"
    },
    {
        "image": "{{ 'modules/website/images/default-images/news/news_6.jpg' | asset_url }}",
        "slug": "8-mobile-ux-best-practices-every-designer-should-consider"
    }
]
{% endparse_json %}
{% comment %} ? DELETE UNTIL THIS LINE OF CODE ONCE NEWS DATABASE IS POPULATED {% endcomment %}

{%  liquid         
    assign page_num = context.params.page | default: 1 | plus: 0
    assign per_page = context.params.per_page | default: 6 | plus: 0
    assign keyword = context.params.search | default: ""
    assign tag = context.params.tag | default: ""
    assign sort =  context.params.sort | default: "DESC"
    assign field = "" | default: "published_date" 
    if sort == "A-Z"
        assign field = "title" 
        assign sort = "ASC"
    endif

    if sort == "Z-A"
        assign field = "title" 
        assign sort = "DESC"
    endif

    if tag == "All"
        assign tag = ""
    endif

%}

{%- graphql get_news = 'modules/website/news/get_news', page: page_num, size: per_page, keyword: keyword, tag: tag, sort: sort, field: field -%}
{%- assign res_news = get_news | dig: 'items', 'results' -%}

{% assign description = "Stay updated with the latest news, insights, and updates. Explore articles on industry trends, company announcements, and expert opinions—all in one place." %}
{% include 'modules/website/content/hero_title', description: description %} 

<div class="wrapper">
    <div class="news-filter-container">
        <div class="grid-container">
            <div class="grid-x gutter-medium grid-padding-x grid-padding-y">
                <div class="large-8 medium-12 small-12 cell filter-container-cell">
                    <ins-filter id="news-filter">
                        <ins-filter-item
                            name="Tag"
                            options='["All", "Design","SEO", "Technology", "Web development"]'
                            selected="{{ context.params.tag }}">
                        </ins-filter-item>
                        <ins-filter-item
                            name="Sort by"
                            options='["Newest First", "Oldest first", "Alphabetical (A-Z)","Alphabetical (Z-A)"]'
                            {% liquid 
                                if context.params.sort == "DESC"
                                    assign sort_val = "Newest First"
                                endif

                                if context.params.sort == "ASC"
                                    assign sort_val  = "Oldest first"
                                endif

                                if context.params.sort == 'A-Z'
                                    assign sort_val = "Alphabetical (A-Z)"
                                endif

                                if context.params.sort == 'Z-A'
                                    assign sort_val = "Alphabetical (Z-A)" 
                                endif             
                            %}
                            selected="{{ sort_val }}">
                        </ins-filter-item>
                    </ins-filter>
                </div>
                <div class="large-4 medium-12 small-12 cell search-container-cell">
                    <div class="">
                        <ins-input                 
                            id="search-input"
                            class="search-award search-bars"
                            placeholder="Search news"
                            icon-event
                            icon="icon-search-1"
                            error-message="Search Keyword cannot be blank"
                            value="{{ context.params.search }}">
                        </ins-input>
                    </div>
                </div>

            </div>
        </div>
    </div>
    <div class="spacer xxxx-large"></div>

{% if get_news.items.total_entries == 0 %}
    <div class="grid-container">
        <div class="grid-x align-center">
            {% if context.params.search != blank %}
                <p class="subHeading">No results found for keyword "<strong>{{ keyword  }}</strong>"</p>
            {% else %}
                <p class="subHeading">No results found</p>    
            {% endif %}
        </div>
    </div>
{% endif %}

    <div class="grid-container">     
        <section class="news-content">
            <div class="team-list grid-x gutter-medium grid-padding-x grid-padding-y">
                {% for item in res_news %}
                    <div class="large-4 medium-6 small-12 cell news-cards">
                        <a href="/news/{{ item.slug }}" class="news-main-link-container">
                            <div class="card"> 
                                <div class="newsImageContainer">
                                    {% if item.list_view_image.url %}
                                        <img width="500" height="500" alt="image" src="{{ item.list_view_image.url }}">
                                    {% else %}
                                        {% comment %} ? SETTING DEFAULT IMAGE {% endcomment %}
                                        {% for news in news_list %}
                                            {% if item.slug == news.slug %}
                                                <img width="500" height="500" alt="image" src="{{ news.image }}">
                                            {% endif %}
                                        {% endfor %}
                                    {% endif %}
                                </div>
                                <div class="spacer large"></div>
                                <div class="news-author">
                                    {%- graphql get_author = 'modules/website/news/get_author', external_id: item.author -%}
                                    {%- assign get_author = get_author | dig: 'items', 'results' | first -%}
                                    {% if item.author != blank %}
                                        <p class="newsSubheading">Published on {{ item.published_date | date: "%b %d, %Y" }} by {{ get_author.first_name }} {{ get_author.last_name }}</p>
                                    {% else %}
                                        <p class="newsSubheading">Published on {{ item.published_date | date: "%b %d, %Y" }} by Mark Webber</p>
                                    {% endif %}                  
                                </div>
                                <div class="newsContentContainer">
                                    <div class="news-content">
                                        <div class="spacer x-small"></div>
                                            <div class="newsTitle">
                                                <h5>{{ item.title }}</h5>
                                            </div>
                                        <div class="spacer x-small"></div>
                                        <div class="description">
                                            <p class="subHeading p-two-line">{{ item.list_view_text }}</p>
                                        </div>
                                        <div class="tagButton">
                                            <ins-tag 
                                                label="{{ item.tag }}" 
                                                icon="icon-star" 
                                                class="news-tag"
                                                {% if item.tag == 'Web Development'%}
                                                    color="green"
                                                {% endif %}
                                                {% if item.tag == 'SEO'%}
                                                    color="red"
                                                {% endif %}
                                                {% if item.tag == 'Design'%}
                                                    color="blue"
                                                {% endif %}
                                                >
                                            </ins-tag>
                                        </div> 
                                    </div>
                                    <div class="news-link">
                                        <i class="icon-arrow-up-right"></i> 
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                {% endfor %}	
            </div>
        </section>
        
        <div class="spacer xxxx-large"></div>
        <ins-table no-wrap
        static-table
        id="insBaseTable"
        without-search>    
        </ins-table>
    </div>
</div>

<div class="spacer xxxx-large"></div>

<script>


    var insBaseTable = document.getElementById('insBaseTable');

    insBaseTable.pageSizeOptions = [6,15,30];
    insBaseTable.totalCount = {{ get_news.items.total_entries }};
    insBaseTable.pageNumber = {{page_num}};
    insBaseTable.pageSize = {{per_page}};
    
    if(insBaseTable){
        setTimeout(() => {
            insBaseTable.querySelector(".ibt-table-wrap__pagination>span").innerHTML='Items per page';
        },600);            
    }
    
    insBaseTable.addEventListener('insPaginationChange', tablePaginationHandler);

    function processTableData(){

        // Get the current URL
        const currentUrl = window.location.href;

        // Remove any existing `page` and `per_page` query parameters
        const newUrl = currentUrl.replace(/[?&]page=\d+/, '').replace(/[?&]per_page=\d+/, '');

        // Set the new `page` and `per_page` values
        const newPage = pageNumber;
        const newPerPage = pageSize;

        // Append the new `page` and `per_page` query parameters to the URL
        const updatedUrl = `${newUrl}?page=${newPage}&per_page=${newPerPage}`;

        // Navigate to the updated URL
        window.location.href = updatedUrl;
    }

    function tablePaginationHandler(event){
        pageSize = event.detail.pageSize;
        pageNumber = event.detail.pageNumber;
        processTableData()
    }

    // Search functionality
    var searchKey = document.getElementById('search-input');

    function goToSearch() {
        var empty = checkIfEmpty(searchKey.value);
        if (!empty) {
            // Get current URL
            var currentUrl = new URL(window.location.href);
            
            // Add or update the 'search' parameter
            currentUrl.searchParams.set('search', searchKey.value);
            
            // Navigate to the updated URL
            window.location.href = currentUrl.toString();
        }
    }

    function checkIfEmpty(searchString) {
        if (searchString === "") {
            searchKey.setAttribute("has-error", "");
            return true;
        } else {
            searchKey.removeAttribute("has-error");
            return false;
        }
    }

    searchKey.addEventListener('insIconClick', goToSearch);

    searchKey.addEventListener('insInput', e => {
        if (e.detail.keyCode === 13) goToSearch();
    });

    searchKey.addEventListener('insValueChange', e => {
        checkIfEmpty(searchKey.value);
    });

    //filter function
    let filterEl = document.getElementById('news-filter');

    filterEl.addEventListener('insFilterApply', (event) => {
        console.log(event);
        
        var currentUrl = new URL(window.location.href);

        // Handling the 'tag' parameter
        var tag = event.detail.Tag;
        if (tag) {
            if (tag === 'all') {
                // If the tag is 'all', clear the 'tag' parameter
                currentUrl.searchParams.delete('tag');
            } else {
                // Otherwise, add or update the 'tag' parameter
                currentUrl.searchParams.set('tag', tag);
            }
        }

        // Handling the 'sort' parameter
        var sortObj = event.detail;
        var sort = sortObj["Sort by"];
        if (sort) {
            if (sort === 'Newest First') {
                sort = "DESC";
            } else if (sort === "Oldest first") {
                sort = "ASC";
            } else if (sort === "Alphabetical (A-Z)") {
                sort = "A-Z";
            } else {
                sort = "Z-A";
            }
            // Add or update the 'sort' parameter
            currentUrl.searchParams.set('sort', sort);
        }

        // Now navigate to the updated URL (after both 'tag' and 'sort' have been updated)
        window.location.href = currentUrl.toString();
    });
</script>

