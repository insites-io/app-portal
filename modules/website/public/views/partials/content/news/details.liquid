---
metadata: {
    page_slug: "news",
    slug: "{{ context.exports.data.item.slug }}",
    page_title: "News | {{ context.exports.data.item.title }}",
    layout: "details"
}
---
{% comment %} ? THIS IS TO SET DEFAULT VALUES FOR NEWS IMAGE {% endcomment %}
{% comment %} ? THIS BLOCK OF CODE CAN BE DELETED ONCE IMAGES ON NEWS DATABASE IS POPULATED BY THE USER{% endcomment %}
{% parse_json news_details %}
[
    {
        "image": "{{ 'modules/website/images/default-images/news/news_details_1.jpg' | asset_url }}",
        "slug": "the-beginners-guide-to-website-development"
    },
    {
        "image": "{{ 'modules/website/images/default-images/news/news_details_2.jpg' | asset_url }}",
        "slug": "advantages-of-working-remotely"
    },
    {
        "image": "{{ 'modules/website/images/default-images/news/news_details_3.jpg' | asset_url }}",
        "slug": "how-to-reach-customers-everywhere-with-mobile-seo"
    },
    {
        "image": "{{ 'modules/website/images/default-images/news/news_details_4.jpg' | asset_url }}",
        "slug": "grow-your-brand-with-custom-merch"
    },
    {
        "image": "{{ 'modules/website/images/default-images/news/news_details_5.jpg' | asset_url }}",
        "slug": "charging-for-gated-content-on-your-website"
    },
    {
        "image": "{{ 'modules/website/images/default-images/news/news_details_6.jpg' | asset_url }}",
        "slug": "8-mobile-ux-best-practices-every-designer-should-consider"
    }
]
{% endparse_json %}
{% comment %} ? DELETE UNTIL THIS LINE OF CODE ONCE NEWS DATABASE IS POPULATED {% endcomment %}

{% if context.exports.data.item.status != "Published" %}
    <script>
      window.location.href = "{{ '/404' }}"
    </script>
{% endif %}

<section class="newsDetailsSection">
  <div class="grid-container">
    <div class="spacer xxxx-large"></div>
    <a href="/news"><span class="news-back-btn colorBlack"> <b> <i class="icon-angle-left"></i> BACK TO NEWS LIST </b> </span></a>
    <div class="spacer xx-large"></div>
    
    <div class="tagButton">
      <ins-tag 
        label="{{ context.exports.data.item.tag }}" 
        icon="icon-tag" 
        color="blue"
        light=false>
      </ins-tag>
    </div>
      
    <div class="spacer small"></div>
    <h1 class="title">{{ context.exports.data.item.title }}</h1>
    <div class="spacer small"></div>
   
    <h4 class="news-title-detail">PUBLISHED ON {{ context.exports.data.item.published_date | date: "%b %d, %Y" }} By {{ context.exports.data.item.author }}</h4>
    <div class="spacer x-large"></div>
    
    {% comment %} ? BANNER {% endcomment %}
    {% if context.exports.data.item.main_image.url %}
      <img loading="lazy" alt="image" src="{{ context.exports.data.item.main_image.url }} "/>
    {% else %}
        {% comment %} ? SETTING DEFAULT IMAGE {% endcomment %}
        {% for news in news_details %}
            {% if context.exports.data.item.slug == news.slug %}
                <img loading="lazy" alt="image" src="{{ news.image }}"/>
            {% endif %}
        {% endfor %}
    {% endif %}
    
    <div class="spacer xxxx-large"></div>

    <div class="newsDetailHolder subHeading">
      <div class="grid-container">
        {{ context.exports.data.item.content }}    
      </div>
    </div>
    <div class="spacer section"></div>
  </div>
</section>