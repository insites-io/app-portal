---
metadata: {
    partial_name: 'Website | FAQs | Side nav'
}
---
<div class="large-3 medium-3 small-12 cell faq-side-nav">
    <div class="wrapper">
        <div class="faq-sidenav">
            {% for item in res_faq %}
                {% if params.slug2 == item.slug %}
                    <ins-accordion-link class="set-active" label="{{ item.question }}" icon="" link="/faqs/{{ item.slug }}" link-target="_self" active> </ins-accordion-link>
                {% else %}
                    <ins-accordion-link class="" label="{{ item.question }}" icon="" link="/faqs/{{ item.slug }}" link-target="_self" active> </ins-accordion-link>
                {% endif %}    
            {% endfor %}
        </div>
    <div class="spacer section show-for-medium"></div>  
    </div>
</div>