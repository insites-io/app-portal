---
# enable_profiler: true
metadata: {
    "label": 'faqs-sidenav'
}
---
<div class="large-3 medium-3 small-12 cell" style="background-color: #F9FAFB;">
  <div class="blocks-sc-2col-08 wrapper">
  <div class="spacer section"></div>  
  <div class="faqSidenav">
	
    {% if context.location.href != '/faqs' %}
        <ins-accordion-link class="" label="FAQ Overview" link="/faqs" open-icon="none" close-icon="none" link-target="_self" active> </ins-accordion-link>
    {% else %}
    	<ins-accordion-link class="setActive" label="FAQ Overview" link="/faqs" open-icon="none" close-icon="none" link-target="_self" active> </ins-accordion-link>
    {% endif %}

    {% for item in res_faq %}
        {% if params.slug2 == item.slug %}
            <ins-accordion-link class="setActive" label="{{ item.question }}" icon="" link="/faqs/{{ item.slug }}" link-target="_self" active> </ins-accordion-link>
   
        {% else %}
            <ins-accordion-link class="" label="{{ item.question }}" icon="" link="/faqs/{{ item.slug }}" link-target="_self" active> </ins-accordion-link>
        {% endif %}    
    {% endfor %}


  </div>
  <div class="spacer section"></div>  
  </div>
</div>