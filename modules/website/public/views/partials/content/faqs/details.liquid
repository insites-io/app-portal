---
metadata: {
    page_slug: "faqs",
    slug: "{{ context.exports.data.item.slug }}",
    page_title: "FAQs | {{ context.exports.data.item.question }}",
    layout: "details"
}
---
{% if context.params.slug2 != context.exports.data.item.slug %}
    {%- redirect_to '/404' -%}
{% endif %}

{% comment %} connect services to graphql {% endcomment %}
{%- graphql get_faq = 'modules/website/faqs/get_faqs' -%}
{% comment %} assign var to fetch the result {% endcomment %}
{%- assign res_faq = get_faq | dig: 'items', 'results' -%}

{% assign get_category = get_faq | dig: 'items', 'results' %}
{% assign get_category = get_category | map: "category" | uniq %}
{% assign description = "Check out the answers to your questions about our portal and how it all works!" %}
{% include 'modules/website/content/hero_title', description: description %} 

<div class="wrapper sideNavBg">
    <div class="spacer section"></div>
    <div class="grid-container">
            <div class="grid-container">
                <div class="blocks-sc-2col-07 wrapper bg-color-ui-01">
                    <div class="grid-container">
                        <div class="grid-x grid-padding-x gutter-medium">
                            
                        {%- include 'modules/website/content/faqs/faqs_sidenav' -%}
                        <div class="large-9 medium-9 small-12 cell">
                            <div class="grid-container">
                              <h4>{{ context.exports.data.item.question }}</h4>
                                        <div class="spacer"></div>
                                        <p class="subHeading">{{ context.exports.data.item.answer }}</p>
                                        <div class="spacer xx-large"></div>
                                            <!-- MAIN VIEW -->
                                            <div id="faqs_accordion" class="blocks-sc-2col-07 wrapper bg-color-ui-01">
                                                <div class="grid-container">
                                                    <div class="large-12 medium-12 small-12">
                                                        <div class="faq-content-questions">
                                                            <ins-accordion class="subHeading"> 
                                                                {% if context.exports.data.item.sub_topic_title_1 != nil and context.exports.data.item.sub_topic_details_1 != nil %}
                                                                <ins-accordion-item   
                                                                open-icon="icon-plus"
                                                                close-icon="icon-minus"
                                                                heading="{{ context.exports.data.item.sub_topic_title_1 }}">
                                                                    {{ context.exports.data.item.sub_topic_details_1 }}
                                                                </ins-accordion-item>  
                                                                {% endif %}   
                                                                
                                                                {% if context.exports.data.item.sub_topic_title_2 != nil and context.exports.data.item.sub_topic_details_2 != nil %}
                                                                <ins-accordion-item 
                                                                open-icon="icon-plus"
                                                                close-icon="icon-minus" 
                                                                heading="{{ context.exports.data.item.sub_topic_title_2 }}">
                                                                    {{ context.exports.data.item.sub_topic_details_2 }}
                                                                </ins-accordion-item>  
                                                                {% endif %}   
                                                                
                                                                {% if context.exports.data.item.sub_topic_title_3 != nil and context.exports.data.item.sub_topic_details_3 != nil %}
                                                                <ins-accordion-item 
                                                                open-icon="icon-plus"
                                                                close-icon="icon-minus"
                                                                heading="{{ context.exports.data.item.sub_topic_title_3 }}">
                                                                    {{ context.exports.data.item.sub_topic_details_3 }}
                                                                </ins-accordion-item>  
                                                                {% endif %}  

                                                                {% if context.exports.data.item.sub_topic_title_4 != nil and context.exports.data.item.sub_topic_details_4 != nil %}
                                                                <ins-accordion-item 
                                                                open-icon="icon-plus"
                                                                close-icon="icon-minus"
                                                                heading="{{ context.exports.data.item.sub_topic_title_4 }}">
                                                                    {{ context.exports.data.item.sub_topic_details_4 }}
                                                                </ins-accordion-item>  
                                                                {% endif %}               
                                                            </ins-accordion>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                              <div class="spacer xxxx-large"></div>  
                            </div>        
                        </div>
                    </div>
                </div>
            </div>
    </div>
</div>

