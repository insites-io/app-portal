{%- graphql get_testimonials = 'modules/website/home/get_testimonials' -%}
{%- assign res_testimonial = get_testimonials | dig: 'items', 'results' -%}

<section class="section-testimonials">
    <div class="blocks-hero-01 homepage-banner-wrap">
        <ins-carousel no-carousel-button loop layout="1" bind-to="homepage-banner-testimonials" transition="700" duration="5000"
          data-test="homepage-slider">
          <div id="homepage-banner-testimonials">
            {% for item in res_testimonial %}
            <!-- item -->
            <div class="slide-container">
              <div class="img-wrap">
              </div>
  
              <div class="slide-content wrapper vertical-align-middle">
                <div class="grid-x">
                  <div class="large-12 medium-12 small-12 cell colorWhite">
                    <h2 class="testiLabel">TESTIMONIALS</h2>
                    <div class="spacer"></div>
                    <p class="testiMessage">{{  item.message  }}</p>
                    <div class="spacer"></div>
                    <p class="testiName">{{ item.full_name }}</p>
                    <div class="spacer x-small"></div>
                    <p class="testiLoc"> {{ item.location }}</p>
                  </div>
                </div>
              </div>
            </div>
            <!-- /item -->
          {% endfor %}
          </div>
        </ins-carousel>
    </div>
</section>