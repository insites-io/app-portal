---
metadata: {
    partial_name: "Website | Index | Feedback",
}
---

{%- graphql get_feedback = 'modules/website/home/get_feedback' -%}
{%- assign res_feedback = get_feedback | dig: 'items', 'results' -%}

<div class="feedback-section">
  <div class="homepagepage-feedback-wrap">
      <ins-carousel no-carousel-button loop layout="1" bind-to="homepage-banner-feedback" transition="700" duration="5000"
        data-test="homepage-slider">
        <div id="homepage-banner-feedback">
          {% for item in res_feedback %}
          <!-- item -->
          <div class="slide-container">
            <div class="slide-content vertical-align-middle">
                <h2 class="testiLabel">What our clients say</h2>
                <div class="spacer"></div>
                <p class="testiMessage">{{  item.message  }}</p>
                <div class="spacer xxxx-large"></div>
                <p class="testiName">{{ item.full_name }}</p>
                <div class="spacer x-small"></div>
                <p class="testiPos"> {{ item.location }}</p>
            </div>
          </div>
          <!-- /item -->
        {% endfor %}
        </div>
      </ins-carousel>
  </div>
  <div class="feedback-image">
    <img width="1000" height="800" src="{{ 'modules/website/images/home/feedback/feedback-bg.webp' | asset_url  }}" alt="Feedback image">
  </div>
</div>