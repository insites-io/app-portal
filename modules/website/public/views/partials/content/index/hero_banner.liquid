<style>
#banner-dynamic-word {
 display: inline-block;
  position: relative;
  height: 1em;
  overflow: hidden;
  vertical-align: baseline; /* changed from bottom */
  line-height: inherit; /* matches surrounding text */
  top: 5px;
  left: 8px
}

#banner-dynamic-word .word {
  display: block;
  height: 1em;
  font-weight: bold;
  background: linear-gradient(135deg, #88FF6C 0%, #3F93FF 96.83%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  /* position: absolute; */
  left: 0;
  width: 100%;
  transition: transform 0.4s ease-in-out;
}

#banner-dynamic-word .current {
  top: 0;
  transform: translateY(0);
}

#banner-dynamic-word .next {
  top: 100%;
  transform: translateY(0);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const words = ['clients', 'members', 'users', 'customers'];
  let index = 0;

  const wordWrapper = document.getElementById('banner-dynamic-word');
  const currentWord = wordWrapper.querySelector('.current');
  const nextWord = wordWrapper.querySelector('.next');

  function rollWords() {
    index = (index + 1) % words.length;
    nextWord.textContent = words[index];

    // Animate scroll up
    currentWord.style.transform = 'translateY(-100%)';
    nextWord.style.transform = 'translateY(-100%)';

    // After animation, reset positions
    setTimeout(() => {
      currentWord.textContent = words[index];

      // Reset transforms instantly
      currentWord.style.transition = 'none';
      nextWord.style.transition = 'none';
      currentWord.style.transform = 'translateY(0)';
      nextWord.style.transform = 'translateY(0)';

      // Force reflow
      void currentWord.offsetWidth;

      // Reapply transitions
      currentWord.style.transition = 'transform 0.4s ease-in-out';
      nextWord.style.transition = 'transform 0.4s ease-in-out';
    }, 400);
  }

  setInterval(rollWords, 2000);
});
</script>