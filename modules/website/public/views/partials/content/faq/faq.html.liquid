<section class="section-1">
    <div class="blocks-sc-2col-08 wrapper bg-color-ui-01">
    <div class="spacer xxxx-large"></div>
    <div class="grid-container">
        <div class="grid-x gutter grid-padding-x gutter-medium">
            <div class="large-3 medium-3 small-12 cell">
                <ul class="side-links">
                    <li>
                        <a>FAQ Overview</a>
                        <div class="spacer small"></div>
                    </li>
                    {% for item in res_faq %}
                        <li>
                            <a>{{ item.question }}</a>
                            <div class="spacer small"></div>
                        </li>                        
                    {% endfor %}
                </ul>
            </div>
            <div class="spacer xxx-large small-12 cell show-for-small-only"></div>
            <div class="large-9 medium-9 small-12 cell">
                <h1>FAQ Overview</h1>
                <div class="spacer large"></div>

                {% for item in res_faq %}
                    <div class="articles-container">
                        <div class="custom-article-item">
                            <div>
                                <h3>{{ item.question }}</h3>
                            </div>
                            <div class="spacer x-small"></div>
                            <div class="custom-publish-info"><a>LEARN MORE <i class="icon-angle-right"></i></a></div>
                        </div>
                    </div>
                    <div class="spacer"></div>
                {% endfor %}


                <div class="spacer xxxx-large"></div>
                <h1>Policies</h1>
                <div class="spacer large"></div>
                <div class="articles-container">
                    <div class="custom-article-item">
                        <div>
                            <h3>Privacy Policy</h3>
                        </div>
                        <div class="spacer x-small"></div>
                        <div class="custom-publish-info"><a href="/privacy-policy" target="_blank"> LEARN MORE <i class="icon-angle-right"></i> </a></div>
                    </div>
                    <div class="spacer"></div>
                    <div class="custom-article-item">
                        <div>
                            <h3>Terms & Conditions</h3>
                        </div>
                        <div class="spacer x-small"></div>
                        <div class="custom-publish-info"><a href="/terms-and-conditions" target="_blank"> LEARN MORE <i class="icon-angle-right"></i> </a></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="spacer xxxx-large"></div>
</div>

</section>