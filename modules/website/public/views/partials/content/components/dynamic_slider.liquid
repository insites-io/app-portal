{% assign record = data | dig: 'items' %} 
{%- assign data = data | dig: 'items', 'results' -%}

<div class="dynamic-slider">
    <div class="wrapper">
        <div class="grid-container grid-x">
            <div class="dynamic-slider-buttons">
                <i class="icon-arrow-left prev"  id="prevButton" style="display:none;"></i>
                <i class="icon-arrow-right next" id="nextButton" ></i>
            </div>
        
            <div class="slider-container">
                <div class="slider-track">
                    {% for item in data %}
                        <div class="slider-item">
                            <img src="{{ item.icon.url }}" alt="">
                            <h6>{{ item.business_title }}</h6>
                            <p>{{ item.business_description }}</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
    <div class="spacer large"></div>
</div>


<script>
document.addEventListener('DOMContentLoaded', function () {
  let currentIndex = 0; 
  const sliderTrack = document.querySelector('.slider-track');
  const items = document.querySelectorAll('.slider-item');
  const totalItems = items.length;
  const prevButton = document.querySelector('#prevButton');
  const nextButton = document.querySelector('#nextButton');
  const sliderContainer = document.querySelector('.slider-container');
  let containerWidth = sliderContainer.offsetWidth;
  let itemToShow = 4; 

  function updateButtonsVisibility() {
    if (totalItems <= itemToShow) {
      nextButton.style.display = 'none';
    } else {
      if (currentIndex < totalItems - itemToShow) {
        nextButton.style.display = 'inline-block';
      } else {
        nextButton.style.display = 'none';
      }
    }

    if (currentIndex === 0) {
      prevButton.style.display = 'none';
    } else {
      prevButton.style.display = 'inline-block';
    }
  }

  function nextSlide() {
    if (currentIndex < totalItems - itemToShow) {
      currentIndex++;
      updateSliderPosition();
      updateButtonsVisibility();
    }
  }

  function prevSlide() {
    if (currentIndex > 0) {
      currentIndex--;
      updateSliderPosition();
      updateButtonsVisibility();
    }
  }

  function updateItemWidth() {
    const visibleItems = itemToShow;
    const gap = 2; 
    const paddingLeft = 10; 
    const paddingRight = 10; 

    const itemWidth = (containerWidth - paddingLeft - paddingRight - (visibleItems - 1) * (gap / 100) * containerWidth) / visibleItems;

    items.forEach(item => {
        item.style.flex = `0 0 ${itemWidth}px`;
    });

    sliderTrack.style.gap = `${gap}%`;
  }

  function updateSliderPosition() {
    const visibleItems = itemToShow; 
    const gap = 3; 
    const itemWidth = (containerWidth - (visibleItems - 1) * (gap / 100) * containerWidth) / visibleItems;
    const slideWidth = itemWidth + (gap / 100) * containerWidth;

    let offset = currentIndex * slideWidth;

    if (currentIndex === totalItems - visibleItems) {
      offset = (totalItems - visibleItems) * slideWidth;
    }

    sliderTrack.style.transform = `translateX(-${offset}px)`;
  }

  window.addEventListener('resize', () => {
    containerWidth = sliderContainer.offsetWidth; 
    if (containerWidth <= 639) {
      itemToShow = 1; 
    } else if (containerWidth <= 930) {
      itemToShow = 2; 
    } else if (containerWidth <= 1299) {
      itemToShow = 3; 
    } else {
      itemToShow = 4; 
    }
    updateItemWidth(); 
    updateSliderPosition(); 
    updateButtonsVisibility(); 
  });

  updateButtonsVisibility();
  updateItemWidth();
  updateSliderPosition();

  nextButton.addEventListener('click', nextSlide);
  prevButton.addEventListener('click', prevSlide);
});
</script>