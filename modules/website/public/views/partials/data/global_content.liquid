{%- comment -%} 
Gets 'Insites Site Manager - Global Content' data and exports it to be usable as a 'partial' data export.
{%- endcomment -%}

{% liquid 
    if context.modules.insites_site_manager 
    
        graphql global = 'modules/website/system/get_global_content'
        assign global = global.items.results | first
    
        comment
            Location 1 - concat address
        endcomment
        assign loc_1_address_full = ""
        if global.loc_1_address.street_number and global.loc_1_address.street_number != ''
            assign loc_1_address_full = global.loc_1_address.street_number | append : ", "
        endif
        if global.loc_1_address.address and global.loc_1_address.address != ''
            assign loc_1_address_full = loc_1_address_full | append: global.loc_1_address.address | append : ", "
        endif
        if global.loc_1_address.address2 and global.loc_1_address.address2 != ''
            assign loc_1_address_full = loc_1_address_full | append: global.loc_1_address.address2 | append : ", "
        endif
        if global.loc_1_address.city and global.loc_1_address.city != ''
            assign loc_1_address_full = loc_1_address_full | append: global.loc_1_address.city | append : ", "
        endif
        if global.loc_1_address.state and global.loc_1_address.state != ''
            assign loc_1_address_full = loc_1_address_full | append: global.loc_1_address.state | append : " "
        endif
        if global.loc_1_address.postcode and global.loc_1_address.postcode != ''
            assign loc_1_address_full = loc_1_address_full | append: global.loc_1_address.postcode | append : ", "
        endif
        if global.loc_1_address.country and global.loc_1_address.country != ''
            assign loc_1_address_full = loc_1_address_full | append: global.loc_1_address.country | append : " "
        endif
        assign global = global | add_hash_key: 'loc_1_address_full', loc_1_address_full
   
        comment
            Location 2 - concat address
        endcomment
        assign loc_2_address_full = ""
        if global.loc_2_address.street_number and global.loc_2_address.street_number != ''
            assign loc_2_address_full = global.loc_2_address.street_number | append : ", "
        endif
        if global.loc_2_address.address and global.loc_2_address.address != ''
            assign loc_2_address_full = loc_2_address_full | append: global.loc_2_address.address | append : ", "
        endif
        if global.loc_2_address.address2 and global.loc_2_address.address2 != ''
            assign loc_2_address_full = loc_2_address_full | append: global.loc_2_address.address2 | append : ", "
        endif
        if global.loc_2_address.city and global.loc_2_address.city != ''
            assign loc_2_address_full = loc_2_address_full | append: global.loc_2_address.city | append : ", "
        endif
        if global.loc_2_address.state and global.loc_2_address.state != ''
            assign loc_2_address_full = loc_2_address_full | append: global.loc_2_address.state | append : " "
        endif
        if global.loc_2_address.postcode and global.loc_2_address.postcode != ''
            assign loc_2_address_full = loc_2_address_full | append: global.loc_2_address.postcode | append : ", "
        endif
        if global.loc_2_address.country and global.loc_2_address.country != ''
            assign loc_2_address_full = loc_2_address_full | append: global.loc_2_address.country | append : " "
        endif
        assign global = global | add_hash_key: 'loc_2_address_full', loc_2_address_full

        comment
            Location 3 - concat address
        endcomment
        assign loc_3_address_full = ""
        if global.loc_3_address.street_number and global.loc_3_address.street_number != ''
            assign loc_3_address_full = global.loc_3_address.street_number | append : ", "
        endif
        if global.loc_3_address.address and global.loc_3_address.address != ''
            assign loc_3_address_full = loc_3_address_full | append: global.loc_3_address.address | append : ", "
        endif
        if global.loc_3_address.address2 and global.loc_3_address.address2 != ''
            assign loc_3_address_full = loc_3_address_full | append: global.loc_3_address.address2 | append : ", "
        endif
        if global.loc_3_address.city and global.loc_3_address.city != ''
            assign loc_3_address_full = loc_3_address_full | append: global.loc_3_address.city | append : ", "
        endif
        if global.loc_3_address.state and global.loc_3_address.state != ''
            assign loc_3_address_full = loc_3_address_full | append: global.loc_3_address.state | append : " "
        endif
        if global.loc_3_address.postcode and global.loc_3_address.postcode != ''
            assign loc_3_address_full = loc_3_address_full | append: global.loc_3_address.postcode | append : ", "
        endif
        if global.loc_3_address.country and global.loc_3_address.country != ''
            assign loc_3_address_full = loc_3_address_full | append: global.loc_3_address.country | append : " "
        endif
        assign global = global | add_hash_key: 'loc_3_address_full', loc_3_address_full

        export global

endif
%}