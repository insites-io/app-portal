  </section>


  {%- comment -%} ══ 3. SKILLS ══ {%- endcomment -%}
  <section class="at-skills" id="skills">
    <div class="at-wrap">
      <div class="at-heading-row">
        <span class="at-h-regular">My</span>
        <span class="at-h-bold">Skills</span>
      </div>
      <div class="at-skills-grid">
        <div class="at-skill-card">
          <img src="{{ 'modules/website/images/ai_task/skill-git.svg' | asset_url }}" alt="Git" class="at-skill-img">
