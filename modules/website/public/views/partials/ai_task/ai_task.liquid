---
metadata: {
    partial_name: 'Website | AI Task'
}
---

<style>
/* ── Reset & Base ──────────────────────────────────────────── */
.at *, .at *::before, .at *::after { box-sizing: border-box; margin: 0; padding: 0; }
.at { font-family: 'Sora', sans-serif; color: #18181b; background: #fff; -webkit-font-smoothing: antialiased; }
.at a { text-decoration: none; color: inherit; }
.at img, .at svg { display: block; }
.at ul { list-style: none; }
.at-wrap { max-width: 1280px; margin: 0 auto; padding: 0 80px; }
.at-section-img { width: 100%; display: block; }

/* ── Shared heading style ────────────────────────────────── */
.at-heading-row { display: flex; align-items: baseline; gap: 12px; margin-bottom: 48px; }
.at-h-regular { font-size: 48px; line-height: 56px; letter-spacing: -0.02em; font-weight: 400; }
.at-h-bold    { font-size: 48px; line-height: 56px; letter-spacing: -0.02em; font-weight: 800; }

/* ── Shared button styles ────────────────────────────────── */
.at-btn-solid {
  display: inline-flex; align-items: center; gap: 10px;
  height: 56px; padding: 0 20px;
  background: #000; color: #fff;
  font-family: 'Sora', sans-serif; font-size: 20px; font-weight: 600;
  border: 1px solid #000; border-radius: 4px; cursor: pointer; transition: background .2s;
}
.at-btn-solid:hover { background: #404040; border-color: #404040; }
.at-btn-icon {
  width: 56px; height: 56px; flex-shrink: 0;
  background: #000; border: 1px solid #000; border-radius: 4px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: background .2s, border-color .2s; color: #fff;
}
.at-btn-icon:hover { background: #404040; border-color: #404040; }
.at-btn-icon.is-outlined { background: #fff; color: #000; }
.at-btn-icon.is-outlined:hover { background: #000; color: #fff; }
.at-btn-icon svg { width: 20px; height: 20px; }

/* ═══════════════════════════════════════════════
   1. HEADER — white sticky, 104px
   ═══════════════════════════════════════════════ */
.at-header {
  position: sticky; top: 0; z-index: 100;
  height: 104px; background: #fff;
  display: flex; align-items: center;
}
.at-header .at-wrap { width: 100%; display: flex; align-items: center; justify-content: space-between; }
.at-logo { display: flex; align-items: center; gap: 12px; font-size: 20px; font-weight: 700; color: #000; }
.at-logo-mark { width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; }
.at-nav { display: flex; gap: 32px; }
.at-nav a { font-size: 20px; font-weight: 600; color: #000; transition: color .2s; }
.at-nav a:hover { color: #71717a; }

/* ═══════════════════════════════════════════════
   2. HERO — fully editable HTML
   ═══════════════════════════════════════════════ */
.at-hero { background: #fff; padding: 60px 0 80px; }
.at-hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; }
.at-hero-heading { margin-bottom: 24px; }
.at-hero-line { display: flex; flex-wrap: wrap; align-items: baseline; gap: 12px; line-height: 56px; }
.at-hero-regular { font-size: 48px; font-weight: 400; letter-spacing: -0.02em; color: #000; }
.at-hero-bold    { font-size: 48px; font-weight: 800; letter-spacing: -0.02em; color: #000; }
.at-hero-outline { font-size: 48px; font-weight: 800; letter-spacing: -0.02em; -webkit-text-stroke: 2px #000; color: transparent; }
.at-hero-desc { font-size: 16px; line-height: 24px; color: #71717a; margin-bottom: 40px; max-width: 600px; }
.at-hero-social { display: flex; gap: 16px; }
.at-hero-illustration { display: flex; justify-content: flex-end; align-items: center; }
.at-hero-illustration img { width: 100%; max-width: 630px; }

/* ═══════════════════════════════════════════════
   3. SKILLS — interactive HTML cards
   ═══════════════════════════════════════════════ */
.at-skills { background: #fff; padding: 80px 0; }
.at-skills-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 24px; }
.at-skill-card {
  aspect-ratio: 1 / 1;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px;
  border-radius: 4px; border: 1px solid #e4e4e7; background: #fff;
  cursor: pointer; transition: background .25s, border-color .25s;
}
.at-skill-card:hover { background: #000; border-color: #000; }
.at-skill-card:hover .at-skill-img { filter: invert(1); }
.at-skill-card:hover .at-skill-name { color: #fff; }
.at-skill-img { width: 56px; height: 56px; object-fit: contain; }
.at-skill-name { font-size: 16px; font-weight: 600; color: #000; text-align: center; }

/* ═══════════════════════════════════════════════
   4. EXPERIENCE — fully editable HTML
   ═══════════════════════════════════════════════ */
.at-experience { background: #000; padding: 80px 0; }
.at-experience .at-h-regular,
.at-experience .at-h-bold { color: #fff; }
.at-exp-cards { display: flex; flex-direction: column; gap: 24px; }
.at-exp-card {
  border: 1px solid #27272a; border-radius: 10px;
  padding: 32px; display: flex; flex-direction: column; gap: 20px;
  transition: border-color .2s;
}
.at-exp-card.is-highlighted { background: #27272a; border-color: #3f3f46; }
.at-exp-card:hover { border-color: #52525b; }
.at-exp-header { display: flex; align-items: center; justify-content: space-between; gap: 16px; }
.at-exp-left { display: flex; align-items: center; gap: 16px; }
.at-exp-logo { width: 32px; height: 32px; flex-shrink: 0; }
.at-exp-logo img { width: 32px; height: 32px; }
.at-exp-title { font-size: 24px; font-weight: 600; color: #fff; line-height: 32px; }
.at-exp-date { font-size: 16px; font-weight: 600; color: #d4d4d8; white-space: nowrap; }
.at-exp-desc { font-size: 16px; font-weight: 400; line-height: 24px; color: #d4d4d8; }

/* ═══════════════════════════════════════════════
   5. ABOUT — full Figma SVG (edit in Figma, re-export)
   ═══════════════════════════════════════════════ */
.at-about { background: #fff; line-height: 0; }

/* ═══════════════════════════════════════════════
   6. PROJECTS — black bg
   ═══════════════════════════════════════════════ */
.at-projects { background: #000; padding: 80px 0; }
.at-projects .at-h-regular,
.at-projects .at-h-bold { color: #fff; }
.at-project-item {
  display: grid; grid-template-columns: 1fr 1fr; gap: 40px;
  align-items: center; padding: 40px 0;
  border-top: 1px solid #27272a;
  transition: background .2s;
}
.at-project-item:last-child { border-bottom: 1px solid #27272a; }
.at-project-item:hover { background: #0a0a0a; }
.at-project-item.is-reversed .at-project-img { order: 2; }
.at-project-item.is-reversed .at-project-detail { order: 1; }
.at-project-img {
  background: #18181b; aspect-ratio: 594/476; border-radius: 4px;
  overflow: hidden;
}
.at-project-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.at-project-num   { font-size: 48px; font-weight: 800; color: #fff; letter-spacing: -0.02em; line-height: 56px; margin-bottom: 4px; opacity: .3; }
.at-project-title { font-size: 32px; font-weight: 700; color: #fff; letter-spacing: -0.02em; line-height: 40px; margin-bottom: 12px; }
.at-project-desc  { font-size: 16px; line-height: 24px; color: #71717a; }
.at-read-more {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 16px; font-weight: 600; color: #fff; margin-top: 24px;
  transition: gap .2s, color .2s;
}
.at-read-more:hover { gap: 14px; color: #d4d4d8; }
.at-read-more svg { width: 20px; height: 20px; flex-shrink: 0; }

/* ═══════════════════════════════════════════════
   7. TESTIMONIALS — fully editable HTML
   ═══════════════════════════════════════════════ */
.at-testimonials { background: #fff; padding: 80px 0; }
.at-testimonials .at-h-regular,
.at-testimonials .at-h-bold { color: #000; }
.at-testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
.at-testi-card {
  border-radius: 20px; padding: 40px 32px;
  display: flex; flex-direction: column; gap: 24px;
  background: #fff; border: 1px solid #e4e4e7;
  transition: transform .2s, box-shadow .2s;
}
.at-testi-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,.08); }
.at-testi-card.is-featured { background: #000; border-color: #000; }
.at-testi-avatar { position: relative; width: 96px; height: 96px; }
.at-testi-avatar-circle {
  width: 96px; height: 96px; border-radius: 50%;
  background: #e4e4e7; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
  font-size: 32px; font-weight: 700; color: #71717a;
}
.at-testi-card.is-featured .at-testi-avatar-circle { background: #3f3f46; color: #d4d4d8; }
.at-testi-badge {
  position: absolute; bottom: 0; right: 0;
  width: 30px; height: 30px; border-radius: 50%;
  background: #000; border: 2px solid #fff;
  display: flex; align-items: center; justify-content: center;
}
.at-testi-card.is-featured .at-testi-badge { background: #fff; }
.at-testi-badge svg { width: 14px; height: 14px; }
.at-testi-quote { font-size: 16px; font-weight: 400; line-height: 24px; color: #404040; flex: 1; }
.at-testi-card.is-featured .at-testi-quote { color: #fff; }
.at-testi-divider { width: 120px; height: 2px; background: #000; border: none; }
.at-testi-card.is-featured .at-testi-divider { background: #fff; }
.at-testi-name { font-size: 20px; font-weight: 600; color: #404040; }
.at-testi-card.is-featured .at-testi-name { color: #fff; }
.at-testi-role { font-size: 16px; font-weight: 600; color: #71717a; }
.at-testi-card.is-featured .at-testi-role { color: #d4d4d8; }

/* ═══════════════════════════════════════════════
   8. CONTACT
   ═══════════════════════════════════════════════ */
.at-contact { background: #fff; padding: 80px 0; }
.at-contact .at-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
.at-field { margin-bottom: 12px; }
.at-input, .at-textarea {
  width: 100%; height: 56px; padding: 0 20px;
  font-family: 'Sora', sans-serif; font-size: 16px; color: #18181b;
  background: #fff; border: 1px solid #000; border-radius: 4px;
  outline: none; transition: border-color .2s; appearance: none;
}
.at-textarea { height: 140px; padding: 16px 20px; resize: vertical; }
.at-input::placeholder, .at-textarea::placeholder { color: #71717a; }
.at-input:focus, .at-textarea:focus { border-color: #71717a; }
.at-form-row { display: flex; align-items: center; gap: 12px; margin-top: 12px; flex-wrap: wrap; }
.at-btn-submit {
  display: inline-flex; align-items: center; gap: 10px;
  height: 56px; padding: 0 32px; background: #000; color: #fff;
  font-family: 'Sora', sans-serif; font-size: 20px; font-weight: 600;
  border: none; border-radius: 4px; cursor: pointer; transition: background .2s;
}
.at-btn-submit:hover { background: #404040; }
.at-contact-tagline { font-size: 48px; font-weight: 800; line-height: 1.2; letter-spacing: -0.02em; color: #000; margin-bottom: 24px; }
.at-contact-tagline strong { font-weight: 800; display: block; }
.at-talk-outline { -webkit-text-stroke: 2px #000; color: transparent; }
.at-contact-sub { font-size: 16px; line-height: 24px; color: #71717a; margin-bottom: 32px; }
.at-contact-details { display: flex; flex-direction: column; gap: 4px; }
.at-contact-details a { font-size: 28px; font-weight: 600; color: #000; transition: color .2s; }
.at-contact-details a:hover { color: #71717a; }

/* ═══════════════════════════════════════════════
   9. FOOTER — black bg
   ═══════════════════════════════════════════════ */
.at-footer { height: 100px; background: #000; display: flex; align-items: center; }
.at-footer .at-wrap { width: 100%; display: flex; align-items: center; justify-content: space-between; }
.at-footer-logo { display: flex; align-items: center; gap: 12px; font-size: 20px; font-weight: 700; color: #fff; }
.at-footer-copy { text-align: right; }
.at-footer-copy span { display: block; font-size: 16px; font-weight: 600; color: #fff; }

/* ═══════════════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════════════ */
@media (max-width: 1024px) {
  .at-wrap { padding: 0 40px; }
  .at-skills-grid { grid-template-columns: repeat(4, 1fr); }
  .at-exp-title { font-size: 20px; }
}
@media (max-width: 768px) {
  .at-wrap { padding: 0 24px; }
  .at-header { height: auto; padding: 20px 0; position: static; }
  .at-nav { display: none; }
  .at-hero-grid { grid-template-columns: 1fr; }
  .at-hero-illustration { display: none; }
  .at-hero-regular, .at-hero-bold, .at-hero-outline { font-size: 36px; line-height: 44px; }
  .at-h-regular, .at-h-bold { font-size: 36px; line-height: 44px; }
  .at-skills-grid { grid-template-columns: repeat(3, 1fr); }
  .at-exp-header { flex-direction: column; align-items: flex-start; }
  .at-testimonials-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
  .at-project-item { grid-template-columns: 1fr; gap: 24px; }
  .at-project-item.is-reversed .at-project-img,
  .at-project-item.is-reversed .at-project-detail { order: unset; }
  .at-contact .at-wrap { grid-template-columns: 1fr; }
  .at-contact-tagline { font-size: 36px; }
  .at-contact-details a { font-size: 22px; }
}
@media (max-width: 480px) {
  .at-skills-grid { grid-template-columns: repeat(2, 1fr); }
  .at-testimonials-grid { max-width: none; }
  .at-contact-tagline { font-size: 28px; }
  .at-contact-details a { font-size: 18px; }
}
</style>

<div class="at">

  {%- comment -%} ══ 1. HEADER ══ {%- endcomment -%}
  <header class="at-header">
    <div class="at-wrap">
      <a href="/ai-task" class="at-logo">
        <div class="at-logo-mark">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
