        <div class="at-skill-card">
          <img src="{{ 'modules/website/images/ai_task/skill-react.svg' | asset_url }}" alt="React" class="at-skill-img">
          <span class="at-skill-name">React</span>
        </div>
        <div class="at-skill-card">
          <img src="{{ 'modules/website/images/ai_task/skill-sass.svg' | asset_url }}" alt="Sass/SCSS" class="at-skill-img">
          <span class="at-skill-name">Sass/SCSS</span>
        </div>
        <div class="at-skill-card">
          <img src="{{ 'modules/website/images/ai_task/skill-nest.svg' | asset_url }}" alt="Nest.js" class="at-skill-img">
          <span class="at-skill-name">Nest.js</span>
        </div>
        <div class="at-skill-card">
          <img src="{{ 'modules/website/images/ai_task/skill-storybook.svg' | asset_url }}" alt="Storybook" class="at-skill-img">
          <span class="at-skill-name">Storybook</span>
        </div>
        <div class="at-skill-card">
          <img src="{{ 'modules/website/images/ai_task/skill-socket.svg' | asset_url }}" alt="Socket.io" class="at-skill-img">
          <span class="at-skill-name">Socket.io</span>
        </div>
        <div class="at-skill-card">
          <img src="{{ 'modules/website/images/ai_task/skill-nextjs.svg' | asset_url }}" alt="Next.js" class="at-skill-img">
          <span class="at-skill-name">Next.js</span>
