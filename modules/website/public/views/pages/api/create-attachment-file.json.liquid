---
slug: api/forms/create-attachment-file
method: post
format: json
searchable: false
---

{%- assign data = context.params | parse_json | default: null -%}
{%- assign path = data.path | split: "modules/insites_core/attachment/file/" -%}
{%- assign path = path[1] -%}
{%- assign uuid = path | split: "/" | first -%}

{%- graphql result = 'modules/website/forms/create_attachment_file',
    uuid: uuid,
    file: data.url -%}

{%- if result.item == blank -%} 
  {%- assign status = 400 -%}
{%- else %}
  {%- assign status = 200 -%}
{%- endif -%}

{% response_status status %}
{{ result }}