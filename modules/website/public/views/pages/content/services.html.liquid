---
slug: services
layout: modules/website/dynamic
## Note: Make sure to add 'modules/insites_database/insites_admin/database_layouts/page_metadata' partial / content block
##       to the layout used so INS Database Layouts will generate SEO Metadata.
# enable_profiler: true
searchable: true
max_deep_level: 2
metadata: {
    "status": "published",
    "page_title": "Services | Insites",
    "page_type": "content", ## content, system or endpoint
    ##
    ## Metadata `database_name`, `list_enabled` and `details_enabled` values is used 
    ## to connect this page to the Insites Database Layouts
    ## Setting `list_enabled` / `details_enabled` value to `true` will enable the layout page
    ##
    "database_name": "modules/website/services",
    "list_enabled": true,
    "details_enabled": true
}
redirect_to: >
  {%- comment -%}
  This is a Insites Database Module partial / content block,
  add this to your page `redirect_to` YAML configuration and
  it will automatically check if page should proceed or be redirected to 404 page.
  {%- endcomment -%}
  {%- include 'modules/insites_database/insites_admin/database_layouts/insites_database_layouts_redirect_to' -%}
dynamic_cache:
  layout: |-
    {%- comment -%}Set layout cache depending if E-commerce module is present{%- endcomment -%}
    {%- if context.modules.ecommerce.name != blank -%}
    false
    {%- else -%}
    true
    {%- endif -%}
  key: |-
    {%- parse_json models -%}
    [
      {%- if context.modules.ecommerce.name == blank -%} "modules/website/main_menu", {%- endif -%}
      "modules/insites_site_manager/insites_global_content",
      "modules/website/page_header",
      "modules/insites_core/insites_system_fields",
      "modules/website/services",
      "modules/website/services_faq"
    ]
    {%- endparse_json -%}
    {%- include "modules/website/generate_cache_key", models: models -%}
---

{%- comment -%}
This is a Insites Database Module partial / content block,
add this to your page `body` / `content` of the page
and it will automatically check if the page should be displaying details or list view.
{%- endcomment -%}
