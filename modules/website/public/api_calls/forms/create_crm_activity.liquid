---
to: '{{ platform_context.host }}/insites/api/ins-create-crm-activity.json'
delay: 0.5
enabled: true
trigger_condition: true
request_type: POST
headers: >
    {
        "Content-Type": "application/json",
        "authorization": "{{ context.constants.insites_crm_activities_auth }}"
    }
---
{%- comment -%}
API Call sends data to insites_crm_activities module.
It creates a new activity to a CRM record.
{%- endcomment -%}
{%- graphql data = 'modules/website/system/get_model', id: form.id -%}
{%- assign model = data.items.results | first -%}
{%- assign subject = "Form Submission: " | append: model.name | append: ' - ' | append: form.id -%}

{%- if model.name == 'modules/website/contact_us' -%}
    {%- assign subject = "Submitted enquiry: Contact Us - ID: " | append: form.id  -%}
    {%- assign notes = form.properties.message -%}
{%- elsif model.name == 'modules/website/subscriptions' -%}
    {%- assign subject = "Subscribed to Newsletter" -%}
{%- elsif model.name == 'modules/ins_template_locator/locator_enquiry' -%}
    {%- assign subject = "Locator enquiry - ID: " | append: form.id  -%}
    {% capture 'notes' %}
Location: {{ form.properties.location_name }} - {{ form.properties.location_id }}
Requested days: {{ form.properties.requested_days[0] }}
Message: {{ form.properties.message }}
    {% endcapture %}
{%- endif -%}

{
    "payload": {
        "properties": {
            "type": "Other",
            "attendees": ["{{ model.user_id }}"],
            "notes": "{{ notes | default: "" }}",
            "message": "",
            "activity_start_date_time": "{{ 'now' | date: "%Y-%m-%d %H:%M" }}",
            "activity_end_date_time": "",
            "attachments": [],
            "source": "User",
            "source_id": "{{ model.user_id }}",
            "subject": "{{ subject }}",
            "recipient": []
        }
    }
}

