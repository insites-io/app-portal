---
name: bill_payment_failed
to: '{{ data.customer_info.email }}'
delay: 0
enabled: true
trigger_condition: true
from: >
    {%- include 'modules/portal/emails/autoresponder_from' -%}
reply_to: >
    {%- include 'modules/portal/emails/autoresponder_reply_to' -%}
cc:
bcc:
subject: Bill payment failed
layout: modules/insites_core/insites_external_email_layout
metadata: {
    email_name: "Auto Responder | Bill Payment Failed"
}
---

{%- graphql global = 'modules/insites_core/utilities/get_global_content_for_email' -%}

{%- include 'modules/insites_core/email_layout/email_icon' -%}

<table class="module" role="module" data-type="text" border="0" cellpadding="0"
  cellspacing="0" width="100%" style="table-layout: fixed;"
  data-muid="ae3b5e25-e601-4be7-8e69-e21f7125e6e7" data-mc-module-version="2019-10-22">
  <tbody>
    <tr>
      <td style="padding:0px 24px 24px 24px; line-height:24px; text-align:inherit;"
        height="100%" valign="top" bgcolor="" role="module-content">
        <div>
          <div style="font-family: inherit; text-align: center"><span
              style="font-size: 24px"><strong>Payment Failed</strong></span></div>
          <div></div>
        </div>
      </td>
    </tr>
  </tbody>
</table>
<table class="module" role="module" data-type="text" border="0" cellpadding="0"
  cellspacing="0" width="100%" style="table-layout: fixed;"
  data-muid="c91a48dd-cef4-4985-9a78-d3e751a003dc" data-mc-module-version="2019-10-22">
  <tbody>
    <tr>
      <td style="padding:0px 24px 0px 24px; line-height:24px; text-align:inherit;"
        height="100%" valign="top" bgcolor="" role="module-content">
        <div>
          <div style="font-family: inherit; text-align: left"><span
              style="white-space: pre-wrap">We were unable to process the payment. This could have happened for a number of reasons:</span></div>
          <div style="font-family: inherit; text-align: left"><br></div>
          <ul>
            <li style="text-align: left"><span style="white-space: pre-wrap">Insufficient funds on the account</span></li>
            <li style="text-align: left"><span style="white-space: pre-wrap">Expired Credit Card</span></li>
            <li style="text-align: left"><span style="white-space: pre-wrap">The bank's fraud rules blocked the transaction</span></li>
          </ul>
          <div style="font-family: inherit; text-align: left"><br></div>
          <div style="font-family: inherit; text-align: left"><span
              style="white-space: pre-wrap">You might need to update your billing info or retry at </span><span
              style="white-space: pre-wrap"><strong>{{global.items.results[0].company_name}}</strong></span><span
              style="white-space: pre-wrap">. If the issue persists contact your bank for more information.</span></div>
          <div></div>
        </div>
      </td>
    </tr>
  </tbody>
</table>

{% comment %} <!-- spacer --> {% endcomment %}
<table class="module" role="module" data-type="spacer" border="0" cellpadding="0"
  cellspacing="0" width="100%" style="table-layout: fixed;"
  data-muid="a15f4ddd-d611-4626-945c-62c1a481f19f">
  <tbody>
    <tr>
      <td style="padding:0px 0px 40px 0px;" role="module-content" bgcolor="">
      </td>
    </tr>
  </tbody>
</table>

{% comment %} <!-- Button --> {% endcomment %}
<table border="0" cellpadding="0" cellspacing="0" class="module" data-role="module-button"
  data-type="button" role="module" style="table-layout:fixed;" width="100%"
  data-muid="7564a63d-604e-486b-a509-14550d6d9be3">
  <tbody>
    <tr>
      <td align="center" bgcolor="" class="outer-td" style="padding:40px 24px 0px 24px;">
        <table border="0" cellpadding="0" cellspacing="0" class="wrapper-mobile"
          style="text-align:center;">
          <tbody>
            <tr>
              <td align="center" bgcolor="#333333" class="inner-td"
                style="border-radius:6px; font-size:16px; text-align:center; background-color:inherit;">
                <a href="{{ platform_context.host }}/pay-bills"
                  style="background-color:#333333; border:0px solid #333333; border-color:#333333; border-radius:4px; border-width:0px; color:#ffffff; display:inline-block; font-size:16px; font-weight:700; letter-spacing:0px; line-height:normal; padding:16px 80px 16px 80px; text-align:center; text-decoration:none; border-style:solid; font-family:arial,helvetica,sans-serif;"
                  target="_blank">Retry</a>
              </td>
            </tr>
          </tbody>
        </table>
      </td>
    </tr>
  </tbody>
</table>