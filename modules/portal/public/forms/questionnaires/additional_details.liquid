---
name: questionnaires_additional_details
resource: modules/portal/questionnaires
resource_owner: anyone
redirect_to: >
  {%  liquid
      if form.properties.save_exit == 'true'
        assign redirect_url = '/questionnaires'
      else
        assign redirect_url = '/questionnaires-confirmation/' | append: form.id
      endif
  %}
  {{ redirect_url }}
fields:
  properties:
    contact_name:
      validation:
        presence: true
    contact_number:
      validation:
        presence: true
    update_site:
      validation:
        presence: true
    notes:
    save_exit:
      property_options:
        virtual: true
async_callback_actions:
  delay: 0
  priority: low
  max_attempts: 2
  content: |-
    {% comment %} Create Event Stream {% endcomment %}
    {% graphql get_questionaire_table_id = 'modules/portal/questionnaires/get_questionaires_table' | dig: 'admin_tables', 'results' %}
    {%  assign questionaire_table_id = get_questionaire_table_id | first  %}

    {%- assign current_user_name =  context.current_user.first_name | append: ' ' | append: context.current_user.last_name | default: context.current_user.email -%}
    {%- capture description -%} <a target="_blank" href="/admin/insites/#/databases/{{ questionaire_table_id.id }}/items/{{ form.id }}">Questionnaires</a> - Additional Details (Step 2 of 3) - <a target="_blank" href="/admin/insites/#/crm/contacts/{{ context.current_user.id }}">{{ current_user_name  | default: context.current_user.email }}</a> {%- endcapture -%}
    {%- assign payload = '{}' | parse_json -%}
    {%- assign payload = payload | add_hash_key: "description", description -%}


    {% capture log_info %}
      {
          "user": {
            "id": "{{ context.current_user.id }}",
            "email": "{{ context.current_user.email }}",
            "first_name": "{{ context.current_user.first_name }}",
            "last_name": "{{ context.current_user.last_name }}"
          },
          "id": "{{ form.id }}",
          "contact_name": "{{ form.properties.contact_name }}",
          "contact_number": "{{ form.properties.contact_number }}",
          "update_site": "{{ form.properties.update_site }}",
          "notes": "{{ form.properties.notes }}",
          "contact_uuid": "{{ context.current_user.external_id }}"
      }    
    {% endcapture %}
    {%- assign log_info_json = log_info | parse_json -%}
    {%- assign info = payload | add_hash_key: "log", log_info_json -%}
    {% include 'modules/portal/events/log_event', info %}  
---

{%  liquid
    assign props = form.fields.properties
%}

{%- form
    html-autocomplete: "off"
    html-id: "questionnaires-form"
    html-class: 'insites-form insites-form-code questionnaires-form' 
    html-novalidate: true
    html-onsubmit: "return validateQuestionnairesForm(event)" -%}   

    <input name="{{ props.save_exit.name }}" id="save-exit" type="hidden" value="false" >

    <div class="insites-form-grid">
    
        <div class="form-groups-tab">        
            {% include "modules/portal/questionnaires/form_steps" %}
        </div>
        
        {% include "modules/portal/questionnaires/additional_details_inputs", form %}
        
    </div>
    <div class="spacer x-large"></div>
    <div class="insites-form-grid ">    
      <div class="column-2 left">
        <div class="grid-x">
          <div class="cell">
            <ins-button type="submit" label="SAVE & EXIT" icon="icon-exit-to-app" id="save-exit-btn" ></ins-button>
          </div>
        </div>
        
      </div> 
      <div class="insites-form-buttons column-2 right">
        <div class="grid-x">
    
            {% comment %} Desktop view of buttons {% endcomment %}
            <div class="show-for-large">
              <ins-button type="button" label="CANCEL" class="cancel-btn" icon="icon-close-1"></ins-button>
              <a href="/questionnaires-general/{{context.params.slug2}}"><ins-button type="button" label="BACK" icon="icon-arrow-left" outlined ></ins-button></a>
              <ins-button type="submit" label="SAVE & NEXT" class="save-next-btn mr-0" icon-right="icon-arrow-forward" solid ></ins-button>
            </div>            
            
            {% comment %} Tablet and Mobile view of buttons {% endcomment %}
            <div class="hide-for-large mr-0">              
              <ins-button type="submit" label="SAVE & NEXT" class="save-next-btn" icon-right="icon-arrow-forward" solid ></ins-button>
              <div class="spacer"></div>
              <a href="/questionnaires-general/{{context.params.slug2}}"><ins-button type="button" label="BACK" icon="icon-arrow-left" outlined ></ins-button></a>
              <div class="spacer"></div>
              <ins-button type="button" label="CANCEL" class="cancel-btn" icon="icon-close-1" ></ins-button>
            </div>
        </div>
      </div>
    </div>
    
{%- endform -%}

{%- include 'modules/portal/questionnaires/cancel_modal' -%}

<script>
  <!-- Set Contact Number value -->
  let contactNumber = document.getElementById('ins_contact_number');
  contactNumber.addEventListener('didLoad', function(e){    
    let countryCode = {{ form.fields.properties.contact_number.value | split: ' ' | default: '[]' }};
    if (Array.isArray(countryCode)){
      contactNumber.setCountryCode(`+${countryCode[0]}`);
      if(countryCode.length > 1){
        contactNumber.setAttribute('phonenum-value', countryCode[1]);
      }
    }
  });   

  <!-- Submit Form -->
  let form = document.getElementById('questionnaires-form');
  let saveNextBtn = document.querySelectorAll('.save-next-btn');
  let saveExitBtn = document.getElementById('save-exit-btn');
  let saveExitInput = document.getElementById('save-exit');
      saveExitBtn.addEventListener('insClick', event => {
        saveExitInput.value = "true";
      });   

  async function validateQuestionnairesForm(event) {
    event.preventDefault();
                    
    if (await App.validation.validateForm(form)) {
      saveNextBtn.forEach(btn => btn.loading = true);
      document.querySelectorAll('ins-button').forEach(btn => btn.disabled = true);

      let contactNumberInput = document.getElementById('contact_number');
      let phoneVal = await contactNumber.getValues();
      contactNumberInput.value = `${phoneVal.country_code} ${phoneVal.phone_number}`; 
      
      form.submit();
      return true;
    } else {
      saveNextBtn.forEach(btn => btn.loading = false);
      return false;
    }
  }
</script>  