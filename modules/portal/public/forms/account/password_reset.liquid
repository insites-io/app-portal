---
name: password_reset
resource: User
resource_owner: anyone
redirect_to: password-reset
flash_alert: Sorry-PasswordReset
flash_notice: Your password has been updated.
fields:
  email:
    property_options:
      readonly: true
  password:
    validation:
      confirmation: true
      message: Password doesn't match.
  password_confirmation:
    property_options:
      virtual: true
  
  properties:
    company_uuid:
      property_options:
        virtual: true

    permission_level:
      property_options:
        virtual: true

    user_id:
      property_options:
        virtual: true


callback_actions: |-   
  {% if form.properties.company_uuid != blank %}
   {%- graphql user_details = "modules/portal/account/get_user_by_email" 
        email: form.email
        | dig: "items" | dig: "results" | first -%}

    {% parse_json update_crm_data  %}
    {
        "id": "{{ form.properties.user_id }}",
        "uuid": "{{ user_details.uuid }}",
        "email": "{{ form.email }}",
        "company.uuid": "{{ form.properties.company_uuid }}",
        "permission_level": "{{ form.properties.permission_level }}",
        "invitation_status": "Accepted" 
    }
    {% endparse_json %}

    {% graphql add_crm_contact = 'modules/website/trigger_api_call', name: "modules/portal/update_crm_via_password_reset",
    data: update_crm_data
    | dig: 'items','response','body'
    | parse_json  
    %}
  {% endif %}

---

  <div class="grid-x">
    <div class="small-12 cell spacer xxx-large hide-for-small-only"></div>
    <div class="large-8 medium-9 small-12 cell">
        <h3 class="heading-3">Password Reset</h3>
        <div class="spacer small"></div>
        <p class="p-dark p-body">Enter a password to reset the password on your account.</p>
    </div>
    <div class="small-12 cell spacer xxx-large"></div>
    <div class="large-8 medium-9 small-12 cell">
      {%- form 
        html-id: "password-reset-form"
        html-novalidate: true
        html-enctype="multipart/form-data"
        html-onsubmit:"return LoginScript.methods.validateForm(event)" -%}

        <div class="grid-x grid-padding-x">
          <div class="small-12 cell">

            <input name="token" value="{{ context.params.token }}" type="hidden">
            <input name="email" value="{{ form.email }}" type="hidden">
            <input name="{{ form.fields.properties.company_uuid.name }}" value="{{ context.params.company_uuid | base64_url_safe_decode }}" type="hidden">
            <input name="{{ form.fields.properties.permission_level.name }}" value="{{ context.params.permission_level |  base64_url_safe_decode }}" type="hidden">
            <input name="{{ form.fields.properties.user_id.name }}" value="{{ id }}" type="hidden">

            <ins-input validate
              id="password"
              label="New Password"
              field="password"
              name="{{ form.fields.password.name }}" 
              value="{{ form.fields.password.value }}" 
              {% if form.errors['password'] %} has-error {% endif %}
              {% assign errmatch = form.fields.password.validation.errors | any: "doesn't match Password" %}
              {% if errmatch %}
              error-message="Password doesn't match." 
              {% else %}
              error-message="Invalid password" 
              {% endif %}
              placeholder="Enter your new password">
            </ins-input>
            <div class="spacer"></div>
            <ins-input validate
              id="password_confirmation"
              label="Confirm New Password"
              field="password"
              name="{{ form.fields.password_confirmation.name }}" 
              value="{{ form.fields.password_confirmation.value }}" 
              {% if form.errors['password'] %} has-error {% endif %}
              {% assign errmatch = form.fields.password.validation.errors | any: "doesn't match Password" %}
              {% if errmatch %}
              error-message="Password doesn't match." 
              {% else %}
              error-message="Invalid password" 
              {% endif %}
              
              placeholder="Re-enter your new password">
            </ins-input>      
          </div>
          <div class="small-12 cell spacer x-large"></div>
          <div class="small-12 cell text-center">
            <ins-button id="submit-btn" class="full" label="Reset my password" solid color="blue" type="submit" size="normal"></ins-button>
          </div>

        </div>

      {%- endform -%}
    </div>
</div>
        


{%- if context.flash and context.flash.alert == "Sorry-PasswordReset" -%}
<script>
setTimeout(() => {
    App.events.notyf('error', "Error in reseting password.");
}, 200);
</script>
{% endif -%}
