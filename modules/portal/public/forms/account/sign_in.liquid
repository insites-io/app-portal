---
name: sign_in
resource: Session
resource_owner: anyone
flash_notice: 'Successful'
flash_alert: 'Sorry-SignIn'
redirect_to: >
  {{ form.redirect }}
fields:
  email:
    validation: 
      presence:
        message: Please enter a valid email.
      email: 
        message: Please enter a valid email.
  password:
    validation: 
      presence:
        message: Password is required.
  redirect:
    property_options:
        virtual: true
        
async_callback_actions:
  delay: 0
  priority: low
  max_attempts: 2
  content: |-
    {% comment %} Create Event Stream {% endcomment %}
    {%- graphql user = "modules/portal/account/get_user_by_email" 
        email: form.email
        | dig: "items" | dig: "results" | first -%}
    {%  assign crm_contact = user.crm_contact | first %}
    {%- assign current_user_name =  user.first_name | append: ' ' | append: user.last_name | default: user.email -%}
    {%- capture description -%}<a target="_blank" href="/admin/insites/#/crm/contacts/{{ user.id }}">{{ current_user_name  | default: user.email }}</a> from <a target="_blank" href="/admin/insites#/crm/companies/{{ crm_contact.company_uuid }}">{{ crm_contact.company.company_name }}</a> logged in to the portal {%- endcapture -%}
    {%- assign payload = '{}' | parse_json -%}
    {%- assign payload = payload | add_hash_key: "description", description -%}
    {%- assign payload = payload | add_hash_key: "font_icon", "icon-users" -%}
    {%- assign payload = payload | add_hash_key: "font_icon_color", '#33B8C0' -%}


    {% capture log_info %}
      {
          "user": {
            "id": "{{ user.id }}",
            "email": "{{ user.email }}",
            "first_name": "{{ user.first_name }}",
            "last_name": "{{ user.last_name }}"
          },
          "contact_uuid": "{{ user.uuid }}"
      }
    {% endcapture %}

    {%- assign log_info_json = log_info | parse_json -%}
    {%- assign info = payload | add_hash_key: "log", log_info_json -%}
    {% include 'modules/portal/events/log_event', info %}
---

{%- form 
	html-id: "sign-in-form"
	html-novalidate: true
  html-enctype="multipart/form-data"
  html-onsubmit:"return LoginScript.methods.validateForm(event);" -%}
	
	<div class="grid-x grid-padding-x">
		<div class="small-12 cell">
			<ins-input validate
				id="email"
        label="Email*"
        field="email"
        name="{{ form.fields.email.name }}" 
        value="{{ form.fields.email.value }}" 
        {% if form.errors['email'] %} has-error {% endif %}
        error-message="{{ form.fields.email.validation.rules.presence.message }}"
        placeholder="Email">
			</ins-input>

      <div class="spacer"></div>

      <ins-input validate
          class="spacer"
          id="password"
          label="Password*"
          field="password"
          name="{{ form.fields.password.name }}" 
          value="{{ form.fields.password.value }}" 
        {% if form.errors['password'] %} has-error {% endif %}
          error-message="{{ form.fields.password.validation.rules.presence.message }}"
          placeholder="Password">
      </ins-input>
    </div>

    {% comment %} {%- if context.flash.alert == 'Sorry-SignIn' -%}
    <div class="small-12 cell">
			<p class="warning">Invalid email or password</p>
		</div>
  	{%- endif -%} {% endcomment %}

		<div class="cell grid-x">
			<div class="cell text-right pt-24">
				<a class="a-label-no-visit" href="/forgot-password">Forgot your password?</a>
			</div>
		</div>
		<div class="small-12 cell spacer x-large">
    {%- if context.flash.alert and context.flash.alert != 'Sorry-SignIn' -%}
      <div class="spacer small"></div>
    {%- endif -%}
    </div>
    
    <div class="small-12 cell">
			<ins-button id="submit-btn" label="Sign in" class="full" solid color="blue" type="submit" ></ins-button>
     
      {% if context.constants.ecommerce_addon == 'true' and context.params.slug == 'checkout' %}
        <div class="spacer x-large"></div>
        <p>Not a member? <a href="/create-account">Join us.</a></p>      
        <input type="hidden" name="{{ form.fields.redirect.name }}" value="checkout" >      
      {% else %}
        <div class="spacer x-large"></div>
        <div class="small-12 cell"> 
          Don’t have an account? <a class="a-label-no-visit" href="/create-account">Create an account.</a>
        </div>
        <input type="hidden" name="{{ form.fields.redirect.name }}" value="overview" >
      {% endif %}

		</div>

	</div>
{%- endform -%}