---
name: create-account
resource: User
resource_owner: anyone
flash_alert: Sorry-Signup
flash_notice: Congratulations-Signup
redirect_to: account-created
fields:
  # User Fields
  email:
    validation: 
      unique:
        message: Email already exist
      presence:
        message: Email is required.
      email: 
        message: Please enter a valid email.     
  password:
    validation: 
      presence: 
        message: Invalid password.
  first_name:
    validation: 
      presence: 
        message: First name is required.
  last_name:
    validation: 
      presence: 
        message: Last name is required.
  
  properties:
    # Profile - CRM Contact Fields
    mobile_phone_country_code:
      property_options:
        virtual: true
    mobile_phone_number:
      property_options:
        virtual: true

    # CRM Address - Contact Fields              
    address_1:
      validation: 
        presence: 
          message: Address 1 is required.
      property_options:
        virtual: true
    address_2:
      property_options:
        virtual: true
    suburb:
      validation: 
        presence: 
          message: Suburb is required.
      property_options:
        virtual: true
    state:
      validation: 
        presence: 
          message: State is required.
      property_options:
        virtual: true
    postcode:
      validation: 
        presence: 
          message: Postcode is required.
      property_options:
        virtual: true
    country:
      validation: 
        presence: 
          message: Country is required.
      property_options:
        virtual: true
    latitude:
      property_options:
        virtual: true
    longitude:
      property_options:
        virtual: true

    # CRM Company Fields          
    email_1:
      validation: 
        presence:
          message: Company email is required.
        email: 
          message: Please use a valid email address.  
      property_options:
        virtual: true 
    company_name:
      validation: 
        presence: 
          message: Company name is required.
      property_options:
        virtual: true 
    registered_business_number:
      validation: 
        presence: 
          message: Company registration number is required. 
      property_options:
        virtual: true 

    # CRM Address - Company Fields
    company_mobile_phone_country_code:
      property_options:
        virtual: true
    company_mobile_phone_number:
      property_options:
        virtual: true
    company_address_1:
      validation: 
        presence: 
          message: Address 1 is required.
      property_options:
        virtual: true
    company_address_2:
      property_options:
        virtual: true
    company_suburb:
      validation: 
        presence: 
          message: Suburb is required.
      property_options:
        virtual: true
    company_state:
      validation: 
        presence: 
          message: State is required.
      property_options:
        virtual: true
    company_postcode:
      validation: 
        presence: 
          message: Postcode is required.
      property_options:
        virtual: true
    company_country:
      validation: 
        presence: 
          message: Country is required.
      property_options:
        virtual: true    
    company_latitude:
      property_options:
        virtual: true
    company_longitude:
      property_options:
        virtual: true
    

  # Confirmation Fields
  agreement:
    presence: true
    property_options:
      virtual: true
      
async_callback_actions:
  delay: 0
  priority: high
  max_attempts: 2
  content: >
    {% comment %}
      Steps:
        1. Add Company
        2. Update company_uuid on Client Profile
        3. Update Contact
        4. Add Contact Address    
    {% endcomment %}
    {% assign data = form | json %}
    
    {% assign props = form.properties %}

    # Create Company details object
    {% parse_json company_details %}
    {
      "company_name": "{{ props.company_name }}",
      "registered_business_number": "{{ props.registered_business_number }}",
      "email_1": "{{ props.email_1 }}",
      "mobile_phone_country_code": "{{ props.company_mobile_phone_country_code }}",
      "mobile_phone_number": "{{ props.company_mobile_phone_number }}"
    }
    {% endparse_json %}

    # Add company
    {% function add_company = "crm/controller/companies/create", params: company_details %}
    
    # Create Company address object
    {% parse_json company_address_details %}
    {
      "company.uuid": "{{  add_company.uuid }}",
      "address_label": "{{ props.company_address_1 | default: "Default" }}" ,
      "address_1": "{{ props.company_address_1 }}",
      "address_2": "{{ props.company_address_2 }}",
      "suburb": "{{ props.company_suburb }}",
      "state": "{{ props.company_state }}",
      "postcode": "{{ props.company_postcode }}",
      "country": "{{ props.company_country }}",
      "latitude": "{{ props.company_latitude }}",
      "longitude": "{{ props.company_longitude }}"
    }
    {% endparse_json %}

    # Add company address
    {% function add_company_address = "crm/controller/addresses/create", type: "company", params: company_address_details %}
    {% parse_json data_company_address %}
    {
     "default_address.uuid": "{{ add_company_address.uuid }}"
    }
    {% endparse_json %}

    # Update Company
    {% function update_company = "crm/controller/companies/update", uuid: add_company.uuid, params: data_company_address %}
   
    {%- graphql user_details = "modules/portal/account/get_user_by_email" 
        email: form.email
        | dig: "items" | dig: "results" | first -%}

    ###Ecommerce module passes contact_uuid rather than relying on the logged-in user's UUID because guest checkout also saves CRM data.
    {% liquid     
        if props.contact_uuid != blank
            assign contact_uuid = props.contact_uuid
        else 
            assign contact_uuid = user_details.uuid
        endif
    %}

    # Create contact address object
    {% parse_json contact_address_details %}
    {
        "contact.uuid": "{{ contact_uuid }}",
        "address_label": "{{ props.address_1 | default: 'Default' }}", 
        "default_address": true,
        "address_1": "{{ props.address_1 }}",
        "address_2": "{{ props.address_2 }}",
        "suburb": "{{ props.suburb }}",
        "state": "{{ props.state }}",
        "postcode": "{{ props.postcode }}",
        "country": "{{ props.country }}",
        "latitude": "{{ props.latitude }}",
        "longitude": "{{ props.longitude }}"
    }
    {% endparse_json %}

    {% comment %} NOTE: Create CRM -> Contact Address via Controller {% endcomment %}
    {% function add_contact_address = "crm/controller/addresses/create", type: "contact", params: contact_address_details %}

    {% parse_json update_contact_data %}
    {
      "email": "{{ form.email }}",
      "company.uuid": "{{ add_company.uuid }}",
      "mobile_phone_country_code": "{{ form.properties.mobile_phone_country_code }}",
      "mobile_phone_number": "{{ form.properties.mobile_phone_number }}",
      "default_address.uuid": "{{ add_contact_address.uuid }}",
      "is_archived": false
    }
    {% endparse_json %}

    {% comment %} NOTE: Update CRM -> Contact via Controller {% endcomment %}
    {% function update_contact = "crm/controller/contacts/update", uuid: user_details.uuid, params: update_contact_data %}
  
    # Generate user temporary token
    {%  liquid
      graphql temporary_token = 'modules/portal/account/generate_user_temporary_token', email: form.email | dig: 'items', 'results' | first
    %}

    # Create user profile
    {%  liquid
      graphql create_user_profile = 'modules/portal/account/create_user_profile', id: temporary_token.id, token: temporary_token.temporary_token, is_enabled: true, primary_account_holder: true
    %}
    
    # Create Event Stream
    {%- assign current_user_name =  form.first_name | append: ' ' | append: form.last_name | default: form.email -%}

    {%- capture description -%} <a target="_blank" href="/admin/insites/#/crm/contacts/{{ form.id }}">{{ current_user_name  | default: form.email }}</a> has submitted  a registration for <a target="_blank" href="/admin/insites#/crm/companies/{{ form.properties.company_uuid }}">{{ form.properties.company_name }}</a> {%- endcapture -%}
    {%- assign payload = '{}' | parse_json -%}
    {%- assign payload = payload | add_hash_key: "description", description -%}
    {%- assign payload = payload | add_hash_key: "font_icon", "icon-completed-outcomes" -%}
    {%- assign payload = payload | add_hash_key: "font_icon_color", "#289AFF" -%}
    {%- assign payload = payload | add_hash_key: "administrator_uuid", user_details.uuid  -%}


    {% capture log_info %}
    {
      "action": "create_account",
      "data": {
        "items": {
          "first_name": "{{ form.first_name }}",
          "last_name": "{{ form.last_name }}",
          "email": "{{ form.email }}",
          "mobile_phone_country_code": "{{ form.properties.mobile_phone_country_code }}",
          "mobile_phone_number": "{{ form.properties.mobile_phone_number }}",
          "contact_address":{
            "address_1": "{{ form.properties.address_1 }}",
            "address_2": "{{ form.properties.address_2 }}",
            "suburb": "{{ form.properties.suburb }}",
            "state": "{{ form.properties.state }}",
            "postcode": "{{ form.properties.postcode }}",
            "country": "{{ form.properties.country }}"
          },
          "company":{
            "company_name": "{{ form.properties.company_name }}",
            "registered_business_number": "{{ form.properties.registered_business_number }}",
            "email_1": "{{ form.properties.email_1 }}",
            "mobile_phone_country_code": "{{ form.properties.company_mobile_phone_country_code }}",
            "mobile_phone_number": "{{ form.properties.company_mobile_phone_number }}"
          },
          "company_address":{
            "address_1": "{{ form.properties.company_address_1 }}",
            "address_2": "{{ form.properties.company_address_2 }}",
            "suburb": "{{ form.properties.company_suburb }}",
            "state": "{{ form.properties.company_state }}",
            "postcode": "{{ form.properties.company_postcode }}",
            "country": "{{ form.properties.company_country }}"
          },
          "contact_uuid": "{{ user_details.uuid }}"   
        }
      }
    }
    {% endcapture %}
    {%- assign log_info_json = log_info | parse_json -%}
    {%- assign info = payload | add_hash_key: "log", log_info_json -%}
    {% include 'modules/portal/events/log_event', info %}
---

{%- form 
    html-id: "register-form"
    html-class: 'insites-form insites-form-code' 
    html-novalidate: true
    html-enctype="multipart/form-data"
    html-onsubmit:"return Session.events.signUpHandler(event, 'personal-details-container');" -%}

  <div class="insites-form-grid">
  
  {% if context.params.email %}
    {% include 'modules/portal/account/registration_personal_details', email: context.params.email %}
  {% else %}
    {% include 'modules/portal/account/registration_personal_details' %}  
  {% endif %}
  

  {% include 'modules/portal/account/registration_company_details' %}

  {% include 'modules/portal/account/registration_confirmation' %}
            
  </div>

{%- endform -%}