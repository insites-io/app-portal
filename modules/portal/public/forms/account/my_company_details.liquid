---
name: my_company_details
resource: modules/insites_core/crm_company
resource_owner: anyone
flash_alert: Error-Company-Details
flash_notice: Success-Company-Details
redirect_to: my-company-details
fields:  
  properties:
    #CRM Company Fields
    email_1:
      validation: 
        presence:
          message: Company email is required
        email: 
          message: Please use a valid email address     
    company_name:
      validation: 
        presence: 
          message: Company name is required
    registered_business_number:
      validation: 
        presence: 
          message: Company registration number is required          
    mobile_phone_number:
    mobile_phone_country_code:

    #CRM Address (Company) Fields
    company_address_1:
      validation: 
        presence: 
          message: Address 1 is required
      property_options:
        virtual: true
    company_address_2:
      property_options:
        virtual: true
    company_suburb:
      validation: 
        presence: 
          message: Suburb is required
      property_options:
        virtual: true
    company_state:
      validation: 
        presence: 
          message: State is required
      property_options:
        virtual: true
    company_postcode:
      validation: 
        presence: 
          message: Postcode is required
      property_options:
        virtual: true
    company_country:
      validation: 
        presence: 
          message: Country is required
      property_options:
        virtual: true    
    company_uuid:
      property_options:
        virtual: true
    company_address_uuid:
      property_options:
        virtual: true
    company_latitude:
      property_options:
        virtual: true
    company_longitude:
      property_options:
        virtual: true
callback_actions: |-
  {% comment %} 
    The form itself will update the CRM_Company only
    Update the company address using API
      If company already exist
        - use API to update_company_address only
      Else
        - use API to add_company (this will update the address also)
  {% endcomment %}
  {%  liquid                  
      assign data = form | json

      if form.properties.company_address_uuid != '' and form.properties.company_address_uuid != null
        graphql update_company_address = 'modules/website/trigger_api_call', name: 'modules/portal/update_company_address', data: data | dig: 'items','response','body' | parse_json
        assign company_uuid = form.properties.company_uuid
      else
        graphql add_company = 'modules/website/trigger_api_call', name: 'modules/portal/add_company', data: data | dig: 'items','response','body' | parse_json
        assign company_uuid = add_company.items.properties.uuid
      endif

  %}   
async_callback_actions:
  delay: 0
  priority: low
  max_attempts: 2
  content: |-
    {% comment %} Create Event Stream {% endcomment %}
    {%- graphql user = "modules/portal/account/get_user_by_email" 
    email: context.current_user.email 
    | dig: "items" | dig: "results" | first -%}
    {%- assign crm_contact = user.crm_contact | first -%}
    {%- assign current_user_name =  context.current_user.first_name | append: ' ' | append: context.current_user.last_name | default: context.current_user.email -%}
    {%- capture description -%}<a target="_blank" href="/admin/insites/#/crm/contacts/{{ context.current_user.id }}">{{ current_user_name  | default: context.current_user.email }}</a> updated their company details - <a target="_blank" href="/admin/insites#/crm/companies/{{ crm_contact.company_uuid }}">{{ crm_contact.company.company_name }}</a>{%- endcapture -%}
    {%- assign payload = '{}' | parse_json -%}
    {%- assign payload = payload | add_hash_key: "description", description -%}
    {%- assign payload = payload | add_hash_key: "font_icon", "icon-company-added" -%}
    {%- assign payload = payload | add_hash_key: "font_icon_color", "#60A5E5" -%}

    {% capture log_info %}
      {
          "user": {
            "id": "{{ context.current_user.id }}",
            "email": "{{ context.current_user.email }}",
            "first_name": "{{ context.current_user.first_name }}",
            "last_name": "{{ context.current_user.last_name }}"
          },
          "company":{
            "company_name": "{{ form.properties.company_name }}",
            "registered_business_number": "{{ form.properties.registered_business_number }}",
            "email_1": "{{ form.properties.email_1 }}",
            "mobile_phone_country_code": "{{ form.properties.mobile_phone_country_code }}",
            "mobile_phone_number": "{{ form.properties.mobile_phone_number }}"
          },
          "company_address":{
            "address_1": "{{ form.properties.company_address_1 }}",
            "address_2": "{{ form.properties.company_address_2 }}",
            "suburb": "{{ form.properties.company_suburb }}",
            "state": "{{ form.properties.company_state }}",
            "postcode": "{{ form.properties.company_postcode }}",
            "country": "{{ form.properties.company_country }}"
          },
          "contact_uuid": "{{ context.current_user.external_id }}"      
      }
    {% endcapture %}
    {%- assign log_info_json = log_info | parse_json -%}
    {%- assign info = payload | add_hash_key: "log", log_info_json -%}
    {% include 'modules/portal/events/log_event', info %}
---
{%- form 
    html-id: "my-company-details-form"
    html-class: 'insites-form insites-form-code' 
    html-novalidate: true
    html-onsubmit:"return validateMyCompanyDetails(event);" -%}

    <input type="hidden" name="{{ form.fields.properties.company_uuid.name }}"  value="{{ data.uuid }}" >
    <input type="hidden" name="{{ form.fields.properties.company_address_uuid.name }}" value="{{ data.default_address.uuid }}" >

    <div class="insites-form-grid">
      {% include 'modules/portal/account/registration_company_details', data: data %}
    </div>

{%- endform -%}