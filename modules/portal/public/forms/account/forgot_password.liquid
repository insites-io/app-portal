---
name: forgot_password
resource: modules/portal/reset_password
resource_owner: anyone
redirect_to: /forgot-password
flash_notice: If you provided the right email, we will send you reset password instructions.
fields:
  properties:
    email:
      validation:
        presence: true
        email: true
callback_actions: |-
  {% graphql generated_token = 'modules/portal/account/generate_user_temporary_token', email: form.properties.email | dig: 'items', 'results' | first %}
  {% if generated_token %}
    {% graphql res = 'modules/portal/account/update_password_token', id: generated_token.id, token: generated_token.temporary_token %}
  {% endif %}
async_callback_actions:
  delay: 0
  priority: low
  max_attempts: 2
  content: |-
    {% comment %} Create Event Stream {% endcomment %}
    {%- graphql user = "modules/portal/account/get_user_by_email" 
        email: form.properties.email
        | dig: "items" | dig: "results" | first -%}
    {%  assign crm_contact = user.crm_contact | first %}
    {%- assign current_user_name =  user.first_name | append: ' ' | append: user.last_name | default: user.email -%}
    {%- capture description -%}<a target="_blank" href="/admin/insites/#/crm/contacts/{{ user.id }}">{{ current_user_name  | default: user.email }}</a> from <a target="_blank" href="/admin/insites#/crm/companies/{{ crm_contact.company_uuid }}">{{ crm_contact.company.company_name }}</a> requested a password reset{%- endcapture -%}
    {%- assign payload = '{}' | parse_json -%}
    {%- assign payload = payload | add_hash_key: "description", description -%}
    {%- assign payload = payload | add_hash_key: "font_icon", "icon-email-1" -%}
    {%- assign payload = payload | add_hash_key: "font_icon_color", "#DA8C60" -%}
    {%- assign payload = payload | add_hash_key: "administrator_uuid", user.uuid  -%}


    {% capture log_info %}
    {
      "action": "forgot_password",
      "data": {
        "items": { 
          "user": {
            "id": "{{ user.id }}",
            "email": "{{ user.email }}",
            "first_name": "{{ user.first_name }}",
            "last_name": "{{ user.last_name }}"
          },
          "contact_uuid": "{{ user.uuid }}"
        }
      }
    }
    {% endcapture %}

    {%- assign log_info_json = log_info | parse_json -%}
    {%- assign info = payload | add_hash_key: "log", log_info_json -%}
    {% include 'modules/portal/events/log_event', info %}
---
  
{%- form 
  html-id: "forgot-password-form"
  html-novalidate: true
  html-enctype="multipart/form-data"
  html-onsubmit:"return LoginScript.methods.validateForm(event);" -%}

  <div class="grid-x grid-padding-x">
    <div class="small-12 cell">
      <ins-input validate
        id="email"
        label="Email*"
        field="email"
        name="{{ form.fields.properties.email.name }}" 
        value="{{ form.fields.properties.email.value }}" 
        {% if form.errors['properties.email'] %} has-error {% endif %}
        placeholder="Email">
      </ins-input>
      <span id="emailRequired" class="user-error-txt-red body-x-small is_hidden">Email is required.</span>
      <span id="emailInvalid" class="user-error-txt-red body-x-small is_hidden">Please enter a valid email.</span>
    </div>
    <div class="small-12 cell spacer x-large"></div>
    <div class="small-12 cell text-center">
      <ins-button id="submit-btn" class="full" label="Send reset instructions" solid color="blue" type="submit" ></ins-button>
    </div>
    <div class="small-12 cell spacer x-large"></div>
    <div class="small-12 cell"> 
      Back to <a class="a-label-no-visit" href="/sign-in">sign in.</a>
    </div>
  </div>
    

{%- endform -%}

<script>
    // VALIDATE EMAIL
    let submitBtn = document.getElementById("submit-btn");
    let email = document.getElementById("email");

    submitBtn.addEventListener("click", function(){
        var is_email_valid = true
      var requiredEmail = document.getElementById("emailRequired");
      var emailInvalid = document.getElementById("emailInvalid")
      requiredEmail.classList.add('is_hidden');
      emailInvalid.classList.add('is_hidden');

      if(email.value == '') {
          requiredEmail.classList.add('is_visible');
          requiredEmail.classList.remove('is_hidden');
      } else {
          is_email_valid = isValidEmail(email.value); // no "this."
          if(is_email_valid == false){ 
              emailInvalid.classList.add('is_visible');
              emailInvalid.classList.remove('is_hidden');
          }
      }

    })


    function isValidEmail(email) {
      const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return re.test(email);
    }

</script>