---
name: update_order
to: 'https://{{context.location.host}}/ecommerce/api/v1/orders'
format: http
request_type: PUT
callback: >
  {% assign response_hash = response.body | parse_json %}
request_headers: >
    {% include 'modules/portal/api_headers' %}
---

{%- 
    liquid 

    assign api_data = '{}' | parse_json
    assign payload = '{}' | parse_json

    if data.id 
        assign payload = payload | add_hash_key: 'id', data.id
    endif
    if data.order_reference
        assign payload = payload | add_hash_key: 'order_reference', data.order_reference
    endif
    if data.date_time 
        assign payload = payload | add_hash_key: 'date_time', data.date_time
    endif
    if data.order_status 
        assign payload = payload | add_hash_key: 'order_status', data.order_status
    endif
    if data.order_payment_status 
        assign payload = payload | add_hash_key: 'order_payment_status', data.order_payment_status
    endif
    if data.order_first_name 
        assign payload = payload | add_hash_key: 'order_contact_first_name', data.order_first_name
    endif
    if data.order_last_name 
        assign payload = payload | add_hash_key: 'order_contact_last_name', data.order_last_name
    endif
    if data.order_email
        assign payload = payload | add_hash_key: 'order_contact_email', data.order_email
    endif
    if data.order_phone
        assign payload = payload | add_hash_key: 'order_company_phone_number', data.order_phone
    endif
    if data.currency 
        assign payload = payload | add_hash_key: 'currency', data.currency
    endif
    if data.order_value 
        assign payload = payload | add_hash_key: 'subtotal_amount', data.order_value
    endif
    if data.total_tax_amount
        assign temp_total_tax_amount = data.total_tax_amount | times: 1.0
        assign payload = payload | add_hash_key: 'total_tax_amount', temp_total_tax_amount
    endif
    if data.total_shipping_amount
        assign temp_total_shipping_amount = data.total_shipping_amount | times: 1.9
        assign payload = payload | add_hash_key: 'total_shipping_amount', temp_total_shipping_amount
    endif
    if data.total_amount
        assign temp_total_amount = data.total_amount | times: 1.0
        assign payload = payload | add_hash_key: 'total_amount', temp_total_amount
    endif
    if data.total_amount
        assign temp_total_amount = data.total_amount | times: 1.0
        assign payload = payload | add_hash_key: 'total_amount_paid', temp_total_amount
    endif
    if data.total_discount_amount
        assign temp_total_discount_amount = data.total_discount_amount | times: 1.0 | default: 0.0
        assign payload = payload | add_hash_key: 'total_discount_amount', temp_total_discount_amount
    endif
    if data.shipping_company_name
        assign payload = payload | add_hash_key: 'shipping_company_name', data.shipping_company_name
    endif
    if data.billing_company_name
        assign payload = payload | add_hash_key: 'billing_company_name', data.billing_company_name
    endif

    assign api_data = api_data | add_hash_key: 'payload', payload

-%}
{%- log api_data, type: "Update Order API Payload" -%}
{{ api_data }}
