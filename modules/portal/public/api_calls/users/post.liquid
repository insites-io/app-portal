---
name: add_crm_via_invite_user
to: 'https://{{context.location.host}}/core/api/v1/contacts'
format: http
enabled: true
trigger_condition: true
request_type: POST
callback: >
    {% assign response_hash = response.body | parse_json %}
    {% graphql get_user_custom_field = "modules/portal/users/get_user_custom_field", contact_uuid:  response_hash.items.uuid | dig: 'records', 'results' %}
    
    # Check if Custom field exist 
    {%  if get_user_custom_field.size > 0 %}  
        {%  assign user_custom_field =  get_user_custom_field | first %}
        {%  assign user_custom_field_id = user_custom_field.id %}
        {% graphql update_user_custom_field = "modules/portal/account/update_user_custom_field", id: user_custom_field_id, permission_level: data.permission_level %}
    {% else %}
        {% graphql create_contact_custom_field = "modules/portal/account/create_contact_custom_field", contact_uuid: response_hash.items.uuid, permission_level: data.permission_level %}
    {% endif %}

request_headers: >
    {% include 'modules/website/api_headers' %}
---
{
    "first_name": "{{ data.first_name }} ",
    "last_name": "{{ data.last_name }} ",
    "email": "{{ data.email }}",
    "company_uuid": "{{ data.company_uuid }}",
    "work_phone_country_code": "{{ data.mobile_phone_country_code }}",
    "work_phone_number": "{{ data.mobile_phone_number }}"
}