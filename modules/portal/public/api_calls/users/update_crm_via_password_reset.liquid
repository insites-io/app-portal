---
name: update_crm_via_password_reset
to: 'https://{{context.location.host}}/crm/api/v2/contacts/{{data.uuid}}'
format: http
enabled: true
trigger_condition: true
request_type: PUT
callback: >
    {% assign response_hash = response.body | parse_json %}
    # Generate user temporary token
    {%  graphql temporary_token = 'modules/portal/account/generate_user_temporary_token', email: data.email | dig: 'items', 'results' | first %}
    {% graphql update_portal_profile = 'modules/portal/account/update_portal_profile', id: data.id,  permission_level:  data.permission_level, token: temporary_token.temporary_token, is_enabled: true, invitation_status: data.invitation_status  %}
request_headers: >
    {% include 'modules/website/api_headers' %}
---
{{ data }}