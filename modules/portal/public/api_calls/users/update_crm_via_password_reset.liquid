---
name: update_crm_via_password_reset
to: 'https://{{context.location.host}}/crm/api/v2/contacts/{{data.uuid}}'
format: http
enabled: true
trigger_condition: true
request_type: PUT
callback: >
    {% assign response_hash = response.body | parse_json %}
    {% graphql update_portal_profile = 'modules/portal/account/update_portal_profile', id: data.id,  permission_level:  data.permission_level, is_enabled: true, invitation_status: data.invitation_status  %}
request_headers: >
    {% include 'modules/website/api_headers' %}
---
{
    "id": "{{ data.id }}",
    "email": "{{ data.email }}", 
    "company_uuid": "{{ data.company_uuid }}"
}