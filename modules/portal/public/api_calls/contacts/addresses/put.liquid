---
name: update_contact_address
to: 'https://{{context.location.host}}/crm/api/v2/contacts/addresses/{{ data.properties.contact_address_uuid }}'
format: http
request_type: PUT
request_headers: >
    {% include 'modules/portal/api_headers' %}
---
{%- assign props = data.properties -%}
{
    "address_label": "{{ props.address_1 }}",
    "address_1": "{{ props.address_1 }}",
    "address_2": "{{ props.address_2 }}",
    "suburb": "{{ props.suburb }}",
    "state": "{{ props.state }}",    
    "postcode": "{{ props.postcode }}",
    "country": "{{ props.country }}",
    "latitude": "{{ props.latitude }}",
    "longitude": "{{ props.longitude }}"
}