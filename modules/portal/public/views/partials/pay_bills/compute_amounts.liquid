---
metadata: {
    partial_name: 'Portal | Paybills | Compute amounts'
}
---

{% comment %} Payload: total_amount {% endcomment %}

{%  liquid
    assign amount = subtotal_amount
    assign cc_surcharge = amount | times: 0.017
    assign tax = total_tax_amount 
    assign total_amount = amount | plus: cc_surcharge | plus: tax
%}

{% parse_json computed %}
{
    "amount": {{ amount }},
    "cc_surcharge": {{ cc_surcharge }},
    "total_amount": {{ total_amount }},
    "tax": {{ tax }}
}
{% endparse_json %}

{% liquid return computed %}