---
metadata: {
    partial_name: 'Portal | Emails | Log event'
}
---

{%- parse_json data -%}
{
    "font_icon": "{{ info.font_icon | default: "icon-info" }}",
    "font_icon_color": "{{ info.font_icon_color | default: "#451278" }}",
    "details": "{{ info.details | default: "" }}"   
}
{%- endparse_json -%}

{%- assign data = data | add_hash_key: "log", info.log -%}
{%- assign data = data | add_hash_key: "description", info.description | default: "" -%}
{%- assign data = data | add_hash_key: "module_source",  "insites_databases" -%}
{%- assign data = data | add_hash_key: "module_feature", "database_items" -%}
{%- assign data = data | add_hash_key: "request_type", "internal" -%}
{%- assign data = data | add_hash_key: "administrator_uuid", info.administrator_uuid  -%}

{% function add_events = "crm/controller/event-streams/create", params: data %}