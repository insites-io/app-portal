---
metadata: {
    partial_name: 'Portal | Users | Invite User Event Stream'
}
---
{% comment %} Create Event Stream {% endcomment %}
{%- graphql user = "modules/portal/account/get_user_by_email" 
    email: context.current_user.email | dig: "items" | dig: "results" | first -%}
{%- graphql user_invited = "modules/portal/account/get_user_by_email" 
    email: data.email | dig: "items" | dig: "results" | first -%}
{%- assign crm_contact = user.crm_contact | first -%}
{%- assign current_user_name = user.first_name | append: ' ' | append: user.last_name | default: user.email -%}
{%- assign invited_user_name = user_invited.first_name | append: ' ' | append: user_invited.last_name | default: user_invited.email -%}
{%- assign payload = '{}' | parse_json -%}
{% if data.actions != "change_permission_level"  %}
    {%- capture description -%}
        <a target="_blank" href="/admin/insites/#/crm/contacts/{{ user.id }}">{{ current_user_name | default: user.email }}</a> 
        invited
        <a target="_blank" href="/admin/insites/#/crm/contacts/{{ user_invited.id }}">{{ invited_user_name | default: user.email }}</a> 
        to join
        <a target="_blank" href="/admin/insites#/crm/companies/{{ crm_contact.company_uuid }}">{{ crm_contact.company.company_name }}</a> 
    {%- endcapture -%}
    {%- assign payload = payload | add_hash_key: "font_icon", "icon-user-plus" -%}
    {% assign action = "user_invite" %}
{% else %}
      {% if data.permission_level != "No Access" %}
        {%- capture description -%}
            <a target="_blank" href="/admin/insites/#/crm/contacts/{{ user.id }}">{{ current_user_name | default: user.email }}</a> 
            from
            <a target="_blank" href="/admin/insites#/crm/companies/{{ crm_contact.company_uuid }}">{{ crm_contact.company.company_name }}</a> 
            granted
            <a target="_blank" href="/admin/insites/#/crm/contacts/{{ user_invited.id }}">{{ invited_user_name | default: user.email }}</a> 
            the role of {{ data.permission_level }}         
        {%- endcapture -%}
        {%- assign payload = payload | add_hash_key: "font_icon", "icon-user-check" -%}
        {% assign action = "update_user_permission" %}
      {% else %}
        {%- capture description -%}
            <a target="_blank" href="/admin/insites/#/crm/contacts/{{ user.id }}">{{ current_user_name | default: user.email }}</a> 
            from
            <a target="_blank" href="/admin/insites#/crm/companies/{{ crm_contact.company_uuid }}">{{ crm_contact.company.company_name }}</a> 
            revoked access for
            <a target="_blank" href="/admin/insites/#/crm/contacts/{{ user_invited.id }}">{{ invited_user_name | default: user.email }}</a>          
        {%- endcapture -%}
        {%- assign payload = payload | add_hash_key: "font_icon", "icon-user-minus" -%}
        {% assign action = "revoke_user_access" %}
      {% endif %}  
{% endif %}


{%- assign payload = payload | add_hash_key: "description", description -%}
{%- assign payload = payload | add_hash_key: "font_icon_color", "#E1B000" -%}
{%- assign payload = payload | add_hash_key: "administrator_uuid", context.current_user.external_id  -%}

{% capture log_info -%}
{
    "action": "{{ action }}",
    "data": {
        "items": {
            "contact": {
                "id": "{{ user_invited.id }}",
                "email": "{{ user_invited.email }}",
                "first_name": "{{ user_invited.first_name }}",
                "last_name": "{{ user_invited.last_name }}"
            },
            "contact_uuid": "{{ user_invited.uuid }}"
        }
    }
}
{%- endcapture %}

{% log log_info %}

{%- assign log_info_json = log_info | parse_json -%}
{%- assign info = payload | add_hash_key: "log", log_info_json -%}
{% include 'modules/portal/events/log_event', info %}
