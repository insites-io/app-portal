---
metadata: {
    partial_name: 'Portal | Account | Registration steps'
}
---

{%- liquid

    if context.flash.notice != blank
        assign statusPersonal = "complete"
        assign statusCompany = "complete"
        assign statusConfirmation = "complete"
        assign statusVerify = "complete"
    endif

-%}

<div class="form-groups-tab step-scrollbar">        
    <ins-steps inline id="register-stepper" class="hide-for-small-only">
        <ins-step id="stepper-personal-details" description="Personal" {{statusPersonal}} ></ins-step>
        <ins-step id="stepper-company-details" description="Company" {{statusCompany}} ></ins-step>
        <ins-step id="stepper-confirmation" description="Terms" {{statusConfirmation}} ></ins-step>
    </ins-steps>

    <ins-steps id="register-stepper" class="show-for-small-only">
        <ins-step id="stepper-personal-details" description="Personal" {{statusPersonal}} ></ins-step>
        <ins-step id="stepper-company-details" description="Company" {{statusCompany}} ></ins-step>
        <ins-step id="stepper-confirmation" description="Terms" {{statusConfirmation}} ></ins-step>
    </ins-steps>
</div>