---
metadata: {
    partial_name: 'Portal | Stripe | Payments | Checkout payment paybill'
}
---

{%- assign stripe_customer_id = blank -%}
{%- assign company_id = company_id | default: blank -%}
{%- assign company_name = company_name | default: blank -%}
{%- assign charge_to_this_card = false -%}

{% if context.current_user %}
    {%- assign customer_email = context.current_user.email | strip -%}
    {%- assign customer_name = context.current_user.first_name | append: ' ' | append: context.current_user.last_name -%}
{% else %}
    {%- assign customer_email = form.properties.email | strip -%}
    {%- assign customer_name = form.properties.first_name | append: ' ' | append: form.properties.last_name -%}
{% endif %}

{%- comment -%} STEP 1: Stripe Customer  {%- endcomment -%}
{%- graphql stripe_customer = "modules/portal/customers/get_customer_model" 
    email: customer_email,
    gateway_name: "Stripe" 
    | dig: "items" | dig: "results" | first -%}

{% comment %} NOTE: Get CRM -> Contact via Controller {% endcomment %}
{% assign contact_uuid = context.current_user.external_id %}
{% function contact = "crm/controller/contacts/get", uuid: contact_uuid %}

{% comment %} if stripe_customer.id {% endcomment %}
{% if contact.id %}
    {%- comment -%}Step 1-A: Customer Stripe data exist. Proceed payment process {%- endcomment -%}

    {%- comment -%}Step 1-A.1: Get updated 'user' data{%- endcomment -%}
    {%- graphql user = "modules/portal/account/get_user_by_email" 
        email: customer_email
        | dig: "items" | dig: "results" | first -%}
    
    {%- assign customer_model_id = stripe_customer.id | downcase -%}
    {%- assign user_id = user.id -%}

    {%- comment -%}Step 1-A.2: Update customer model data{%- endcomment -%}
    {%- graphql customer_model = "modules/portal/customers/update_customer_model", 
        id: customer_model_id
        user_id: user_id,
        name: customer_name | dig: "items" -%}
    
    {%- comment -%}Step 1-A.3: Customer Stripe data exist. Proceed create stripe credit card {%- endcomment -%}
    {%- assign stripe_customer_id = customer_model.properties.payment_method_token -%}

    {%- assign check_new = form.properties.stripe_credit_card | split: '_' | first | downcase -%}
    {% if check_new == 'tok' %}
        {%- comment -%}Create new card object payload {%- endcomment -%}
        {% parse_json stripe_card %}
        {
            "customer_id": "{{ stripe_customer_id }}",
            "source": "{{ form.properties.stripe_credit_card }}"
        }
        {% endparse_json %}
        {%- comment -%}Create new card on Stripe API {%- endcomment -%}
        
        {%- capture charge_to_this_card -%}
            {% if user_id %}
                {%- assign bind_card_user_id = user_id | default: blank -%}
            {% endif %}
            {%- include 'modules/portal/stripe/credit_cards/create_credit_card', 
                stripe_card: stripe_card,
                user_id: bind_card_user_id
                return: true -%}
        {%- endcapture -%}
        {%- assign charge_to_this_card = charge_to_this_card | strip_newlines | strip -%}
    {% elsif check_new == 'card' %}
        {%- assign charge_to_this_card = form.properties.stripe_credit_card -%}
    {% endif %}
    {%- comment -%}Proceed to Step 2: Payment {%- endcomment -%}
{% else %}
    {%- assign charge_to_this_card = form.properties.stripe_credit_card -%}
    {%- comment -%}Step 1-B: New customer: Create Stripe customer data{%- endcomment -%}
    
{% endif %}

{% comment %} 
    GET STRIPE ID
 {% endcomment %}

 {%- graphql user_stripe_id = 'modules/portal/customers/get_user_stripe_id', email: customer_email | dig: 'items','results' | first -%}

 {% assign get_stripe_id = user_stripe_id | dig: 'profiles' | first %}

{% comment %} Compute amounts {% endcomment %}
{% assign amount = form.properties.total_amount | times: 100 %}

{% comment %} GET STRIPE SETTINGS {% endcomment %}
{% function get_stripe_settings = "modules/portal/stripe/get_stripe_settings" %}

{%- comment -%} STEP 2: Stripe Charge / Payment  {%- endcomment -%}
{% parse_json "create_charge" %}
{
    "idempotency_key": "{{ '' | uuid }}",
    "currency": "AUD",
    "amount": "{{ amount | advanced_format: '%.0f' }}",
    "customer": "{{ get_stripe_id.stripe_id }}",
    {% if charge_to_this_card contains 'card_' %}
            "source": "{{ charge_to_this_card }}",
    {% endif %}
    "description": "Insites Order ID: {{ form.id }} (Insites Customer ID: {{ user.uuid }})",
    "metadata": {
        "Insites Order ID": "{{ form.id }}",
        "Insites Customer ID": "{{ user_id }}",
        "Insites Company ID": "{{ company_id }}",
        "Insites Company Name": "{{ company_name }}",
        "Insites Order": "https://{{ context.location.host }}/admin/insites#/ecommerce/edit-order/{{ form.id }}"
    },
    "statement_descriptor": "{{ form.properties.statement_descriptor }}",
    "sk_key": "{{ get_stripe_settings.sk_key }}",
    "stripe_account_id": "{{ get_stripe_settings.account_id }}",
    "sk_key_insites": "{{ get_stripe_settings.sk_key_insites }}"
}
{% endparse_json %}

{% graphql stripe_create_charge = 'modules/website/trigger_api_call', 
    name: "modules/portal/create_charge",
    data: create_charge 
    | dig: "items" | dig: "response" %}   

{%- assign stripe_create_charge = stripe_create_charge.body | parse_json -%}

{%- assign payment_response = stripe_create_charge -%}

{% export payment_response %}
