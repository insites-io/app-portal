---
metadata: {
    partial_name: 'Portal | Stripe | Credit cards | Create credit card'
}
---

{% graphql stripe_create_card = 'modules/website/trigger_api_call', name: "modules/portal/create_card",
    data: stripe_card | dig: 'items' | dig: 'response' %}

    {% log stripe_create_card, type: 'stripe_create_card' %}
    {%- assign stripe_response = stripe_create_card.body | parse_json -%}
    {% parse_json credit_card %}
    {
        "uuid": "{{ '' | uuid }}",
        "currency": "",
        "bank_name": "",
        "card_brand":  "{{ stripe_response.brand }}",
        "company_uuid": "",
        "contact_uuid": "{{ stripe_card.contact_uuid }}",
        "bank_account_bsb": "",
        "card_expiry_year": "{{ stripe_response.exp_year }}",
        "bank_account_name": "",
        "card_expiry_month": " {{ stripe_response.exp_month }}",
        "payment_method_name": "Stripe",
        "payment_method_token":  "{{ stripe_response.id }}",
        "card_last_four_digits": "{{ stripe_response.last4 }}",
        "bank_account_last_four_digits": ""
    }
    {% endparse_json %}
    {% log credit_card , type: 'credit_card' %}
    {% comment %} Create pOS credit card model {% endcomment %}
    {% graphql card_model = "modules/portal/credit_cards/create_credit_card" args: credit_card  %}
    {% log card_model, type: 'card_model' %}

{%- comment -%}Return Stripe Card ID{%- endcomment -%}
{% export stripe_response %}