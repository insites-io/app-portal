---
metadata: {
    partial_name: 'Portal | Stripe | Get stripe settings'
}
---

{%  liquid
    graphql get_stripe_settings = 'modules/website/trigger_api_call', name: 'modules/portal/get_stripe_settings' 

    assign response = get_stripe_settings.items.response.body | parse_json 

    # Insites SK Key must be added via Constants - For Stipe Connect
    if response.livemode
        assign pk_key = response.pk_live_key
        assign sk_key = response.sk_live_key
        assign sk_key_insites = context.constants.insites_stripe_sk_live_key
    else
        assign pk_key = response.pk_test_key
        assign sk_key = response.sk_test_key
        assign sk_key_insites = context.constants.insites_stripe_sk_test_key
    endif      
%}

