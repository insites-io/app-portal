---
slug: generate-password-token
layout: application
max_deep_level: 3
authorization_policies:
metadata: {
    page_name: "API - generate password token",
}
--- 

{%  liquid  

    if params.reset == "true"
        # For reset password if not logged in
        assign email = params.email
    else 
        # For reset password if logged in
        assign email = context.current_user.email
    endif
    
    graphql generated_token = 'modules/portal/account/generate_user_temporary_token', email: email | dig: 'items', 'results' | first

    if generated_token
    graphql res = 'modules/portal/account/update_password_token', id: generated_token.id, token: generated_token.temporary_token
    endif

    graphql user_with_token = 'modules/portal/account/get_user_with_password_token', email: email | dig: 'users','results' | first 
    assign user_data_default = user_with_token.default | first
    assign token = user_data_default.password_token | url_encode 
    assign encode_email = email | base64_url_safe_encode
    assign url = '/password-reset?token=' |  append: token | append: '&email=' |  append: encode_email
    
    redirect_to url
%}