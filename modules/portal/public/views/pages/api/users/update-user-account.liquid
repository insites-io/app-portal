---
slug: api/update-user-account
method: post
searchable: false
layout: application
max_deep_level: 3
authorization_policies:
metadata: {
    page_name: "API | Users | Update User Account",
}
--- 
{% assign details = context.params %}
{% comment %} ? Catch email with + {% endcomment %}
{%- assign email = details.email | replace: " ", "+" -%}
{% if details.actions == "change_permission_level" %}
    {% comment %} ? ACTION == user TOGGLE {% endcomment %}
    
    {% comment %} ? SET TOKEN PASSWORD FOR INVITED{% endcomment %}
    {%  liquid
        graphql generated_token = 'modules/portal/account/generate_user_temporary_token', email: email | dig: 'items', 'results' | first
        if generated_token
            graphql set_profile = 'modules/portal/users/set_profile_to_invited_users', id: generated_token.id, token: generated_token.temporary_token, company_uuid: details.company_uuid
            graphql set_password_token = 'modules/portal/users/set_password_token_to_invited_users', id: generated_token.id, token: generated_token.temporary_token
        endif
    %}

    {%- graphql user_with_token = 'modules/portal/account/get_user_with_password_token', email: email | dig: 'users','results' | first -%}
    {%- assign user_data_default = user_with_token.default | first -%}

    {% comment %} ? EMAIL NOTIF {% endcomment %}
    {% if details.permission_level != "No Access" %}
        {%- assign user_invitation = "modules/portal/user_invitation" -%}
        {% parse_json data %}
        {
            "email": "{{ email }}",
            "name": "{{ details.name }}",
            "company": "{{ details.company }}",
            "password_token": "{{ user_data_default.password_token }}",
            "company_uuid": "{{ details.company_uuid }}",
            "permission_level": "{{ details.permission_level }}"
        }
        {% endparse_json %}
        {% comment %} {%- graphql trigger = "modules/website/trigger_email_notification", name: user_invitation, data: data -%} {% endcomment %}
    {% endif %}
    
    {% if details.permission_level  != "No Access" %}
        {% graphql update_portal_profile = 'modules/portal/account/update_portal_profile', id: user_with_token.id, invitation_status: "", permission_level: details.permission_level   %}
    {% else %}
        {% graphql update_portal_profile = 'modules/portal/account/update_portal_profile', id: user_with_token.id,  invitation_status: "", permission_level: "No Access"  %}
    {% endif %}

{% else %}
    {% comment %} ? ACTION == ADD user {% endcomment %}
    {% if details.is_email_found == "false" %}
        {% assign is_email_found = false %}
    {% else %}
        {% assign is_email_found = true %} 
    {% endif %}

    {% if is_email_found == true %}
        {%- graphql user_details = "modules/portal/account/get_user_by_email" 
        email: email
        | dig: "items" | dig: "results" | first -%}

        {% comment %} ? UPDATE CRM {% endcomment %}
        {% parse_json update_crm_data %}
        {
            "id": "{{ details.user_id }}",
            "first_name": "{{ details.userFirstName }}",
            "last_name": "{{ details.userLastName }}",
            "email": "{{ email }}",
            "work_phone_country_code": "{{ details.mobile_phone_country_code | default: 61 }}",
            "work_phone_number": "{{ details.mobile_phone_number }}",
            "permission_level": "{{ details.userPermission }}",
            "company": "{{ details.company }}"
        }
        {% endparse_json %}
        {% comment %} ? UPDATE CRM FIRST {% endcomment %}
        {% comment %} NOTE: Update CRM -> Contact via Controller {% endcomment %}
        {% function update_crm_contact = "crm/controller/contacts/update", uuid: user_details.uuid, params: update_crm_data %}
        {% comment %} LOG: {% endcomment %}
        {% log update_crm_contact, type: "update_crm_contact - update_user_account" %}
        
        {% graphql update_portal_profile = 'modules/portal/account/update_portal_profile', id: details.user_id,  invitation_status: "Invited"  %}
    {% else %}
        {% comment %} ? SAVE NEW CRM {% endcomment %}
        {% parse_json add_crm_data %}
        {
            "first_name": "{{ details.userFirstName }}",
            "last_name": "{{ details.userLastName }}",
            "email": "{{ email }}",
            "work_phone_country_code": "{{ details.mobile_phone_country_code | default: 61 }}",
            "work_phone_number": "{{ details.mobile_phone_number }}",
            "permission_level": "{{ details.userPermission }}",
            "company": "{{ details.company }}"
        }
        {% endparse_json %}

        {% comment %} ? ADD CRM FIRST {% endcomment %}
        {% comment %} NOTE: Create CRM -> Contact via Controller {% endcomment %}
        {% function add_contact = "crm/controller/contacts/create", params: add_crm_data %}

    {% graphql add_portal_profile = 'modules/portal/account/create_user_profile', id: add_contact.id, token: "", invitation_status: "Invited", permission_level: details.permission_level, is_enabled: false  %}

    {% endif %}   
    {% comment %} ? CLOSING ENDIF FOR INVITE user - EMAIL EXISTS OR NOT {% endcomment %}

    {% comment %} ? SET TOKEN PASSWORD FOR INVITED user {% endcomment %}
    {%  liquid
        graphql generated_token = 'modules/portal/account/generate_user_temporary_token', email: email | dig: 'items', 'results' | first
        if generated_token
            graphql set_profile = 'modules/portal/users/set_profile_to_invited_users', id: generated_token.id, token: generated_token.temporary_token
            graphql set_password_token = 'modules/portal/users/set_password_token_to_invited_users', id: generated_token.id, token: generated_token.temporary_token
        endif
    %}
    {%- graphql user_with_token = 'modules/portal/account/get_user_with_password_token', email: email | dig: 'users','results' | first -%}
    {%- assign user_data_default = user_with_token.default | first -%}

    {% comment %} ? EMAIL NOTIF {% endcomment %}
    {%- assign user_invitation = "modules/portal/user_invitation" -%}
    {% parse_json data %}
    {
        "email": "{{ email }}",
        "name": "{{ details.userFirstName }} {{ details.userLastName }}",
        "company": "{{ details.company }}",
        "password_token": "{{ user_data_default.password_token }}",
        "company_uuid": "{{ details.company_uuid }}",
        "permission_level": "{{ details.userPermission }}"
    }
    {% endparse_json %}
    {%- graphql trigger = "modules/website/trigger_email_notification", name: user_invitation, data: data -%}
        
{% endif %}
{% comment %} ? CLOSING ENDIF FOR TOGGLE OR INVITE {% endcomment %}


{% comment %} ? Event Stream {% endcomment %}
{% parse_json crm_data_event_stream %}
{
    "first_name": "{{ details.userFirstName }}",
    "last_name": "{{ details.userLastName }}",
    "email": "{{ email }}",
    "company_uuid": "{{ details.company_uuid }}",
    "mobile_phone_country_code": "{{ details.mobile_phone_country_code | default: 61 }}",
    "mobile_phone_number": "{{ details.mobile_phone_number }}",
    "permission_level": "{{ details.permission_level }}",
    "actions": "{{ details.actions }}",
    "company": "{{ details.company }}"
}
{% endparse_json %}

{% include 'modules/portal/users/invite_user_event_stream', data: crm_data_event_stream %}

