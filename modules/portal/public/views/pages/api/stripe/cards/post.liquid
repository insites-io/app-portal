---
slug: api/stripe/create-credit-card
format: json
method: post
searchable: false
metadata: {
  "status": "published",
  "open_graph:title": "Create Credit Card",
  "open_graph:description": "Create Credit Card",
  "meta_title": "Create Credit Card",
  "page_title": "Create Credit Card",
  "meta_description": "Create Credit Card",
  "canonical_url": "",
  "is_visible_to_search_engines": "false",
  "sitemap_priority": 0.0, ## primary order (DESC)
  "sitemap_order": 9999, ## secondary order (ASC)
  "sitemap_changefreq": "never"
}
---
{%- assign payload = context.params.payload | parse_json -%}

{%- assign status = 200 -%}
{% assign response = "{}" | parse_json %}

{%- assign stripe_customer_id = blank -%}
{%- assign user_id = blank -%}
{%- assign customer_email = payload.email | strip -%}
{%- assign customer_name = payload.first_name | append: " " | append: payload.last_name -%}

{%- comment -%} 
    NEW: STEP 1 - CHECK CONTACT IF STRIPE_ID HAS DETAILS 
{%- endcomment -%}
{%- graphql user_stripe_id = 'modules/portal/customers/get_user_stripe_id', email: customer_email | dig: 'items','results' | first -%}

{%- assign user_id = user_stripe_id.id -%}
{%- assign external_id = user_stripe_id.external_id -%}
{% assign get_stripe_id = user_stripe_id | dig: 'profiles' | first %}

{% if get_stripe_id.stripe_id %}
  
    {%- comment -%}Create new card object payload {%- endcomment -%}
    {% parse_json stripe_card %}
    {
        "contact_uuid": "{{ external_id }}",
        "payment_method_token":  "{{ get_stripe_id.stripe_id }}",
        "source": "{{ payload.stripe_credit_card }}"
    }
    {% endparse_json %}
    {%- comment -%} Bind Card to user {%- endcomment -%}
    {%- assign bind_card_user_id = user_id | default: blank -%}
    {%- comment -%}Create new card on Stripe API {%- endcomment -%}
    {%- capture new_stripe_credit_card -%}
        {%- include 'modules/portal/stripe/credit_cards/create_credit_card', 
            stripe_card: stripe_card,
            user_id: bind_card_user_id
            return: true -%}
    {%- endcapture -%}
    {%- assign new_stripe_credit_card = new_stripe_credit_card | strip_newlines | strip -%}

{% else %}
    {%- comment -%}Step 1-B: New customer: Create Stripe customer data{%- endcomment -%}    
    {% parse_json "stripe_customer" %}
    {
        "email": "{{ customer_email }}",
        "name": "{{ customer_name }}",
        "description": ""
    }
    {% endparse_json %}
    {% graphql stripe_create_customer = 'modules/website/trigger_api_call', 
        name: "modules/portal/create_customer",
        data: stripe_customer
        | dig: 'items' | dig: 'response' %}    

    {%- assign stripe_create_customer = stripe_create_customer.body | parse_json  -%}
    {%- assign stripe_customer_id = stripe_create_customer.id -%}

    {% comment %}
        Connect the Stripe ID to CRM
    {% endcomment %}
    {% parse_json connect_stripe_id %}
    {
        "id": "{{ user_id }}", 
        "email": "{{ customer_email }}",
        "stripe_id": "{{ stripe_customer_id }}"
    }
    {% endparse_json %}
    
    {% graphql update_contact = 'modules/website/trigger_api_call', name: 'modules/portal/update_contact', data: connect_stripe_id | dig: 'items','response','body' | parse_json %}

    {% parse_json stripe_card %}
    {
        "contact_uuid": "{{ external_id }}",
        "payment_method_token":  "{{ stripe_customer_id }}",
        "source": "{{ payload.stripe_credit_card }}"
    }
    {% endparse_json %}

    {%- include 'modules/portal/stripe/credit_cards/create_credit_card', 
        stripe_card: stripe_card -%}
{% endif %}

{%- comment -%}
  Return GraphQL reposponse & status code 200 or 400
{%- endcomment -%}
{{ response }}
{%- response_status status -%}