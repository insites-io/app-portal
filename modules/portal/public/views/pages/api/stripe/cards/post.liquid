---
slug: api/stripe/create-credit-card
format: json
method: post
searchable: false
metadata: {
  "status": "published",
  "open_graph:title": "Create Credit Card",
  "open_graph:description": "Create Credit Card",
  "meta_title": "Create Credit Card",
  "page_title": "Create Credit Card",
  "meta_description": "Create Credit Card",
  "canonical_url": "",
  "is_visible_to_search_engines": "false",
  "sitemap_priority": 0.0, ## primary order (DESC)
  "sitemap_order": 9999, ## secondary order (ASC)
  "sitemap_changefreq": "never"
}
---
{%- 
    liquid
    assign status = 200
    assign payload = context.params.payload | parse_json
    assign customer_email = payload.email | strip
    assign card_brand = payload.card_brand | default: null
    assign stripe_customer_id = blank
    assign user_id = blank
    assign guest_user = false 
    assign email_exist = false

    assign response = "{}" | parse_json

    function has_profile = "modules/website/layout/check_if_user_has_profile"

    if payload.first_name
        if has_profile
            assign customer_name = payload.first_name | append: " " | append: payload.last_name
        else
            assign customer_name = context.session.billing_contact_first_name | append: " " | append: context.session.billing_contact_last_name 
            assign guest_user = true
        endif
    else
        if has_profile
            assign customer_name = context.current_user.first_name | append: " " | append: context.current_user.last_name 
        else
            assign customer_name = context.session.billing_contact_first_name | append: " " | append: context.session.billing_contact_last_name 
            assign guest_user = true
        endif
    endif

    graphql user_exist = "modules/ecommerce/user/get_user_by_email", email: customer_email | dig: "items"

    if user_exist.total_entries > 0
        assign email_exist = true

        assign user_exist = user_exist | dig: 'results' | first 
        assign user_id = user_exist.id
        assign user_uuid = user_exist.uuid 
    endif

-%}
{% log guest_user, type:"guest_userguest_userguest_user"  %}
{% if guest_user == true %}
    {% comment %} 
        Guest User Workflow
        - Steps:
        - 1. Check if the email exists in the system.
        - 2. If yes, update the CRM data for the existing contact.
        - 3. If no, create a new user and add them to the CRM.
        - 4. Add the guest user info to the session.

        Note:
         - For guest users, we don't need to create a Stripe customer ID.
         - Guest payments are processed via Payment Intent or as one-time payments,
           without saving the customer or payment method for future use.
    {% endcomment %}
    {% if email_exist == false %}
        {% comment %} Create a new user. {% endcomment %}
        {%- parse_json new_user_data -%}
        {
            "email": "{{ customer_email }}",
            "first_name": "{{ context.session.billing_contact_first_name }}",
            "last_name": "{{ context.session.billing_contact_last_name }}",
            "password": "{{ password }}",
            "uuid": "{{ '' | uuid }}",
            "mobile_phone_number": "{{ context.session.billing_contact_phone_number }}",
            "mobile_phone_country_code": "{{ context.session.billing_contact_phone_country_code }}"
        }
        {%- endparse_json -%}
        {%- graphql new_user = 'modules/ecommerce/user/create_user', args: new_user_data -%}

        {%- assign user = new_user.user -%}
        {%- assign user_uuid = user.user_uuid -%}
        {%- assign user_id = user.id -%}

    {% else %}
        {% comment %} Update the CRM data for the existing user. {% endcomment %}
        {%- parse_json crm_data -%}
        {
            "id": "{{ user_id }}", 
            "email": "{{ customer_email }}",
            "first_name": "{{ context.session.billing_contact_first_name }}",
            "last_name": "{{ context.session.billing_contact_last_name }}",
            "mobile_phone_number": "{{ context.session.billing_contact_phone_number }}",
            "mobile_phone_country_code": "{{ context.session.billing_contact_phone_country_code }}"
        }
        {%- endparse_json -%}    
        {%- graphql update_contact = 'modules/ecommerce/system/trigger_api_call', name: 'modules/portal/update_contact', data: crm_data | dig: 'items','response','body' | parse_json -%}

    {% endif %}

    {% comment %} Add the guest user info to the session.{% endcomment %}
    {%- parse_json guest_info -%}
    {
        "id": "{{ user_id }}",
        "uuid": "{{ user_uuid }}",
        "card_brand": "pm_card_{{ card_brand | downcase }}"
    }
    {%- endparse_json -%}
    {% session guest_info = guest_info %}

{% else %}
    {% comment %}
        Logged-in User Workflow
        - Steps:
        - 1. Check if the user already has a Stripe ID.
        - 2. If yes, use the existing Stripe ID to create a new credit card for the user.
        - 3. If no, create a new Stripe customer, save the Stripe ID in CRM, and then create the credit card.
    {% endcomment %}

    {%- comment -%} 
        NEW: STEP 1 - CHECK CONTACT IF STRIPE_ID HAS DETAILS 
    {%- endcomment -%}
    {%- graphql user_stripe = 'modules/portal/customers/get_user_stripe_id', email: customer_email | dig: 'items','results' | first -%}
    {%- assign stripe_id = user_stripe | dig: 'profiles' | first | dig: 'stripe_id' -%}

    {% if stripe_id and stripe_id != '' %}
        {%- comment -%}Create new card object payload {%- endcomment -%}
        {% parse_json stripe_card %}
        {
            "contact_uuid": "{{ user_uuid }}",
            "payment_method_token":  "{{ stripe_id }}",
            "source": "{{ payload.stripe_credit_card }}"
        }
        {% endparse_json %}
        {%- comment -%}Create new card on Stripe API {%- endcomment -%}
        {%- include 'modules/portal/stripe/credit_cards/create_credit_card', stripe_card: stripe_card -%}
        
    {% else %}
        {% comment %} Create a new Stripe customer. {% endcomment %}
        {%- parse_json customer_data -%}
        {
            "email": "{{ customer_email }}",
            "name": "{{ customer_name }}",
            "description": ""
        }
        {%- endparse_json -%}
        {%- graphql create_stripe_customer = 'modules/website/trigger_api_call', name: "modules/portal/create_customer", data: customer_data | dig: 'items' | dig: 'response' -%}    
        
        {%- assign stripe_create_customer = stripe_create_customer.body | parse_json  -%}
        {%- assign stripe_customer_id = stripe_create_customer.id -%}


        {% if email_exist == true %}
            {% comment %} Save the Stripe ID in CRM. {% endcomment %}
            {%- parse_json crm_data -%}
            {
                "id": "{{ user_id }}", 
                "email": "{{ customer_email }}",
                "stripe_id": "{{ stripe_customer_id }}"
            }
            {%- endparse_json -%}    
            {%- graphql update_contact = 'modules/website/trigger_api_call', name: 'modules/portal/update_contact', data: crm_data | dig: 'items','response','body' | parse_json -%}
        {% else %}
            {% log "Error: Logged-in user has no CRM data" %}
        {% endif %}

        {% parse_json stripe_card %}
        {
            "contact_uuid": "{{ user_uuid }}",
            "payment_method_token":  "{{ stripe_customer_id }}",
            "source": "{{ payload.stripe_credit_card }}"
        }
        {% endparse_json %}

        {%- include 'modules/portal/stripe/credit_cards/create_credit_card', stripe_card: stripe_card -%}      

    {% endif %}

{% endif %}


{
    "stripe_id": "{{ context.exports.stripe_response.id }}",
    "is_new_user": {{ is_new_user | default: false }}
}
{%- response_status status -%}