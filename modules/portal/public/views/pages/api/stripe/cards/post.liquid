---
slug: api/stripe/create-credit-card
format: json
method: post
searchable: false
metadata: {
  "status": "published",
  "open_graph:title": "Create Credit Card",
  "open_graph:description": "Create Credit Card",
  "meta_title": "Create Credit Card",
  "page_title": "Create Credit Card",
  "meta_description": "Create Credit Card",
  "canonical_url": "",
  "is_visible_to_search_engines": "false",
  "sitemap_priority": 0.0, ## primary order (DESC)
  "sitemap_order": 9999, ## secondary order (ASC)
  "sitemap_changefreq": "never"
}
---
{%- 
    liquid
    assign status = 200
    assign payload = context.params.payload | parse_json
    assign customer_email = payload.email | strip
    assign customer_name = payload.first_name | append: ' ' | append: payload.last_name
    assign card_brand = payload.card_brand | default: null
    assign stripe_customer_id = blank
    assign user_id = blank 
    assign email_exist = false

    assign response = "{}" | parse_json
    graphql user_exist = "modules/portal/account/get_user_by_email", email: customer_email | dig: "items"

    if user_exist.total_entries > 0
        assign email_exist = true
        assign user_exist = user_exist | dig: 'results' | first 
        assign user_id = user_exist.id
        assign user_uuid = user_exist.uuid 
    endif

-%}

    {% comment %}
        Logged-in User Workflow
        - Steps:
        - 1. Check if the user already has a Stripe ID.
        - 2. If yes, use the existing Stripe ID to create a new credit card for the user.
        - 3. If no, create a new Stripe customer, save the Stripe ID in CRM, and then create the credit card.
    {% endcomment %}

    {%- comment -%} 
        NEW: STEP 1 - CHECK CONTACT IF STRIPE_ID HAS DETAILS 
    {%- endcomment -%}
    {%- graphql user_stripe = 'modules/portal/customers/get_user_stripe_id', email: customer_email | dig: 'items','results' | first -%}
    {%- assign stripe_id = user_stripe | dig: 'profiles' | first | dig: 'stripe_id' -%}

    {% if stripe_id and stripe_id != blank %}
        {%- comment -%}Create new card object payload {%- endcomment -%}
        {% parse_json stripe_card %}
        {
            "contact_uuid": "{{ user_uuid }}",
            "payment_method_token":  "{{ stripe_id }}",
            "source": "{{ payload.stripe_credit_card }}"
        }
        {% endparse_json %}
        {%- comment -%} Create new card on Stripe API: Export stripe_response {%- endcomment -%}
        {%- include 'modules/portal/stripe/credit_cards/create_credit_card', stripe_card: stripe_card -%}
        
    {% else %}
        {% comment %} Create a new Stripe customer. {% endcomment %}
        {%- parse_json customer_data -%}
        {
            "email": "{{ customer_email }}",
            "name": "{{ customer_name }}",
            "description": ""
        }
        {%- endparse_json -%}
        {%- graphql create_stripe_customer = 'modules/website/trigger_api_call', name: "modules/portal/create_customer", data: customer_data | dig: 'items','response' -%}    
        {%- assign stripe_create_customer = create_stripe_customer.body | parse_json -%}
        {%- assign stripe_customer_id = stripe_create_customer.id -%}


        {% if email_exist == true %}
            {% comment %} Save the Stripe ID in CRM. {% endcomment %}
            {%- parse_json crm_data -%}
            {
                "email": "{{ customer_email }}",
                "stripe_id": "{{ stripe_customer_id }}"
            }
            {%- endparse_json -%}  
            
            {% comment %} NOTE: Update CRM -> Contact via Controller {% endcomment %}
            {% function update_contact = "crm/controller/contacts/update", uuid: user_uuid, params: crm_data %}            
        {% else %}
            {% comment %} LOG: {% endcomment %}
            {% log "Error: Logged-in user has no CRM data" %}
            {% assign status = 400 %}
        {% endif %}

        {%- if stripe_customer_id -%}
            {% parse_json stripe_card %}
            {
                "contact_uuid": "{{ user_uuid }}",
                "payment_method_token":  "{{ stripe_customer_id }}",
                "source": "{{ payload.stripe_credit_card }}"
            }
            {% endparse_json %}
            {%- comment -%} Create new card on Stripe API: Export stripe_response {%- endcomment -%}
            {%- include 'modules/portal/stripe/credit_cards/create_credit_card', stripe_card: stripe_card -%}      
        {% endif %}

    {% endif %}


{
    "stripe_card_id": "{{ context.exports.stripe_response.id }}"
}
{%- response_status status -%}