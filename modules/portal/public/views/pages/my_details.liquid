---
slug: my-details
layout: modules/portal/portal_form
searchable: false
max_deep_level: 1
metadata: {
    "status": "published",
    "page_name": "My Details | Insites Portal",
    "open_graph:url": "{{ context.exports.global.company_url | strip }}",
    "open_graph:type": "",
    "open_graph:image": "",
    "open_graph:title": "",
    "open_graph:description": "",
    "open_graph:site_name": "{{ context.exports.global.company_name | strip }}",
    "meta_title": "",
    "page_title": "My Details | Insites Portal",
    "meta_description": "",
    "canonical_url": "",
    "is_visible_to_search_engines": false,
    "sitemap_enabled": false,
    "sitemap_priority": "1.0",## primary order (DESC)
    "sitemap_order": "0", ## secondary order (ASC)
    "sitemap_changefreq": "never",
    "heading": ""
}
authorization_policies:
  - modules/portal/is_user_logged_in
---

{%- graphql user = 'modules/portal/account/get_current_user' | dig: 'current_user' -%}  
{% assign user_company_uuid =  user | dig: 'crm_contact' | first  %}
{% comment %} Check if CRM Contact was assigned already to CRM Company {% endcomment %}
{%- if user.crm_contact[0].company_uuid != user.portal[0].company_uuid -%}
  {%- parse_json data -%}
  {
    "contact_uuids": [
        "{{ user.external_id }}"
    ]
  }
  {%- endparse_json -%}

  {% function assign_company_contact = "crm/controller/companies/assign-contacts", uuid: user_company_uuid.company_uuid, params: data %}  
{%- endif -%}

{% comment %} Check if user verified their account {% endcomment %}
{%- liquid
    if user.portal
        assign profile = user.portal[0]
        if profile != blank and profile.is_activated
            assign verified = true
        else
            assign verified = false            
        endif
    endif    
-%}

{% comment %} NOTE: Get CRM -> Contact via Controller {% endcomment %}
{% assign contact_uuid = user.external_id %}
{% function get_contact = "crm/controller/contacts/get", uuid: contact_uuid %}

{% comment %} NOTE: Get CRM -> Contact Address via Controller {% endcomment %}
{% assign contact_address_uuid = get_contact.default_address.uuid %}

{% if contact_address_uuid and contact_address_uuid != '' %}

  {% comment %} Default Address {% endcomment %}
  {% function get_contact_address = "crm/controller/addresses/get", type: "contact", uuid: contact_address_uuid %}

{% elsif contact_uuid and contact_uuid != '' %}

  {% comment %} First Address of the Contact {% endcomment %}
  {% parse_json address_params %}
  {
    "page": "1",
    "size": "1",
    "keyword": "{{ contact_uuid }}",
    "search_by": "contact.uuid"
  }
  {% endparse_json %}
  {% function get_contact_address = "crm/controller/addresses/list", type: "contact", params: address_params %}
  {% assign get_contact_address = get_contact_address | dig: "results" | first %}

{% endif %}

{% assign get_contact = get_contact | add_hash_key: "default_address", get_contact_address %}

<div class="my-details">    

    <h3 class="heading-3">My details</h3>
    <div class="spacer"></div>
    <p class="p-dark">Update your personal information, contact details, and preferences in your profile.</p>

     {%- if verified == false -%}
      <div class="small-12 cell text-center">
      </div>
    {%- endif -%} 
    <div class="spacer xxx-large"></div>
    <h5 class="heading-5">Account information</h5>
    <div class="spacer x-large"></div>
    {%- include_form 'modules/portal/my_details', id: user.id, data: get_contact -%}
    {%- include_form 'modules/portal/change_password', id: user.id -%}
    <div class="spacer xxxx-large hide-for-small-only"></div>
</div>


{% comment %} Search Address Script {% endcomment %}
{% include 'modules/website/layout/googlemaps' %}

<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
{%- if context.environment == "staging" -%}
  <script src="{{ 'modules/portal/scripts/address-lookup.js' | asset_url }}"></script>
  <script src="{{ 'modules/portal/scripts/user-profile.js' | asset_url }}"></script>
{%- else -%}
  <script src="{{ 'modules/portal/scripts/address-lookup.min.js' | asset_url }}"></script>
  <script src="{{ 'modules/portal/scripts/user-profile.min.js' | asset_url }}"></script>
{%- endif -%}

{%- if context.flash and context.flash.notice == "Success-My-Details" -%}
<script>
setTimeout(() => {
    App.events.notyf('success', "Account details has been updated.");
}, 200);
</script>
{% endif -%}

{%- if context.flash and context.flash.alert == "Error-My-Details" -%}
<script>
setTimeout(() => {
    App.events.notyf('error', "Error updating account detail.");
}, 200);
</script>
{% endif -%}
