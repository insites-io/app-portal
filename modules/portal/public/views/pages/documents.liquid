---
slug: documents
layout: modules/portal/portal_form
searchable: false
max_deep_level: 1
metadata: {
    "status": "published",
    "page_name": "My Documents",
    "open_graph:url": "",
    "open_graph:type": "",
    "open_graph:image": "",
    "open_graph:title": "My Documents | Insites",
    "open_graph:description": "My Documents | Insites",
    "open_graph:site_name": "",
    "meta_title": "My Documents | Insites",
    "page_title": "My Documents | Insites",
    "meta_description": "My Documents | Insites",
    "canonical_url": "",
    "is_visible_to_search_engines": true,
    "sitemap_enabled": true,
    "sitemap_priority": "1.0",## primary order (DESC)
    "sitemap_order": "1", ## secondary order (ASC)
    "sitemap_changefreq": "monthly",
    "heading": "My Documents"
}
authorization_policies:
  - modules/portal/is_user_logged_in
---
{%- comment -%} Pagination and Filters {%- endcomment -%}
{%  liquid            
    assign page_num = context.params.page | default: 1 | plus: 0
    assign per_page = context.params.per_page | default: 6 | plus: 0
    assign description = context.params.search | default: ""
%}

{% parse_json filters %}
{
    "user_id": "{{context.current_user.id}}",
    "page": {{page_num}},
    "size": {{per_page}}      
    {% if description != '' %} 
    ,"description": "{{description}}"
    {% endif %} 
}
{% endparse_json %}

{%- graphql data = "modules/portal/documents/get_documents", args: filters | dig: "items" -%}

<div class="documents">

    <div class="box">
        <p>Please upload your documents or files here.</p>
    </div>

    <div class="spacer xxx-large"></div>
    
    <input type="hidden" id="get-document-count" value='{{ data.total_entries }}'>

    {% if data.total_entries > 0 or params.search %}

    <div class="grid-x">
        <div class="cell large-5">
            <ins-button 
                id="add-document-btn"
                class="add-btn open-form-btn"
                label="Add Document" 
                icon="icon-plus" 
                solid 
                color="blue">
            </ins-button>
        </div>
        <div class="cell large-6 large-offset-1">
            <div class="hide-for-large spacer"></div>
            <ins-input                 
                id="search-description"
                class="search-item search-bars"
                placeholder="Search by Description"
                value="{{ context.params.search}}"
                icon="icon-search-1">
            </ins-input>
        </div>                
    </div>

    {% endif %}

    {% if data.total_entries > 0 %}

    <div class="grid-container client-card">

        <div class="grid-x grid-padding-x grid-padding-y">       
        {%- assign key = 0 -%}                 
        {%- for item in data.results -%}
        <div class="large-4 medium-12 small-12 cell align-stretch">
            {%- include "modules/portal/documents/list_card", item, key: key -%}
        </div>
        {%- assign key = key | plus: 1 -%} 
        {%- endfor -%}
        </div>
        
    </div>

    {% elsif params.search %}

    <div class="box no-item text-center mt-12">
        <div class="spacer xxxx-large"></div>
        <h4 class="heading-4">No result for search "{{params.search}}"</h4>
        <div class="spacer small"></div>        
        <div class="spacer xxxx-large"></div>
    </div>

    {% else %}

    <div class="box no-item text-center">
        <div class="spacer xxxx-large"></div>
        <h4 class="heading-4">No documents uploaded</h4>
        <div class="spacer small"></div>
        <ins-button 
            id="add-document-btn"
            class="add-btn open-form-btn"
            label="Add Document" 
            icon="icon-plus" 
            solid 
            color="blue">
        </ins-button>
        <div class="spacer xxxx-large"></div>
    </div>

    {% endif %}


    <ins-modal 
        id="modal-form"
        with-backdrop 
        confirmation value="DATA"
        height="auto"  
        no-button
        width="500px"
        class="no-close-icon document-modal-form">
        <div id="myModalContent">        
            {% include_form 'modules/portal/documents', id: :375 %}
        </div>
    </ins-modal>    

    <ins-table no-wrap
    static-table
    id="insBaseTable"
    {% if data.total_entries == 0 %}
        without-pagination
    {% endif %}
    without-search>    
    </ins-table>

</div>

<script>    
    let documentsForm = document.querySelector('form.documents-form');
    let submitFormBtn = document.getElementById('submit-form-btn');
    let noticeMessage = document.getElementById('notice-message');
   
    <!-- File Upload -->
    let insFileUploaderEl = document.getElementById('document-input');
    let documentFieldEl = document.getElementById('document');
    let table = "modules/portal/documents";
    let property = "file";

    <!-- Edit Document -->
    let data = {{data.results}};
    let index, method, value;
    let description = document.getElementById("description");
    let notes = document.getElementById("notes");
    let resource_id = document.querySelector("#documents-form input[name=resource_id]");

    <!-- Modal - Form -->
    let modalForm = document.getElementById('modal-form');
    let openFormBtn = document.querySelectorAll('.open-form-btn');
    let closeFormBtn = document.getElementById('close-form-btn');

    openFormBtn.forEach(field => {
        field.addEventListener('insClick', () => {
            modalForm.open();
            if(field.getAttribute("id") == "add-document-btn"){
                //Add Document
                documentsForm.action = "/api/customizations/";
                resource_id.value = "new";           
                method = document.querySelector("#documents-form input[name=_method]");  
                var document_heading = document.getElementById("document_heading");
                document_heading.innerText = "Add Document";   
                if(method != null){
                    method.remove();
                }
                submitFormBtn.label = "Add Document";
                noticeMessage.value = "Document successfully added.";
                description.value = "";
                documentFieldEl.value = "";
                notes.value = "";
                insFileUploaderEl.removeFiles();
            }else{
                //Edit Document
                index = field.getAttribute("data-index");
                documentsForm.action = "/api/customizations/" + data[index].id;                
                resource_id.value = data[index].id;
                method = document.querySelector("#documents-form input[name=_method]");
                var document_heading = document.getElementById("document_heading");
                document_heading.innerText = "Edit Document";
                if(method == null){
                    const el = document.createElement("input");
                    el.name = "_method";
                    el.type = "hidden";
                    el.value = "patch";
                    el.autocomplete = "off";            
                    documentsForm.appendChild(el);
                }

                //Fill existing data
                description.value = data[index].description;
                notes.value = data[index].notes;

                //Preview existing file
                let imageExtsions = ["jpg", "jpeg", "jfif", "pjpeg", "pjp", "apng", "png", "avif", "gif", "svg", "webp", "bmp", "ico", "tif", "tiff"];
                let type = imageExtsions.includes(data[index].file.extension)? "image" : "file";

                // Remove spaces, convert to lowercase, and replace invalid characters
                let fileName = data[index].file.file_name
                    .replace(/\s+/g, '-')      // Replace spaces with hyphens
                    .toLowerCase()             // Convert to lowercase
                    .replace(/[^a-z0-9\-\_\.]+/g, '');  // Remove any non-alphanumeric characters, except hyphen, underscore, and period

                value = [{
                    name: fileName,
                    type: `"${type}/${data[index].file.extension}"`,
                    url: data[index].file.url
                }]
                insFileUploaderEl.removeFiles();
                insFileUploaderEl.setFiles(value);

                submitFormBtn.label = "Update";
                noticeMessage.value = "Document successfully updated.";
            }
        });            
    });

    closeFormBtn.addEventListener('insClick', () => {
        modalForm.close();
    });    

    
                
    <!-- Filter List - Search Description -->
    let search = "{{description}}";
    let keywordInput = document.getElementById("search-description");
    if (keywordInput) {
        keywordInput.addEventListener('insInput', this.keywordInputEvent);
        keywordInput.addEventListener('insIconClick', this.keywordInputEvent);
    }
    function keywordInputEvent(event) {        
        if (event.detail.keyCode === 13) {            
            let tempURL = window.location.href.replace("?search="+search, "");
            tempURL = tempURL.replace("search="+search, "");
            let Qmark = tempURL.indexOf("?") == -1? "?" : "";
            let url = tempURL + Qmark + "search="+event.detail.value;                    
            window.location = url;
        }
    }

    <!-- Submit Form -->
    async function validateDocumentsForm(event) {
        event.preventDefault();
        submitFormBtn.loading = true;
        if (await App.validation.validateForm(documentsForm)) {
            await FileUpload.methods.processAttachments();
            documentsForm.submit();
            return true;
        } else {
            submitFormBtn.loading = false;
            return false;
        }
    }

    // Pagination
    insBaseTable.pageSizeOptions = [6,15,30];
    insBaseTable.totalCount = {{ data.total_entries }};
    insBaseTable.pageNumber = {{page_num}};
    insBaseTable.pageSize = {{per_page}};

    if(insBaseTable){
        setTimeout(() => {
            insBaseTable.querySelector(".ibt-table-wrap__pagination>span").innerHTML='Items per page';
        },600);            
    }

    insBaseTable.addEventListener('insPaginationChange', tablePaginationHandler);

    function processTableData(){

        // Get the current URL
        const currentUrl = window.location.href;

        // Remove any existing `page` and `per_page` query parameters
        const newUrl = currentUrl.replace(/[?&]page=\d+/, '').replace(/[?&]per_page=\d+/, '');

        // Set the new `page` and `per_page` values
        const newPage = pageNumber;
        const newPerPage = pageSize;

        // Append the new `page` and `per_page` query parameters to the URL
        const updatedUrl = `${newUrl}?page=${newPage}&per_page=${newPerPage}`;

        // Navigate to the updated URL
        window.location.href = updatedUrl;
    }

    function tablePaginationHandler(event){
        pageSize = event.detail.pageSize;
        pageNumber = event.detail.pageNumber;
        processTableData()
    }
</script>
{%- if context.environment == "staging" -%}
<script src="{{ 'modules/portal/scripts/file-upload.js' | asset_url }}"></script>
{% else %}
<script src="{{ 'modules/portal/scripts/file-upload.min.js' | asset_url }}"></script>
{%- endif -%}

{%- if context.flash.notice == "Success-Documents" -%}
<script>
let msg = "{{ context.session.document_notice_message | default: 'Document successfully added.' }}";
setTimeout(() => {
    App.events.notyf('success', msg);
}, 200);
</script>
{% endif -%}
