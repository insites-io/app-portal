---
slug: sign-in
layout: modules/portal/portal_system_pages
searchable: true
max_deep_level: 1
metadata: {
    "status": "published",
    "open_graph:url": "{{ context.exports.global.company_url | strip }}",
    "open_graph:type": "",
    "open_graph:image": "",
    "open_graph:title": "Sign-in | Insites Portal",
    "open_graph:description": "Sign in or create an account for the Insites Portal.",
    "open_graph:site_name": "{{ context.exports.global.company_name | strip }}",
    "meta_title": "Sign in to your account | Insites Portal",
    "page_title": "Sign-in | Insites Portal",
    "meta_description": "Sign in or create an account for the Insites Portal.",
    "canonical_url": "",
    "is_visible_to_search_engines": false,
    "sitemap_enabled": false,
    "sitemap_priority": "1.0",## primary order (DESC)
    "sitemap_order": "0", ## secondary order (ASC)
    "sitemap_changefreq": "never"
}
authorization_policies:
  - modules/portal/has_client_profile    
---

{%- if context.current_user -%}    
    {%- redirect_to '/overview' -%} 
{%- endif -%} 

<div class="sign-up grid-x">
    <div class="large-8 cell sign-in-field">
        <h3 class="heading-3">Sign in</h3>
        <div class="spacer x-small"></div>
        <p class="p-body p-dark">Log in to your account for access to your services.</p>
        <div class="spacer x-large"></div>
        {%- include_form 'modules/portal/sign_in' -%}
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
{%- if context.environment == "staging" -%}
    <script src="{{ 'modules/portal/services/apiServices.js' | asset_url }}"></script>
    <script src="{{ 'modules/portal/scripts/login-scripts.js' | asset_url }}"></script>
{%- else -%}
    <script src="{{ 'modules/portal/services/apiServices.min.js' | asset_url }}"></script>
    <script src="{{ 'modules/portal/scripts/login-scripts.min.js' | asset_url }}"></script>
{%- endif -%}

{%- if context.flash.alert == "Sorry-SignIn"-%}
    <script>
    setTimeout(() => {
        App.events.notyf('error', "Please check your email and password.");
    }, 200);
    </script>
{% endif -%}
    