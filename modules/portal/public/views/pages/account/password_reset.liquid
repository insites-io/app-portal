---
slug: password-reset
layout: modules/portal/portal_system_pages
searchable: false
max_deep_level: 1
metadata: {
    "status": "published",
    "page_name": "Portal | Password Reset",
    "open_graph:url": "{{ context.exports.global.company_url | strip }}",
    "open_graph:type": "",
    "open_graph:image": "",
    "open_graph:title": "",
    "open_graph:description": "",
    "open_graph:site_name": "{{ context.exports.global.company_name | strip }}",
    "meta_title": "",
    "page_title": "Reset Password | Insites Portal",
    "meta_description": "",
    "canonical_url": "",
    "is_visible_to_search_engines": false,
    "sitemap_enabled": false,
    "sitemap_priority": "1.0",## primary order (DESC)
    "sitemap_order": "0", ## secondary order (ASC)
    "sitemap_changefreq": "never"
}
---
{% assign email = params.email | base64_url_safe_decode %}
{%- graphql user_with_token = 'modules/portal/account/get_user_with_password_token', email: email | dig: 'users','results' | first -%}
{% assign token_valid = params.token | is_token_valid: user_with_token.id %}

{%- if context.flash.notice or context.flash.alert -%}
    {%- comment -%} If any flash notice or alert is pressent {%- endcomment -%}

    {%- if context.flash.notice != blank -%}
        {%- parse_json messageInfo -%}
        {
            "title" : "Password changed!",
            "type": "success",
            "message": "<p class='p-dark p-body'>Your password has been changed successfully.<br> <br> You can now proceed to <a class='a-label-no-visit' href='/sign-in'>sign in.</a></p>"
        }
        {%- endparse_json -%}
        {%- include 'modules/portal/system/form_result', messageInfo: messageInfo -%}

    {%- else -%}
        {% if params.token == nil or params.token == '' or params.email == nil or params.email == '' %}
            {%- redirect_to '/404' -%}
        {% else %}
            {%- include_form 'modules/portal/password_reset', id: user_with_token.id  -%}
        {% endif %}
    {%- endif -%}

{%- else -%}
    {% if params.token == nil or params.token == '' or params.email == nil or params.email == '' %}
        {%- redirect_to '/404' -%}
    {% else %}
        
        {%- comment -%} If there is no flash notice or alert {%- endcomment -%}
        {% if user_with_token.id == blank or token_valid == false or user_with_token.default[0].password_token != params.token %}
            <div class="sign-up">
            <div class="grid-x align-left">
                <div class="large-5 medium-9 samll-12 cell">
                    <div class="spacer xxx-large"></div>
                    <div class="large-12 medium-12 small-12 cell text-center">
                        <div class="system-pages warning spacer">
                            <i class="icon-alert-triangle"></i>
                        </div>
                        <h2 class="sub-title">Invalid Token</h2>
                        <div class="spacer small"></div>
                        <div class="context">
                            <p>Unfortunately, provided token is not valid anymore. Please request password instructions again.</p>
                        </div>
                        <div class="spacer x-large"></div>      
                        {%- graphql user_with_token = 'modules/portal/account/get_user_with_password_token', email: context.current_user.email | dig: 'users','results' | first -%}
                        {%- assign user_data_default = user_with_token.default | first -%}
        
                        <ins-button class="margin-top-small hydrated" label="Resend the authentication email" color="solid blue" onclick="document.location.href = '/generate-password-token?email={{ user_with_token.email | url_encode }}';">
                        </ins-button>
                    </div>
                    <div class="spacer xxxx-large"></div>
                </div>
            </div>
        </div>

        {%- else -%}         
            {%- include_form 'modules/portal/password_reset', id: user_with_token.id  -%}                
        {%- endif -%}
    {% endif %}

{%- endif -%}


<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>
{%- if context.environment == "staging" -%}
    <script src="{{ 'modules/portal/services/apiServices.js' | asset_url }}"></script>
    <script src="{{ 'modules/portal/scripts/login-scripts.js' | asset_url }}"></script>
{%- else -%}
    <script src="{{ 'modules/portal/services/apiServices.min.js' | asset_url }}"></script>
    <script src="{{ 'modules/portal/scripts/login-scripts.min.js' | asset_url }}"></script>
{%- endif -%}