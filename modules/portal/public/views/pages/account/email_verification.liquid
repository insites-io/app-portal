    "page_name": "Portal | Email Verification",
    "open_graph:url": "{{ context.exports.global.company_url | strip }}",
    "open_graph:type": "",
    "open_graph:image": "",
    "open_graph:title": "Email Verification | {{ context.exports.global.company_name | strip }}",
    "open_graph:description": "Email Verification | {{ context.exports.global.company_name | strip }}",
    "open_graph:site_name": "{{ context.exports.global.company_name | strip }}",
