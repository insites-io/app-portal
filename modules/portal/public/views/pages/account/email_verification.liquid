---

{%- graphql user_with_token = 'modules/portal/account/get_user_with_password_token', email: params.email | dig: 'users','results' | first -%}
{% assign token = context.location.search.token %}
{% assign user_id = user_with_token.id %}
{% assign token_valid = token | is_token_valid: user_id %}

{% if user_id == blank or token_valid == false or user_with_token.portal[0].verification_token != params.token %}

    <div class="sign-up">
        <div class="grid-x align-center">
            <div class="large-5 medium-9 samll-12 cell text-center">
                <div class="spacer xxx-large"></div>
                <div class="spacer x-large"></div>
                <p><strong>Unfortunately, provided token is not valid anymore.<br> Please request another verification instruction by trying to <a href="/sign-up">sign up</a> again.</strong></p>
                <div class="spacer section"></div>
            </div>
        </div>
    </div>

{% else %}
    {% graphql verifyResult = 'modules/portal/account/verify_email', id: user_id, token: user_with_token.portal[0].verification_token %}

    {% if verifyResult.items  %}

        {%- parse_json messageInfo -%}
        {
            "title" : "Success",
            "type": "success",
            "message": "<p>Your email has been verified. You may now continue to <a style='color:#436CF2 !important' href='/sign-in'><strong>sign in</strong></a>.</p>"
        }
        {%- endparse_json -%}
        {%- include 'modules/portal/system/form_result', messageInfo: messageInfo -%}

    {% endif %}
    
{% endif %}