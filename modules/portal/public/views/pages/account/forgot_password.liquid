{%- if context.current_user -%}    
    {%- redirect_to '/overview' -%} 
{%- endif -%} 

{%- if context.flash.notice != blank -%}

{%- parse_json messageInfo -%}
{
    "title" : "Success",
    "type": "success",
    "message": "<p>If you provided the right email, we will send you the reset password instructions.</p><div class='spacer'></div><p>Go to <a href='/sign-in'>sign in</a>"
}
{%- endparse_json -%}
{%- include 'modules/portal/system/form_result', messageInfo: messageInfo -%}

{%- else -%}

<div class="sign-up grid-x">
    <div class="large-offset-4 large-5 medium-offset-3 medium-8 small-12 cell">
        <h1 class="heading-1 text-center">Forget your password?</h1>
        <div class="spacer x-small"></div>
        <p class="text-center">Enter your email address below and we'll get you back on track</p>
        <div class="spacer xxx-large"></div>

        {%- include_form 'modules/portal/forgot_password' -%}
    </div>
</div>

{%- endif -%}



<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.19.0/axios.min.js"></script>

{%- if context.environment == "staging" -%}
    <script src="{{ 'modules/portal/services/apiServices.js' | asset_url }}"></script>
    <script src="{{ 'modules/portal/scripts/login-scripts.js' | asset_url }}"></script>
{%- else -%}
    <script src="{{ 'modules/portal/services/apiServices.min.js' | asset_url }}"></script>
    <script src="{{ 'modules/portal/scripts/login-scripts.min.js' | asset_url }}"></script>
{%- endif -%}