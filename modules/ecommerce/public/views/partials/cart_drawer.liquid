<ins-button 
  label="Open Inner" 
  solid color="blue" 
  id="openDrawerEl">
</ins-button>


<!-- Drawer inside iframe -->

<ins-drawer 
  label="Cart (4)" 
  custom-width="390px" 
  position="right" 
  id="drawerEl"
  class="cart-drawer">

    {% for i in (1..4) %}
    <div class="grid-x" >
        <div class="cell grid-y large-7">
            <h6>UrbanLounge Sectional</h6>
            <p class="body-x-small">SKU 9SIAJB7APH0171</p>
            <div class="spacer x-small"></div>
            <p>
                <span class="body-x-small-bold">Colour:</span>
                <span class="body-x-small">Yellow</span>
            </p>
            <p>
                <span class="body-x-small-bold">Price:</span>
                <span class="body-x-small">$130.00</span>
            </p>
        </div>
        <div class="cell grid-y large-5 text-right">
            <p class="cart-price">$130.00</p>
            <div class="spacer x-small"></div>
            <ins-input-stepper
                id="qty-cart-{{ cart_item.id }}" 
                class="quantity-cart" 
                value="{{ cart_item.properties.quantity }}" 
                step="1" min="1" 
                max="{{ max_qty }}" 
                small>
            </ins-input-stepper>
        </div>        
    </div>
    <div class="text-right" >
        <ins-button label="Remove" icon="icon-trash-2" size="small" ></ins-button>
    </div>
    <div class="spacer x-large"></div>
    {% endfor %}

    <div class="spacer"></div>
    <div class="grid-x align-justify" >
        <p class="heading-3-small font-color-head">Sub Total</p>
        <p class="heading-3-small font-color-head">$3,142.55</p>
    </div>
    <div class="spacer"></div>
    <ins-button label="Go to Cart" icon="icon-shopping-cart" solid></ins-button>
    <div class="spacer x-small"></div>
    <ins-button label="Continue Shopping" icon="icon-arrow-back" size="small" ></ins-button>




</ins-drawer>

<script>
  // this button opens the <ins-drawer> inside of the iframe
  document.getElementById('openDrawerEl').addEventListener('insClick', function() {
    document.getElementById('drawerEl').setDrawerState(true);
  });
</script>